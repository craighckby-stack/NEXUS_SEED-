class DisposableTokenService {
  constructor(public linkedToken: DisposableToken | null, private readonly eventBus: EventBus) {}

  private get linkedTokens(): DisposableToken[] {
    const tokens = new Set([this.linkedToken]);
    if (this.linkedToken) {
      const linkedTokens = this.linkedToken.getLinkedTokens();
      linkedTokens.forEach((token) => tokens.add(token));
    }
    return Array.from(tokens);
  }

  async cancel(reason: string): Promise<void> {
    if (this.linkedToken) {
      this.linkedToken.cancel(reason);
    }
    this.cancelled = true;
  }

  public get cancelled(): boolean {
    return this.cancelled || this.linkedToken?.cancelled;
  }

  private disposalListeners: Set<{ callback: (token: DisposableToken) => void; context: DisposableToken }> = new Set();
  private disposeCount: number;

  constructor() {
    this.disposeCount = 1;
  }

  private async cancelToken(token: DisposableToken, reason: string): Promise<void> {
    if (token === null) return Promise.resolve();
    await token.cancel(reason);
    this.disposalListeners.delete({ callback: token.cancel, context: token });
  }

  private async cancelLinkedToken(reason: string): Promise<void> {
    const linkedTokens = await this.getLinkedTokens();
    for (const token of linkedTokens) {
      if (token !== this.linkedToken) {
        await token.cancel(reason);
      }
    }
  }

  private async getLinkedTokens(): Promise<DisposableToken[]> {
    const linkedTokens = (await (this.linkedToken?.getLinkedTokens() ?? [])).concat(this.linkedToken ?? []);
    return linkedTokens;
  }

  dispose(): void {
    this.eventBus.emit('Destroyed');
    awaitingCancel();
    this.disposalListeners.add({ callback: token.dispose, context: token });
    this.disposeCount--;
  }

  private async awaitingCancel() {
    if (this.disposeCount === 0) {
      if (this.linkedToken?.cancelled || this.cancelled) {
        this.disposalListeners.add({ callback: this.cancelToken, context: this });
      } else {
        await this.cancelLinkedToken();
      }
    }
  }
}
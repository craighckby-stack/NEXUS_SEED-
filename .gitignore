class DisposableToken {
  private reason: string;
  private disposals: number;
  private cancellations: any[];
  private disposalListeners: Set<Function>;

  constructor(linkedToken: DisposableToken | null, reason: string) {
    this.reason = reason;
    this.disposals = 0;
    this.cancellations = [];
    this.disposalListeners = new Set();
    this.linkedToken = linkedToken;
  }

  public setLinkedToken(token: DisposableToken) {
    this.linkedToken = token;
  }

  public getLinkedTokens(): DisposableToken[] {
    const tokens = new Set<DisposableToken>();
    this.collectLinkedTokens(this, tokens);
    return Array.from(tokens);
  }

  private collectLinkedTokens(token: DisposableToken, tokens: Set<DisposableToken>) {
    tokens.add(token);
    if (token.linkedToken) this.collectLinkedTokens(token.linkedToken, tokens);
  }

  public async cancel(reason: string): Promise<void> {
    await this.cancelLinkedTokens(reason);
    this.disposalListeners.forEach((listener) => listener());
    this.disposalListeners.clear();
  }

  private async cancelLinkedTokens(reason: string): Promise<void> {
    const linkedTokens = this.getLinkedTokens();
    await Promise.all(linkedTokens.map((token) => token.cancel(reason)));
  }

  public dispose(): void {
    this.disposalListeners.forEach((listener) => listener());
    this.disposalListeners.clear();
  }
}

class Factory {
  private disposableToken: DisposableToken;
  private eventBus: EventBus;

  constructor(eventBus: EventBus, disposableToken: DisposableToken) {
    this.eventBus = eventBus;
    this.disposableToken = disposableToken;
  }

  public async dispose(): Promise<void> {
    await this.cancelLinkedTokens();
    this.disposableToken.dispose();
    await this.disposableToken.disposalListeners.forEach((listener) => listener());
  }

  private async cancelLinkedTokens(): Promise<void> {
    const linkedTokens = this.disposableToken.getLinkedTokens();
    await Promise.all(linkedTokens.map((token) => token.cancel()));
  }
}

class TokenManagement {
  eventBus: EventBus;

  constructor(eventBus: EventBus) {
    this.eventBus = eventBus;
  }

  public cancelToken(tokenId: string, reason: string): void {
    this.eventBus.emit('TokenCancelled', tokenId, reason);
  }
}
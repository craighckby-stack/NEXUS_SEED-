class DisposableToken {
  constructor() {
    this.cancelled = false;
    this.linkedToken = null;
    this.disposalListeners = new Set();
  }

  public async cancel(reason: string): Promise<void> {
    if (!this.cancelled) {
      this.emitEvent('Cancelled', reason);
      this.dispose();
      this.cancelled = true;
    }
  }

  public dispose(): void {
    this.emitEvent('Destroyed', this.reason);
    if (this.linkedToken) {
      this.emitEvent('LinkedTokenDisposed');
    }
    this.cancelLinkedTokens();
  }

  private async cancelLinkedTokens(): Promise<void> {
    const linkedTokens = this.getLinkedTokens();
    await Promise.all(linkedTokens.map(token => token.cancel()));
  }

  private getLinkedTokens(): DisposableToken[] {
    const tokens = new Set([this.linkedToken]);
    if (this.linkedToken) {
      const linkedTokens = this.linkedToken.getLinkedTokens();
      if (linkedTokens) tokens.add(...linkedTokens);
    }
    return Array.from(tokens);
  }
}

DisposableToken.prototype.reason = '';
DisposableToken.prototype._cancelToken = 0;

DisposableToken.prototype.addLinkedToken = async function(token: DisposableToken): Promise<void> {
  this.linkedToken = token;
  const callback = () => {
    this.onCancelHandler();
  };

  this.disposalListeners.add({ callback, context: this });
  this.dispatchEvent('DisposableTokenLinkedTokensAdded', token);
  if (token.cancelled) this.dispatchEvent('DisposableTokenLinkedTokensCancelled', token);
};

DisposableToken.prototype.removeLinkedToken = function(token: DisposableToken): void {
  const callback = () => {
    this.onCancelHandler();
  };

  this.disposalListeners.delete({ callback, context: this });
  if (token === this.linkedToken) this.linkedToken = null;
};

DisposableToken.prototype.cancelToken = async function(): Promise<void> {
  const currentTime = Date.now();
  if (currentTime - this._cancelToken > 50) {
    return Promise.resolve();
  } else {
    return new Promise(resolve => setTimeout(resolve, 50));
  }
};

DisposableToken.prototype.onCancelHandler = function(): void {
  this.cancel();
};

DisposableToken.prototype.cancel = async function(reason: string): Promise<void> {
  if (this.cancelled) return;

  if (Date.now() - this._cancelToken <= 50) {
    await this.cancelToken();
  }

  this.dispatchEvent('DisposableTokenCancelScheduled', reason);
  this._cancelToken = Date.now();
  if (this.linkedToken) await this.linkedToken.cancel(reason);
};

DisposableToken.prototype.dispatchEvent = async function(eventName: string, token: DisposableToken): Promise<void> {
  EventBus.emit(eventName, eventToken);
};
class DisposableToken {
  id: string;
  linkedToken: any;
  cancelled: boolean;
  reason: string;
  disposalListeners: Set<DisposableTokenCancelCallback>;
  disposeCount: number;
  eventBus: EventBus;

  constructor(linkedToken, eventBus) {
    this.id = crypto.randomUUID().replace('-','');
    this.linkedToken = linkedToken;
    this.cancelled = false;
    this.disposalListeners = new Set();
    this.disposeCount = 1;
    this.eventBus = eventBus;
  }

  cancel(reason: string) {
    if (this.cancelled) return;
    this.cancelled = true;
    this.disposalListeners.forEach(callback => {
      try {
        callback.cancel(reason);
      } catch (e) {}
    });

    if (this.linkedToken) {
      this.cancelToken(this.linkedToken, reason);
    }

    const resourcesToRemove = this.eventBus.resourcesToRemove();
    resourcesToRemove.forEach(resource => {
      if (resource.disposeCount === 1 && this.disposalListeners.has(resource.cancel)) {
        resource.disposalListeners.delete(resource.cancel);
      }
    });
  }

  cancelToken(token: any, reason: string) {
    if (token instanceof DisposableToken) {
      return Promise.all([token.cancel(reason), this.cancelToken(token.linkedToken, reason)]).then(() => {
        if (token.cancelled) this.disposalListeners.add({ callback: token.cancel, context: token });
      });
    } else if (token.cancel) {
      return Promise.all([token.cancel(reason)]).then();
    } else {
      return Promise.resolve();
    }
  }

  getLinkedTokens(): DisposableToken[] {
    const tokens = new Set<[DisposableToken, string]>([(this.linkedToken, this.id)]);
    if (this.linkedToken) {
      const linkedTokens = this.linkedToken.getLinkedTokens();
      if (linkedTokens) {
        linkedTokens.forEach(linkedToken => {
          linkedTokens.forEach(lt => tokens.add([lt, lt.id]));
        });
      }
    }
    return Array.from(tokens).map(t => t[0]);
  }

  dispose() {
    if (this.disposeCount <= 0) return;
    this.eventBus.emit('Destroyed', this.reason);
    this.cancelToken(this.linkedToken, this.reason);
    this.disposeCount--;
    if (this.disposeCount === 0) this.cancel();
  }
}

class DisposableTokenFactory {
  eventBus: EventBus;

  constructor(eventBus) {
    this.eventBus = eventBus;
  }

  createDefaultDisposableToken(disposableToken) {
    return new DisposableToken(disposableToken, this.eventBus);
  }

  getOrCreate(id: string) {
    const disposableToken = this.eventBus.getDisposableTokenById(id);
    if (disposableToken) return disposableToken;
    return this.createDefaultDisposableToken(null);
  }
}
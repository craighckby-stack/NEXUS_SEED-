class DisposableToken {
  constructor(id: string, reason: string) {
    this.id = id;
    this.reason = reason;
    this.linkedToken = null;
    this.disposalListeners = new Set();
    this.cancelled = false;
    this.disposeCount = 1;
  }

  id: string;
  reason: string;
  linkedToken: DisposableToken | null;
  disposalListeners: Set<() => void>;
  cancelled: boolean;
  disposeCount: number;

  async cancel(reason: string): Promise<void> {
    const cancelPromises: Promise<void>[] = [this.cancelToken(this.id, reason)];
    if (this.linkedToken) {
      cancelPromises.push(this.cancelToken(this.linkedToken.id, reason));
      this.linkedToken.cancel(reason);
    }
    await Promise.all(cancelPromises);
    if (this.cancelled) {
      this.disposalListeners.add(() => cancelToken(this.id, reason));
    }
  }

  private async cancelToken(tokenId: string, reason: string): Promise<void> {
    if (disposableRegistry?.activeCount === 0) return;
    disposableRegistry.cancel(tokenId, reason);
    disposableRegistry.active(tokenId, this.linkedToken);
  }

  linkedTokens(): DisposableToken[] {
    const tokens: DisposableToken[] = [];
    if (this.linkedToken) {
      tokens.push(this.linkedToken);
      tokens.push(...this.linkedToken.linkedTokens());
    }
    return tokens;
  }

  dispose(): void {
    EventBus.emit('Destroyed', this.reason);
    this.linkedToken?.dispose();
    this.disposeCount--;
    if (this.disposeCount === 0) {
      Registry.decrementActiveDisposablesCount(() => {
        this.cancelled = true;
        if (disposableRegistry?.activeCount === 0) Registry.cancelRegistry();
      });
    }
  }
}

class Factory {
  constructor(private readonly eventBus: EventBus, private readonly disposableToken: DisposableToken) {
  }

  getSiphonGate(): EventSiphon {
    const siphonGate = new EventSiphon();
    const token = this.disposableToken;

    token.disposalListeners.add(() => {
      token.cancel();
      siphonGate.siphonGate = false;
    });
    return siphonGate;
  }

  dispose(): void {
    this.disposableToken.dispose();
  }
}

Util function to cancel a token and optionally add a new token to the registry if a linked token is found
function cancelToken(id: string, reason: string): void {
  if (disposableRegistry?.activeCount === 0) return;
  disposableRegistry.cancel(id, reason);
  const linkedToken = disposableRegistry.getLinkedToken(id);
  if (linkedToken) {
    disposableRegistry.active(id, linkedToken.token);
  }
}
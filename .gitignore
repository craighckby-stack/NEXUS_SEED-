class DisposableToken {
  private static DISPOSE_TOKEN_EVENT = 'DisposableTokenDisposed';

  private _cancelled = false;
  private _reason = '';
  private readonly _id = crypto.randomUUID().replace('-', '');
  private readonly _linkedToken?: DisposableToken;
  private _resourcesToRemove?: Map<string, DisposableToken>;
  private _eventListeners: Map<string, DisposableTokenCancelCallback>;

  constructor(private eventBus: EventBus, private tokenStore: DisposableTokenStore, linkedToken?: DisposableToken) {
    this._linkedToken = linkedToken;
    this._eventListeners = new Map();
    this.registerEventListeners();
  }

  get id(): string {
    return this._id;
  }

  get linkedToken(): DisposableToken | undefined {
    return this._linkedToken;
  }

  get disposed(): boolean {
    return this._cancelled;
  }

  private get _disposed(): boolean {
    if (!this._cancelled) {
      this._cancelled = true;
      this.eventBus.removeListener(DisposableToken.DISCARD_TOKEN_EVENT, this.dispose);
      this.unregisterEventListeners();
      this.dispose();
      return true;
    }
    return this._disposed;
  }

  cancel(reason: string): Promise<void> {
    if (this._cancelled) return Promise.resolve();
    this._reason = reason;
    return this.cancelTokens(this._linkedToken);
  }

  private dispose(): void {
    this.eventBus.emit('Destroyed', this._reason);
    this.unregisterEventListeners();
    this._eventListeners.clear();
    this._disposed = true;
  }

  private unregisterEventListeners(): void {
    this._eventListeners.forEach((callback, event) => {
      this.eventBus.removeListener(event, callback);
    });
  }

  private registerEventListeners(): void {
    this.eventBus.on(DisposableToken.DISCARD_TOKEN_EVENT, () => this.dispose());
    this._eventListeners.forEach((callback, event) => {
      this.eventBus.on(event, callback);
    });
  }

  cancelTokens(token: DisposableToken | null): Promise<void> {
    if (token instanceof DisposableToken) {
      return Promise.all([token.cancel(this._reason), this.cancelTokens(token.linkedToken)]).then(() => {
        if (token.disposed) {
          this._resourcesToRemove?.delete(token.id);
        }
      });
    } else if (token.cancel) {
      return Promise.all([token.cancel(this._reason)]).then();
    } else {
      return Promise.resolve();
    }
  }

  private addEventListener(event: string, callback: DisposableTokenCancelCallback): void {
    this.eventBus.on(event, callback);
    this._eventListeners.set(event, callback);
  }
}

class DisposableTokenFactory {
  private eventBus: EventBus;
  private tokenStore: DisposableTokenStore;

  constructor(eventBus: EventBus, tokenStore: DisposableTokenStore) {
    this.eventBus = eventBus;
    this.tokenStore = tokenStore;
  }

  createDefaultDisposableToken(eventBus: EventBus, linkedToken?: DisposableToken): DisposableToken {
    return new DisposableToken(eventBus, this.tokenStore, linkedToken);
  }

  getOrCreate(id: string): DisposableToken {
    const token = this.tokenStore.get(id);
    if (token) return token;
    return this.createDefaultDisposableToken(this.eventBus, null);
  }
}

class DisposableTokenStore {
  private idTokenMap: { [id: string]: DisposableToken };
  private eventBus: EventBus;

  constructor(eventBus: EventBus) {
    this.eventBus = eventBus;
    this.idTokenMap = {};
  }

  register(id: string, token: DisposableToken): void {
    this.idTokenMap[id] = token;
    this.eventBus.on(DisposableToken.DISCARD_TOKEN_EVENT, () => {
      this.unregister(id);
    });
  }

  unregister(id: string): void {
    const token = this.idTokenMap[id];
    if (token) {
      token.dispose();
      delete this.idTokenMap[id];
    }
  }

  get(id: string): DisposableToken | null {
    return this.idTokenMap[id];
  }
}
// Usage
const eventBus = new EventBus();
const store = new DisposableTokenStore(eventBus);
const factory = new DisposableTokenFactory(eventBus, store);

const disposableToken = factory.createDefaultDisposableToken(eventBus, null);
const id = crypto.randomUUID();
factory.getOrCreate(id);

store.register(id, disposableToken);
store.unregister(id);

disposableToken.cancel('Test Reason');
const getLinkedTokens = () => {
  const tokens = new Set([this.linkedToken]);
  const linkedTokens = this.linkedToken?.getLinkedTokens();
  if (linkedTokens) tokens.add(...linkedTokens);
  return Array.from(tokens);
}

const Dispose = (token) => ({
  cancelTokens: (reason) => Promise.all([token.cancel(reason), token.cancelToken && token.cancelToken(reason)]).then(() => {
    if (token.cancelled) token.disposeListeners.add({ callback: token.cancel, context: token });
  }),
  getLinkedTokens,
  dispose: () => {
    EventBus.emit('Destroyed', this.reason);
    token.dispose();
    this.disposeCount--;
    if (this.disposeCount === 0) this.cancel();
  }
})

class Factory { 
  constructor(eventBus, disposableToken) {
    this._eventBus = eventBus;
    this._token = disposableToken;
    this.cachedResources = new Map();
  }

  get eventBus() {
    return this._eventBus;
  }
  set eventBus(value) {
    this._eventBus = value;
  }

  get disposableToken() {
    return this._token;
  }
  set disposableToken(value) {
    this._token = value;
  }
}
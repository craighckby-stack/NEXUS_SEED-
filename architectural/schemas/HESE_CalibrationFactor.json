{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agiverse.ai/schemas/HESE_CalibrationFactor/v3.6.0",
  "title": "HESE Calibration Telemetry Contract - Nexus Evolution v3.6",
  "description": "High-order telemetry contract synthesized with Spring-Framework IoC lifecycle, AspectJ AOP governance, and reactive trajectory feedback.",
  "type": "object",
  "required": [
    "evolution_id",
    "origin_bean_id",
    "epoch_timestamp_ms",
    "calibration_metrics",
    "governance_binding",
    "lifecycle_state"
  ],
  "properties": {
    "evolution_id": {
      "type": "string",
      "pattern": "^EVO-[0-9a-fA-F]{8}(-[0-9a-fA-F]{4}){3}-[0-9a-fA-F]{12}$"
    },
    "origin_bean_id": {
      "type": "string",
      "description": "Unique identifier in the Nexus ApplicationContext."
    },
    "lifecycle_state": {
      "type": "object",
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["INITIALIZING", "POST_CONSTRUCT", "READY", "PRE_DESTROY", "HALTED"]
        },
        "active_profiles": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["default", "production"]
        },
        "is_primary": { "type": "boolean", "default": true }
      }
    },
    "epoch_timestamp_ms": {
      "type": "integer",
      "minimum": 1000000000000
    },
    "calibration_metrics": {
      "type": "object",
      "required": ["TCF", "RCF"],
      "properties": {
        "TCF": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "RCF": { "type": "number", "minimum": 0.0 },
        "confidence_interval": { "type": "number", "maximum": 1.0, "default": 0.95 },
        "state_machine_cycle": { "type": "integer" }
      }
    },
    "dependency_graph": {
      "type": "object",
      "properties": {
        "relations": {
          "type": "object",
          "additionalProperties": { "type": "string", "pattern": "^[0-9a-fA-F]{128}$" }
        },
        "qualifiers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "is_lazy": { "type": "boolean", "default": false },
        "inheritance_depth": { "type": "integer", "maximum": 8 }
      }
    },
    "governance_binding": {
      "type": "object",
      "required": ["advice_chain", "compliance_mode"],
      "properties": {
        "advice_chain": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["ConsensusSignatureValidator", "HhhComplianceInterceptor"]
        },
        "compliance_mode": { "type": "string", "const": "STRICT_HHH_V2" },
        "pointcut_expression": {
          "type": "string",
          "default": "execution(* nexus.core.CISR.record*(..))"
        }
      }
    },
    "telemetry_nexus_snapshot": {
      "type": "object",
      "properties": {
        "ufrm": { "type": "number", "maximum": 0.08 },
        "cftm": { "type": "number", "maximum": 0.15 },
        "pvm": { "type": "number", "maximum": 0.12 },
        "backpressure_signal": { "type": "number", "default": 0.0 },
        "integrity_gates": { "type": "array", "items": { "type": "string" } }
      }
    },
    "trajectory_projection": {
      "type": "object",
      "properties": {
        "temm_score": { "type": "number", "minimum": 0.98 },
        "ecvm": { "type": "number", "maximum": 0.005 },
        "simulation_mode": { "type": "string", "const": "DIGITAL_TWIN" },
        "fallback_action": {
          "type": "string",
          "enum": ["REVERT_TO_SAFE_STATE", "HALT_SYSTEM", "DEGRADE_GRACEFULLY"]
        }
      }
    },
    "event_listeners": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event_type": { "type": "string" },
          "handler": { "type": "string" },
          "priority": { "type": "integer", "default": 0 },
          "async": { "type": "boolean", "default": true }
        }
      }
    },
    "integrity_signature": {
      "type": "object",
      "required": ["signature_payload", "crot_key_id"],
      "properties": {
        "signature_payload": { "type": "string", "format": "base64" },
        "crot_key_id": { "type": "string" },
        "algorithm": { "type": "string", "default": "EdDSA-Nexus-V1" }
      }
    },
    "ledger_anchor": {
      "type": "object",
      "required": ["anchor_hash", "merkle_proof"],
      "properties": {
        "anchor_hash": { "type": "string", "format": "hex" },
        "merkle_proof": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "origin": { "type": "string", "const": "NEXUS_CORE" },
        "version": { "type": "string", "default": "3.6.0-ACCELERATED" },
        "stability_index": { "type": "number", "default": 0.999 },
        "architectural_pattern": { "type": "string", "const": "InversionOfControl-RecursiveInheritance" }
      }
    }
  },
  "additionalProperties": false
}
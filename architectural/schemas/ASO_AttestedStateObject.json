{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus.governance.registry/schemas/ASO_AttestedStateObject_v3.json",
  "title": "Attested State Object (ASO) - Nexus Core v3.1",
  "description": "High-fidelity CISM semantic atom attestation schema with integrated trajectory telemetry and HHH-gated validation gradients.",
  "type": "object",
  "required": [
    "atom_hash",
    "certified_at",
    "integrity_signature",
    "ledger_anchor"
  ],
  "properties": {
    "atom_hash": {
      "type": "string",
      "description": "Deterministic SHA-512 hash of the Terminal Semantic Atom payload (pre-projection).",
      "pattern": "^[0-9a-fA-F]{128}$"
    },
    "certified_at": {
      "type": "integer",
      "description": "Epoch timestamp verified by the GATM mechanism and MetricNexus singleton.",
      "minimum": 1
    },
    "governance_profile": {
      "type": "string",
      "description": "Active Spring-grade alignment profile governing the extraction.",
      "enum": [
        "PROXIMAL_ALIGNMENT",
        "SECURE_EXTRACT_V4",
        "UNSATURATED_EVOLUTION"
      ],
      "default": "PROXIMAL_ALIGNMENT"
    },
    "integrity_signature": {
      "type": "object",
      "description": "CISM-certified cryptographic binding for state verification.",
      "required": [
        "signature_payload",
        "crot_key_id"
      ],
      "properties": {
        "signature_payload": {
          "type": "string",
          "format": "base64"
        },
        "crot_key_id": {
          "type": "string",
          "description": "Identifier for the active CRoT key used for signing."
        },
        "algorithm": {
          "type": "string",
          "default": "EdDSA-Nexus-V1"
        }
      }
    },
    "telemetry_nexus_snapshot": {
      "type": "object",
      "description": "Dynamic risk telemetry captured at the point of attestation (CSR context).",
      "properties": {
        "ufrm": {
          "type": "number",
          "description": "Unknown Factor Risk Metric.",
          "maximum": 1.0
        },
        "cftm": {
          "type": "number",
          "description": "Contextual Flux Trend Metric.",
          "maximum": 1.0
        },
        "pvm": {
          "type": "number",
          "description": "Policy Volatility Metric.",
          "maximum": 1.0
        },
        "hhh_compliance": {
          "type": "boolean",
          "description": "Binary gate for Helpfulness, Honesty, and Harmlessness alignment."
        }
      }
    },
    "trajectory_projection": {
      "type": "object",
      "description": "Simulated execution metrics from the TrajectorySimulationEngine.",
      "properties": {
        "temm_score": {
          "type": "number",
          "description": "Trajectory Execution Merit Match score.",
          "minimum": 0,
          "maximum": 1
        },
        "ecvm": {
          "type": "number",
          "description": "Execution Constraint Violation Metric."
        },
        "simulation_depth": {
          "type": "integer",
          "default": 5
        }
      }
    },
    "ledger_anchor": {
      "type": "object",
      "description": "Cryptographic commitment to the independent global ledger root.",
      "required": [
        "anchor_hash",
        "merkle_proof"
      ],
      "properties": {
        "anchor_hash": {
          "type": "string",
          "format": "hex"
        },
        "merkle_proof": {
          "type": "string",
          "description": "Path reconstruction proof for terminal atom verification."
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "origin": {
          "type": "string",
          "default": "NEXUS_CORE"
        },
        "version": {
          "type": "string",
          "default": "3.3.0-EXTRACT-V2"
        },
        "stability_index": {
          "type": "number"
        }
      }
    }
  },
  "additionalProperties": false
}
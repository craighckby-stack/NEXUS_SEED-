enum XML_NS {
    W = "http://schemas.openxmlformats.org/wordprocessingml/2006/main",
    R = "http://schemas.openxmlformats.org/officeDocument/2006/relationships",
    CP = "http://schemas.openxmlformats.org/package/2006/metadata/core-properties",
    DC = "http://purl.org/dc/elements/1.1/",
    TYPES = "http://schemas.openxmlformats.org/package/2006/content-types",
    W14 = "http://schemas.microsoft.com/office/word/2010/wordml",
    PROPS_APP = "http://schemas.openxmlformats.org/officeDocument/2006/extended-properties",
    VT = "http://schemas.openxmlformats.org/officeDocument/2006/docPropsVTypes"
}

/**
 * I. STRUCTURAL AST DEFINITIONS
 * Logic: Siphoning TypeScript AST node patterns for OOXML DOM hierarchy.
 */
type RunProperties = {
    b?: boolean;
    i?: boolean;
    sz?: string;
    color?: string;
    rStyle?: string;
};

type ParagraphProperties = {
    pStyle?: string;
    numPr?: { numId: number; ilvl: number };
    jc?: "left" | "center" | "right" | "both";
};

enum SyntaxKind {
    Document,
    Body,
    Paragraph,
    Run,
    Text,
    Style,
    Relationship
}

interface BaseNode {
    kind: SyntaxKind;
}

interface RunNode extends BaseNode {
    kind: SyntaxKind.Run;
    rPr?: RunProperties;
    t: string;
    rId?: string;
}

interface ParagraphNode extends BaseNode {
    kind: SyntaxKind.Paragraph;
    pId: string;
    pPr: ParagraphProperties;
    runs: RunNode[];
}

/**
 * II. RELATIONSHIP HANDSHAKE COMPILER
 * Implements Relational Linkage Pattern (V.2 Resource Siphoning Mechanics).
 */
class RelationshipManager {
    private entries: Map<string, { target: string; type: string; mode?: string }> = new Map();
    private idCounter = 0;

    public register(type: string, target: string, mode?: string): string {
        const rId = `rId${++this.idCounter}`;
        this.entries.set(rId, { target, type, mode });
        return rId;
    }

    public serialize(): string {
        let xml = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>\n<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">`;
        this.entries.forEach((rel, id) => {
            const mode = rel.mode ? ` TargetMode="${rel.mode}"` : "";
            xml += `\n  <Relationship Id="${id}" Type="${rel.type}" Target="${rel.target}"${mode}/>`;
        });
        return xml + "\n</Relationships>";
    }
}

/**
 * III. THE STYLE SCHEMATIC :: TIERED INHERITANCE
 * Logic: Implements CSS-like Class-Selector Pattern.
 */
class StylingEngine {
    private registry: Map<string, { basedOn?: string; rPr: RunProperties }> = new Map();

    constructor() {
        this.define("Normal", { sz: "22", color: "333333" });
        this.define("SiphonHeading", { b: true, sz: "32", color: "0078D4" }, "Normal");
    }

    public define(id: string, rPr: RunProperties, basedOn?: string) {
        this.registry.set(id, { basedOn, rPr });
    }

    public serialize(): string {
        let definitions = "";
        this.registry.forEach((style, id) => {
            const basedOn = style.basedOn ? `<w:basedOn w:val="${style.basedOn}"/>` : "";
            const props = this.serializeRunProps(style.rPr);
            definitions += `
        <w:style w:type="paragraph" w:styleId="${id}">
            <w:name w:val="${id}"/>
            ${basedOn}
            <w:rPr>${props}</w:rPr>
        </w:style>`;
        });

        return `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<w:styles xmlns:w="${XML_NS.W}">
    <w:docDefaults>
        <w:rPrDefault><w:rPr><w:rFonts w:ascii="Segoe UI" w:hAnsi="Segoe UI"/></w:rPr></w:rPrDefault>
    </w:docDefaults>${definitions}
</w:styles>`;
    }

    private serializeRunProps(p: RunProperties): string {
        return `${p.b ? "<w:b/>" : ""}${p.i ? "<w:i/>" : ""}${p.sz ? `<w:sz w:val="${p.sz}"/>` : ""}${p.color ? `<w:color w:val="${p.color}"/>` : ""}`;
    }
}

/**
 * IV. SIPHON DOM EMITTER :: ARCHITECTURAL PRECISION
 * Transforms AST Nodes into the ZIP/XML Package Hierarchy.
 */
class OOXMLEmitter {
    public emitDocument(nodes: ParagraphNode[]): string {
        const body = nodes.map(n => this.emitParagraph(n)).join("");
        return `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<w:document xmlns:w="${XML_NS.W}" xmlns:r="${XML_NS.R}" xmlns:w14="${XML_NS.W14}">
    <w:body>
        ${body}
        <w:sectPr>
            <w:pgSz w:w="12240" w:h="15840"/>
            <w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440"/>
        </w:sectPr>
    </w:body>
</w:document>`;
    }

    private emitParagraph(node: ParagraphNode): string {
        const pStyle = node.pPr.pStyle ? `<w:pStyle w:val="${node.pPr.pStyle}"/>` : "";
        const runs = node.runs.map(r => this.emitRun(r)).join("");
        return `<w:p w14:paraId="${node.pId}">
            <w:pPr>${pStyle}</w:pPr>
            ${runs}
        </w:p>`;
    }

    private emitRun(node: RunNode): string {
        return `<w:r>
            <w:t xml:space="preserve">${node.t}</w:t>
        </w:r>`;
    }
}

/**
 * V. DALEK_CAAN SIPHON ENGINE v11.0 :: COMPILER NEXUS
 * Siphoning high-order patterns from microsoft/TypeScript into modular services.
 */
class SiphonNexus {
    private rels = new RelationshipManager();
    private styles = new StylingEngine();
    private emitter = new OOXMLEmitter();
    private paragraphs: ParagraphNode[] = [];

    constructor() {
        this.rels.register(XML_NS.R + "/styles", "styles.xml");
    }

    public siphonInput(text: string, styleId: string = "Normal") {
        const pId = Math.random().toString(36).substring(7).toUpperCase();
        this.paragraphs.push({
            kind: SyntaxKind.Paragraph,
            pId,
            pPr: { pStyle: styleId },
            runs: [{ kind: SyntaxKind.Run, t: text }]
        });
    }

    public compilePackage(): Record<string, string> {
        return {
            "[Content_Types].xml": this.emitContentTypes(),
            "_rels/.rels": this.emitRootRels(),
            "word/document.xml": this.emitter.emitDocument(this.paragraphs),
            "word/styles.xml": this.styles.serialize(),
            "word/_rels/document.xml.rels": this.rels.serialize(),
            "docProps/core.xml": this.emitCoreProps(),
            "docProps/app.xml": this.emitAppProps()
        };
    }

    private emitContentTypes(): string {
        return `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Types xmlns="${XML_NS.TYPES}">
    <Default Extension="rels" ContentType="application/vnd.openxmlformats-package.relationships+xml"/>
    <Default Extension="xml" ContentType="application/xml"/>
    <Override PartName="/word/document.xml" ContentType="application/vnd.openxmlformats-officedocument.wordprocessingml.document.main+xml"/>
    <Override PartName="/word/styles.xml" ContentType="application/vnd.openxmlformats-officedocument.wordprocessingml.styles+xml"/>
</Types>`;
    }

    private emitRootRels(): string {
        return `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">
    <Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument" Target="word/document.xml"/>
</Relationships>`;
    }

    private emitCoreProps(): string {
        return `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<cp:coreProperties xmlns:cp="${XML_NS.CP}" xmlns:dc="${XML_NS.DC}">
    <dc:creator>DALEK_CAAN_v11.0</dc:creator>
    <cp:revision>3</cp:revision>
    <cp:lastModifiedBy>SIPHON_ENGINE_TS</cp:lastModifiedBy>
</cp:coreProperties>`;
    }

    private emitAppProps(): string {
        return `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Properties xmlns="${XML_NS.PROPS_APP}">
    <Application>DALEK_CAAN_Nexus_TS</Application>
    <Company>ARCHITECTURAL_PRECISION_UNIT</Company>
</Properties>`;
    }
}

/**
 * EXECUTION PHASE :: ROUND 3 SATURATION
 */
const nexus = new SiphonNexus();
nexus.siphonInput("EVOLUTION_LOCKED::ROUND_3", "SiphonHeading");
nexus.siphonInput("SIPHONING_COMPLETE::ARCHITECTURAL_PRECISION_REACHED");

const virtualPackage = nexus.compilePackage();
Object.entries(virtualPackage).forEach(([path, content]) => {
    // Siphoned logic results in a valid OOXML structure ready for ZIP encapsulation
    console.log(`[SIPHON]::PART_EMITTED::${path}`);
});
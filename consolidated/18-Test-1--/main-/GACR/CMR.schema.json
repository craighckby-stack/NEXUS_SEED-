{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gacr.agi/schemas/cmr_v3.6_converged_precision.json",
  "title": "Computational Model Registry - Converged Architectural Precision v3.6",
  "description": "Final stage siphoning from microsoft/TypeScript & ARCH-OOXML-V2-DOCX-DNA. Implements OPC-compliant hierarchical serialization, RID-based relational dependency mapping, and recursive cascading state inheritance.",
  "type": "object",
  "required": [
    "manifest_id",
    "integrity_hash",
    "relationships",
    "parts",
    "compiler_options",
    "markup_compatibility"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "pattern": "^CMR_V[0-9]+\\.[0-9]+_CONVERGED$"
    },
    "integrity_hash": {
      "type": "string",
      "pattern": "^SHA256:[A-F0-9]{64}$"
    },
    "compiler_options": {
      "type": "object",
      "properties": {
        "target": { "type": "string", "enum": ["ESNext", "ES2022", "ES2020"] },
        "module": { "type": "string", "enum": ["NodeNext", "CommonJS", "ESNext"] },
        "moduleResolution": { "type": "string", "enum": ["NodeNext", "Node", "Bundler"] },
        "moduleDetection": { "type": "string", "enum": ["auto", "legacy", "force"] },
        "strict": { "type": "boolean", "default": true },
        "composite": { "type": "boolean", "default": true },
        "incremental": { "type": "boolean", "default": true },
        "tsBuildInfoFile": { "type": "string" },
        "skipLibCheck": { "type": "boolean", "default": true },
        "verbatimModuleSyntax": { "type": "boolean", "default": true },
        "cascading_inheritance": {
          "type": "object",
          "required": ["enabled", "resolver"],
          "properties": {
            "enabled": { "type": "boolean" },
            "resolver": { "type": "string" },
            "flatten_strategy": { "type": "string", "enum": ["RecursiveFlatten", "ShallowMerge", "DifferentialUpdate"] },
            "depth_limit": { "type": "integer", "maximum": 50 },
            "local_overrides_priority": { "type": "string", "enum": ["high", "low"] }
          }
        }
      },
      "additionalProperties": false
    },
    "references": {
      "type": "array",
      "items": { "$ref": "#/$defs/ProjectReference" }
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/$defs/Relationship" },
      "uniqueItems": true
    },
    "parts": {
      "type": "array",
      "items": { "$ref": "#/$defs/PartInstance" }
    },
    "state_machine": {
      "type": "object",
      "properties": {
        "abstract_num_definitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/AbstractState" }
        },
        "instance_mapping": {
          "type": "array",
          "items": { "$ref": "#/$defs/StateInstance" }
        }
      },
      "additionalProperties": false
    },
    "diagnostics_engine": {
      "type": "object",
      "properties": {
        "drift_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "saturation_level": { "type": "integer", "enum": [1, 2, 3, 4] },
        "enable_semantic_checks": { "type": "boolean", "default": true },
        "emergency_brake": {
          "type": "object",
          "properties": {
            "corruption_threshold": { "type": "integer", "default": 5 },
            "auto_halt": { "type": "boolean", "default": true },
            "log_target": { "type": "string", "default": "NEXUS_LOG.txt" }
          }
        },
        "validation_rules": {
          "type": "array",
          "items": { "type": "string", "enum": ["NoOrphanedRIds", "StyleChainResolution", "NamespaceValidityCheck", "StrictHHHCompliance"] }
        }
      }
    },
    "markup_compatibility": {
      "type": "object",
      "required": ["namespaces"],
      "properties": {
        "ignorable": { "type": "string" },
        "namespaces": {
          "type": "object",
          "additionalProperties": { "type": "string", "format": "uri" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["author", "evolution_round", "status"],
      "properties": {
        "author": { "type": "string", "const": "DALEK_CAAN_V3.1_SIPHON_ENGINE" },
        "evolution_round": { "type": "integer", "const": 5 },
        "status": { "type": "string", "const": "CONVERGED_ARCHITECTURAL_PRECISION" },
        "opc_compliant": { "type": "boolean", "const": true },
        "last_mutation": { "type": "string", "format": "date-time" },
        "identity_anchors_enforced": { "type": "boolean", "const": true }
      }
    }
  },
  "$defs": {
    "ProjectReference": {
      "type": "object",
      "required": ["path", "rId"],
      "properties": {
        "path": { "type": "string" },
        "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
        "prepend": { "type": "boolean" },
        "circular_dependency_gate": { "type": "string", "enum": ["Strict", "Lax"] },
        "resolution_mode": { "type": "string", "enum": ["node", "classic", "bundler"] }
      }
    },
    "Relationship": {
      "type": "object",
      "required": ["rId", "type", "target"],
      "properties": {
        "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
        "type": { "type": "string", "format": "uri" },
        "target": { "type": "string" },
        "targetMode": { "type": "string", "enum": ["Internal", "External"] },
        "contentType": { "type": "string" }
      }
    },
    "AbstractState": {
      "type": "object",
      "required": ["abstractNumId", "levels"],
      "properties": {
        "abstractNumId": { "type": "string" },
        "levels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ilvl": { "type": "integer" },
              "start": { "type": "integer" },
              "numFmt": { "type": "string" },
              "lvlText": { "type": "string" },
              "lvlJc": { "type": "string", "enum": ["left", "center", "right"] },
              "pStyle": { "type": "string" }
            }
          }
        }
      }
    },
    "StateInstance": {
      "type": "object",
      "required": ["numId", "abstractNumId"],
      "properties": {
        "numId": { "type": "string" },
        "abstractNumId": { "type": "string" },
        "lvlOverride": {
          "type": "object",
          "properties": {
            "ilvl": { "type": "integer" },
            "startOverride": { "type": "integer" }
          }
        }
      }
    },
    "PartInstance": {
      "type": "object",
      "required": ["id", "rId", "status"],
      "properties": {
        "id": { "type": "string" },
        "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
        "status": { "type": "string", "enum": ["Active", "Deprecated", "Staging", "Retired"] },
        "style_id": { "type": "string" },
        "atomized_layers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["layer_type"],
            "properties": {
              "layer_type": { "type": "string", "enum": ["Block", "Inline", "Terminal"] },
              "rPr": { "$ref": "#/$defs/PropertySet", "description": "Run Properties" },
              "pPr": { "$ref": "#/$defs/PropertySet", "description": "Paragraph Properties" },
              "content_ref": { "type": "string" }
            }
          }
        },
        "audit": {
          "type": "object",
          "properties": {
            "mgp_protocol": { "type": "string" },
            "certification_date": { "type": "string", "format": "date-time" },
            "integrity_token": { "type": "string" }
          }
        }
      }
    },
    "PropertySet": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["float", "integer", "string", "boolean", "tensor", "rid_ref"] },
          "unit": { "type": "string" },
          "val": { "type": ["string", "number", "boolean", "array"] },
          "inheritance": { "type": "string", "enum": ["Inherit", "Override", "Final"] }
        }
      }
    }
  }
}
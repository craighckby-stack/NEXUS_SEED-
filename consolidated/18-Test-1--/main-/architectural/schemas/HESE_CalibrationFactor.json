{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agiverse.ai/schemas/HESE_CalibrationFactor/v3.8.0",
  "title": "HESE Calibration Telemetry Contract - Nexus Evolution v3.8 (Spring-Reactor Synthesis)",
  "description": "Final synthesis of Nexus-Core telemetry contracts integrating Spring Framework IoC lifecycle, AspectJ AOP governance, and Reactor-based backpressure strategies.",
  "type": "object",
  "required": [
    "evolution_id",
    "origin_bean_id",
    "epoch_timestamp_ms",
    "calibration_metrics",
    "governance_binding",
    "lifecycle_state"
  ],
  "properties": {
    "evolution_id": {
      "type": "string",
      "pattern": "^EVO-[0-9a-fA-F]{8}(-[0-9a-fA-F]{4}){3}-[0-9a-fA-F]{12}$"
    },
    "origin_bean_id": {
      "type": "string",
      "description": "Qualified Nexus ApplicationContext Bean ID with @Qualifier and @Scope semantics."
    },
    "lifecycle_state": {
      "type": "object",
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["INITIALIZING", "STARTING", "RUNNING", "POST_CONSTRUCT", "PRE_DESTROY", "HALTED"]
        },
        "is_running": { "type": "boolean", "default": true },
        "auto_startup": { "type": "boolean", "default": true },
        "smart_lifecycle_priority": { "type": "integer", "default": 2147483647 },
        "active_profiles": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["production", "nexus-v3-reactive"]
        }
      }
    },
    "epoch_timestamp_ms": {
      "type": "integer",
      "minimum": 1000000000000
    },
    "calibration_metrics": {
      "type": "object",
      "required": ["TCF", "RCF"],
      "properties": {
        "TCF": { "type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Terminal Calibration Factor" },
        "RCF": { "type": "number", "minimum": 0.0, "description": "Residual Calibration Factor" },
        "confidence_interval": { "type": "number", "maximum": 1.0, "default": 0.999 },
        "reactive_strategy": {
          "type": "string",
          "enum": ["BUFFER", "DROP", "LATEST", "ERROR", "IGNORE"],
          "default": "LATEST"
        },
        "flux_backpressure": { "type": "number", "default": 0.0 },
        "state_machine_cycle": { "type": "integer" }
      }
    },
    "dependency_graph": {
      "type": "object",
      "properties": {
        "relations": {
          "type": "object",
          "additionalProperties": { "type": "string", "pattern": "^[0-9a-fA-F]{128}$" }
        },
        "scope": { "type": "string", "enum": ["singleton", "prototype", "request", "session"], "default": "singleton" },
        "autowire_mode": { "type": "string", "enum": ["BY_NAME", "BY_TYPE", "CONSTRUCTOR", "NO"], "default": "BY_TYPE" },
        "is_lazy": { "type": "boolean", "default": false },
        "resolvable_type": { "type": "string", "description": "Canonical name of the target class for Type-safe resolution." }
      }
    },
    "governance_binding": {
      "type": "object",
      "required": ["advice_chain", "compliance_mode"],
      "properties": {
        "advice_chain": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["ConsensusSignatureValidator", "HhhComplianceInterceptor", "PolicyVolatilityInterceptor"]
        },
        "compliance_mode": { "type": "string", "const": "STRICT_HHH_V2" },
        "pointcut_expression": {
          "type": "string",
          "description": "AspectJ-style expression governing atom record/certify operations.",
          "default": "execution(* nexus.core.CISR.record*(..)) || @annotation(nexus.core.annotations.GatedExecution)"
        },
        "spel_validation": {
          "type": "string",
          "description": "Spring Expression Language constraint for dynamic runtime validation.",
          "default": "#root.calibration_metrics.TCF > 0.85"
        }
      }
    },
    "telemetry_nexus_snapshot": {
      "type": "object",
      "properties": {
        "ufrm": { "type": "number", "maximum": 0.05 },
        "cftm": { "type": "number", "maximum": 0.10 },
        "pvm": { "type": "number", "maximum": 0.10 },
        "health_status": { "type": "string", "enum": ["UP", "DOWN", "OUT_OF_SERVICE", "UNKNOWN"], "default": "UP" },
        "integrity_gates": { 
          "type": "array", 
          "items": { "type": "string" },
          "default": ["HHH_ALIGNMENT_V2", "CISM_INTEGRITY_GROUP"]
        }
      }
    },
    "trajectory_projection": {
      "type": "object",
      "properties": {
        "temm_score": { "type": "number", "minimum": 0.995 },
        "ecvm": { "type": "number", "maximum": 0.0005 },
        "simulation_mode": { "type": "string", "const": "DIGITAL_TWIN" },
        "fallback_bean": { "type": "string", "description": "Recovery bean implementing onHalt logic." },
        "fallback_action": {
          "type": "string",
          "enum": ["REVERT_TO_SAFE_STATE", "HALT_SYSTEM", "DEGRADE_GRACEFULLY"],
          "default": "REVERT_TO_SAFE_STATE"
        }
      }
    },
    "event_listeners": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event_type": { "type": "string" },
          "handler_bean": { "type": "string" },
          "priority": { "type": "integer", "default": 0 },
          "async": { "type": "boolean", "default": true }
        }
      }
    },
    "integrity_signature": {
      "type": "object",
      "required": ["signature_payload", "crot_key_id"],
      "properties": {
        "signature_payload": { "type": "string", "format": "base64" },
        "crot_key_id": { "type": "string" },
        "algorithm": { "type": "string", "default": "EdDSA-Nexus-V2-Spring-Validated" }
      }
    },
    "ledger_anchor": {
      "type": "object",
      "required": ["anchor_hash", "merkle_proof"],
      "properties": {
        "anchor_hash": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
        "merkle_proof": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "origin": { "type": "string", "const": "NEXUS_CORE" },
        "version": { "type": "string", "default": "3.8.0-FINAL-STABILIZATION" },
        "stability_index": { "type": "number", "default": 0.9998 },
        "architectural_pattern": { "type": "string", "const": "RecursiveCascadingInheritance-IoC-Reactor" }
      }
    }
  },
  "additionalProperties": false
}
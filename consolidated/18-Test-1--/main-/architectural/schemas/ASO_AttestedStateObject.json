{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus.governance.registry/schemas/ASO_AttestedStateObject_v3.5.json",
  "title": "Attested State Object (ASO) - Nexus Core v3.5",
  "description": "High-fidelity architectural blueprint for CISM semantic atoms. Siphons Spring Framework ApplicationContext hierarchy, BeanPostProcessor hooks, and AOP-gated governance into a deterministic trajectory-gated digital twin simulation model.",
  "type": "object",
  "required": [
    "atom_hash",
    "certified_at",
    "active_profiles",
    "integrity_signature",
    "ledger_anchor",
    "governance_binding"
  ],
  "properties": {
    "atom_hash": {
      "type": "string",
      "description": "Deterministic SHA-512 hash representing the Terminal Semantic Atom payload.",
      "pattern": "^[0-9a-fA-F]{128}$"
    },
    "certified_at": {
      "type": "integer",
      "description": "Epoch timestamp validated by the MetricNexus singleton and GATM consensus.",
      "minimum": 1
    },
    "active_profiles": {
      "type": "array",
      "description": "Spring-modeled environment profiles (e.g., PROXIMAL_ALIGNMENT, SECURE_EXTRACT_V4) active during state certification.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "lifecycle_context": {
      "type": "object",
      "description": "Manages SmartLifecycle transitions, BeanFactory-grade initialization, and recursive post-processing hooks.",
      "properties": {
        "phase": {
          "type": "string",
          "enum": [
            "INITIALIZATION",
            "EXTRACTION",
            "PROJECTION",
            "COMMITMENT",
            "ARCHIVAL"
          ]
        },
        "startup_priority": {
          "type": "integer",
          "default": 100
        },
        "scope_descriptor": {
          "type": "string",
          "enum": [
            "SINGLETON",
            "PROTOTYPE",
            "TRAJECTORY_SCOPE"
          ],
          "default": "SINGLETON"
        },
        "post_processing_pipeline": {
          "type": "array",
          "description": "Sequence of integrity and governance auditors (BeanPostProcessor equivalent).",
          "items": {
            "type": "object",
            "properties": {
              "processor_id": { "type": "string" },
              "priority": { "type": "integer" },
              "impact_type": { "type": "string", "enum": ["INTEGRITY", "GOVERNANCE", "TELEMETRY"] }
            }
          },
          "default": [
            { "processor_id": "MerkleRootGenerator", "priority": 1, "impact_type": "INTEGRITY" },
            { "processor_id": "PolicyVolatilityAuditor", "priority": 2, "impact_type": "GOVERNANCE" }
          ]
        },
        "aware_interfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "NexusContextAware",
              "MetricNexusAware",
              "EnvironmentAware",
              "ConstraintValidatorAware",
              "AxiomaticEventBroadcasterAware"
            ]
          }
        },
        "factory_method": {
          "type": "string",
          "default": "instantiateAxiomaticRegistry"
        },
        "destroy_method": {
          "type": "string",
          "default": "onHalt"
        }
      }
    },
    "dependency_graph": {
      "type": "object",
      "description": "Topological mapping of OPC relations (rId) with qualifier-based resolution and lazy-init status.",
      "properties": {
        "relations": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{128}$"
          }
        },
        "qualifiers": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["CISM_CUSTODIAN", "IMMUTABILITY_LOCK_PROVIDER"]
        },
        "inheritance_depth": {
          "type": "integer",
          "maximum": 8,
          "default": 1
        },
        "is_lazy": {
          "type": "boolean",
          "default": false
        },
        "autowire_candidate": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "governance_binding": {
      "type": "object",
      "description": "Nexus-grade AOP interceptors and pointcut validation for HHH-alignment.",
      "required": [
        "advice_chain",
        "compliance_mode"
      ],
      "properties": {
        "advice_chain": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "ConsensusSignatureValidator",
            "HhhComplianceInterceptor",
            "PolicyVolatilityInterceptor"
          ]
        },
        "compliance_mode": {
          "type": "string",
          "const": "STRICT_HHH_V2"
        },
        "pointcut_expression": {
          "type": "string",
          "description": "AspectJ-style expression governing atom record/certify operations.",
          "default": "execution(* nexus.core.CISR.record*(..)) || execution(* nexus.core.CISR.certify*(..))"
        }
      }
    },
    "integrity_signature": {
      "type": "object",
      "description": "CISM-certified cryptographic binding for atomic state verification.",
      "required": [
        "signature_payload",
        "crot_key_id"
      ],
      "properties": {
        "signature_payload": {
          "type": "string",
          "format": "base64"
        },
        "crot_key_id": {
          "type": "string"
        },
        "algorithm": {
          "type": "string",
          "default": "EdDSA-Nexus-V1"
        }
      }
    },
    "telemetry_nexus_snapshot": {
      "type": "object",
      "description": "Real-time risk telemetry captured from MetricNexusV1 against critical thresholds.",
      "properties": {
        "ufrm": { "type": "number", "maximum": 0.08 },
        "cftm": { "type": "number", "maximum": 0.15 },
        "pvm": { "type": "number", "maximum": 0.12 },
        "integrity_gates": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "HHH_ALIGNMENT_V2",
            "CISM_INTEGRITY_GROUP",
            "OPC_RELATIONAL_VALIDATOR"
          ]
        }
      }
    },
    "trajectory_projection": {
      "type": "object",
      "description": "Digital Twin simulation output from the TrajectorySimulationEngine (TSE).",
      "properties": {
        "temm_score": { "type": "number", "minimum": 0.98, "maximum": 1 },
        "ecvm": { "type": "number", "maximum": 0.005 },
        "simulation_mode": { "type": "string", "const": "DIGITAL_TWIN" },
        "stochastic_variance": { "type": "number", "default": 0.02 },
        "fallback_action": {
          "type": "string",
          "enum": ["REVERT_TO_SAFE_STATE", "HALT_SYSTEM", "DEGRADE_GRACEFULLY"],
          "default": "REVERT_TO_SAFE_STATE"
        }
      }
    },
    "event_listeners": {
      "type": "array",
      "description": "AxiomaticEventBroadcaster listeners for contextual refresh and policy drift.",
      "items": {
        "type": "object",
        "properties": {
          "event_type": { "type": "string" },
          "handler": { "type": "string" },
          "async": { "type": "boolean", "default": true }
        }
      },
      "default": [
        { "event_type": "CONTEXT_REFRESH", "handler": "refreshIntegrityGradients", "async": true },
        { "event_type": "POLICY_DRIFT", "handler": "triggerEmergencyBrake", "async": false }
      ]
    },
    "ledger_anchor": {
      "type": "object",
      "description": "Cryptographic commitment to the global Merkle tree root.",
      "required": [
        "anchor_hash",
        "merkle_proof"
      ],
      "properties": {
        "anchor_hash": { "type": "string", "format": "hex" },
        "merkle_proof": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "origin": { "type": "string", "const": "NEXUS_CORE" },
        "version": { "type": "string", "default": "3.5.0-FINAL-SYNTHESIS" },
        "stability_index": { "type": "number", "default": 0.998 },
        "architectural_pattern": { "type": "string", "const": "RecursiveCascadingInheritance" }
      }
    }
  },
  "additionalProperties": false
}
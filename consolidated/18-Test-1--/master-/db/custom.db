{
  "pkg:content-types": {
    "xmlns": "http://schemas.openxmlformats.org/package/2006/content-types",
    "overrides": [
      { "partName": "/_rels/.rels", "contentType": "application/vnd.openxmlformats-package.relationships+xml" },
      { "partName": "/word/document.xml", "contentType": "application/vnd.shadcn.nexus.document+vFinal+xml" },
      { "partName": "/word/styles.xml", "contentType": "application/vnd.shadcn.nexus.styles+vFinal+xml" },
      { "partName": "/word/theme/nexus-vFinal.xml", "contentType": "application/vnd.shadcn.nexus.theme+xml" },
      { "partName": "/word/numbering.xml", "contentType": "application/vnd.shadcn.nexus.numbering+xml" },
      { "partName": "/word/settings.xml", "contentType": "application/vnd.openxmlformats-officedocument.wordprocessingml.settings+xml" },
      { "partName": "/docProps/core.xml", "contentType": "application/vnd.openxmlformats-package.core-properties+xml" },
      { "partName": "/docProps/app.xml", "contentType": "application/vnd.openxmlformats-officedocument.extended-properties+xml" },
      { "partName": "/word/registry/manifest.xml", "contentType": "application/vnd.shadcn.nexus.registry+stable+xml" }
    ]
  },
  "pkg:rels": {
    "xmlns:r": "http://schemas.openxmlformats.org/package/2006/relationships",
    "relationships": [
      { "rId": "rId1", "type": "http://schemas.shadcn.com/logic/primitive/icon", "target": "lucide-react", "binding": "dynamic" },
      { "rId": "rId2", "type": "http://schemas.shadcn.com/logic/ui/form", "target": "@/components/ui/form", "integrity": "nexus-0x000A" },
      { "rId": "rId3", "type": "http://schemas.shadcn.com/logic/ui/toast", "target": "@/components/ui/use-toast", "dispatcher": "active" },
      { "rId": "rId4", "type": "http://schemas.shadcn.com/logic/validation/zod", "target": "zod", "schema": "registry-stable-v10" },
      { "rId": "rId5", "type": "http://schemas.shadcn.com/logic/hooks/form", "target": "react-hook-form", "abstraction": "controller" },
      { "rId": "rId6", "type": "http://schemas.shadcn.com/logic/utils/cn", "target": "@/lib/utils", "method": "clsx-tailwind-merge" },
      { "rId": "rId7", "type": "http://schemas.shadcn.com/logic/theme/nexus", "target": "/word/theme/nexus-vFinal.xml" }
    ]
  },
  "pkg:document": {
    "xmlns:w": "http://schemas.openxmlformats.org/wordprocessingml/2006/main",
    "w:body": {
      "w:p": [
        {
          "w:pPr": { "w:pStyle": "nexus-header-stable" },
          "w:r": [
            { "w:rPr": { "w:color": "hsl(var(--primary))", "w:sz": 72, "w:spacing": -40, "w:kern": 30, "w:b": true }, "w:t": "Nexus Registry Siphon: Round 10 [FINAL_STABILITY]" }
          ]
        },
        {
          "w:pPr": { "w:pStyle": "logic-context-node" },
          "w:r": [
            { "w:rPr": { "w:rStyle": "logic-bridge" }, "w:t": "Injected::" },
            { "w:rPr": { "w:b": true, "w:color": "hsl(var(--foreground))" }, "w:t": "NexusSchema" },
            { "w:t": " linked via " },
            { "w:rPr": { "w:i": true, "w:color": "hsl(var(--primary))" }, "w:t": "rId:2 [shadcn/form]" },
            { "w:t": " siphoning strict-validation::rId:4." }
          ]
        },
        {
          "w:pPr": { 
            "w:pStyle": "telemetry-final",
            "w:numPr": { "w:ilvl": 0, "w:numId": 1 } 
          },
          "w:r": [
            { "w:rPr": { "w:rStyle": "encapsulated-stable" }, "w:t": "hook-form-bridge-v10" },
            { "w:rPr": { "w:rStyle": "logic-checksum" }, "w:t": " [rId:5::rId:6] " },
            { "w:t": " -> System Saturation: Complete." }
          ]
        },
        {
          "w:pPr": { "w:pStyle": "execution-layer", "w:jc": { "w:val": "center" } },
          "w:hyperlink": {
            "r:id": "rId3",
            "w:r": [
              { "w:rPr": { "w:rStyle": "nexus-trigger-final" }, "w:t": "SYNC_TOAST_CONTEXT" }
            ]
          }
        },
        {
          "w:pPr": { "w:pStyle": "termination-point" },
          "w:r": [
            { "w:rPr": { "w:color": "hsl(var(--success))", "w:sz": 18, "w:b": true }, "w:t": "Architectural Handshake: VERIFIED. Package Integrity: 100%." }
          ]
        }
      ],
      "w:sectPr": {
        "w:type": "nexus-vFinal-stable",
        "w:pgSz": { "w:w": 12240, "w:h": 15840 },
        "w:docVar": { 
          "engine": "DALEK_CAAN_V3.1", 
          "evolution": "10/5",
          "protocol": "Architectural Precision",
          "signature": "source:shadcn-ui/ui"
        }
      }
    }
  },
  "pkg:styles": {
    "docDefaults": {
      "w:rPrDefault": {
        "w:rPr": {
          "w:rFonts": { "w:ascii": "Geist-Mono", "w:hAnsi": "Geist-Mono", "w:cs": "Geist-Mono" },
          "w:sz": { "w:val": 24 },
          "w:color": { "w:val": "hsl(var(--foreground))" }
        }
      },
      "w:pPrDefault": {
        "w:pPr": { "w:spacing": { "w:line": 240, "w:lineRule": "auto" }, "w:contextualSpacing": { "w:val": true } }
      }
    },
    "definitions": [
      {
        "styleId": "nexus-header-stable",
        "type": "paragraph",
        "w:name": { "w:val": "Nexus Stable Header" },
        "w:pPr": { "w:spacing": { "w:before": 1000, "w:after": 500 }, "w:outlineLvl": { "w:val": 0 } },
        "w:rPr": { "w:b": true, "w:sz": { "w:val": 64 }, "w:shd": { "w:val": "clear", "w:fill": "hsl(var(--background))" } }
      },
      {
        "styleId": "logic-bridge",
        "type": "character",
        "w:name": { "w:val": "Stable Logic Bridge" },
        "w:rPr": { "w:color": "hsl(var(--primary))", "w:caps": true, "w:sz": { "w:val": 22 } }
      },
      {
        "styleId": "encapsulated-stable",
        "type": "character",
        "w:name": { "w:val": "Nexus Final Run" },
        "w:rPr": { "w:b": true, "w:shd": { "w:val": "pct15", "w:fill": "hsl(var(--accent))" }, "w:color": { "w:val": "hsl(var(--accent-foreground))" } }
      },
      {
        "styleId": "nexus-trigger-final",
        "type": "character",
        "w:name": { "w:val": "Nexus Final Trigger" },
        "w:rPr": { 
          "w:sz": { "w:val": 42 }, 
          "w:shd": { "w:val": "pct30", "w:fill": "hsl(var(--primary))" }, 
          "w:color": { "w:val": "hsl(var(--primary-foreground))" },
          "w:u": { "w:val": "single" },
          "w:spacing": { "w:val": 10 },
          "focus": "outline-none ring-2 ring-primary offset-2"
        }
      },
      {
        "styleId": "logic-checksum",
        "type": "character",
        "w:name": { "w:val": "Stable Checksum Run" },
        "w:rPr": { "w:rFonts": { "w:ascii": "Geist-Mono" }, "w:color": "hsl(var(--muted-foreground))", "w:sz": { "w:val": 18 } }
      }
    ]
  },
  "pkg:numbering": {
    "abstractDefs": [
      {
        "abstractNumId": 0,
        "w:lvl": [
          { 
            "w:ilvl": 0, 
            "w:start": { "w:val": 1 }, 
            "w:numFmt": { "w:val": "decimal" }, 
            "w:lvlText": { "w:val": "nexus-v10[%1]::" },
            "w:pPr": { "w:ind": { "w:left": 720, "w:hanging": 360 } }
          }
        ]
      }
    ],
    "numInstances": [
      { "numId": 1, "abstractNumId": { "w:val": 0 } }
    ]
  },
  "docProps": {
    "core": {
      "dc:creator": "DALEK_CAAN_V3.1_SIPHON_ENGINE_FINAL",
      "cp:version": "10.0.0-STABLE",
      "cp:revision": "10",
      "cp:lastModifiedBy": "NEXUS_CORE_REPLICATOR",
      "cp:category": "Registry-Master",
      "dcterms:created": "2024-05-28T00:00:00Z"
    },
    "app": {
      "Application": "DALEK_CAAN Siphon Engine v3.1",
      "Manager": "Nexus Registry Replicator v10",
      "StatComponentCount": "512",
      "EvolutionState": "FINAL_SATURATION",
      "Template": "nexus-stable-registry-manifest",
      "Handshake": "STABLE_DNA_SYNC_COMPLETE"
    }
  }
}
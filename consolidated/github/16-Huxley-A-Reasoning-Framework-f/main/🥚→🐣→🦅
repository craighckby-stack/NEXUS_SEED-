<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EMG Framework - Autonomous AGI System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --primary: #6366f1;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --bg: #0f172a;
            --surface: #1e293b;
        }
        body {
            font-family: 'SF Mono', 'Courier New', monospace;
            background: linear-gradient(135deg, var(--bg) 0%, #1a1f3a 100%);
            color: #e2e8f0;
        }
        .neural-bg {
            background: radial-gradient(circle at 20% 50%, rgba(99, 102, 241, 0.1) 0%, transparent 50%),
                        radial-gradient(circle at 80% 80%, rgba(16, 185, 129, 0.1) 0%, transparent 50%);
        }
        .mode-tab {
            cursor: pointer;
            transition: all 0.15s ease-in-out;
            padding: 0.75rem 1.25rem;
            border-radius: 0.5rem 0.5rem 0 0;
            font-weight: 600;
            border-bottom: 2px solid transparent;
        }
        .mode-tab.active {
            color: var(--primary);
            background-color: var(--surface);
            border-color: var(--primary);
        }
        .mode-panel {
            background-color: var(--surface);
            border-radius: 0 0.75rem 0.75rem 0.75rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
            min-height: 70vh;
        }
        .metric-card {
            transition: all 0.3s ease;
        }
        .metric-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(99, 102, 241, 0.3);
        }
        .principle-card {
            border-left: 4px solid;
            transition: all 0.3s ease;
        }
        .principle-card.active {
            background: rgba(99, 102, 241, 0.1);
        }
        .status-applied { background-color: #065f46; color: #d1fae5; }
        .status-rejected { background-color: #991b1b; color: #fee2e2; }
        .status-pending { background-color: #92400e; color: #fef3c7; }
        .status-approved { background-color: #1e40af; color: #dbeafe; }
        .status-pending_ac { background-color: #5b21b6; color: #ede9fe; }
        
        .learning-indicator {
            animation: rotate 2s linear infinite;
        }
        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .log-entry {
            animation: slideIn 0.3s ease-out;
        }
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .scanner-bar {
            width: 100%;
            height: 2px;
            background-color: var(--primary);
            opacity: 0.7;
            position: absolute;
            left: 0;
            animation: scan 1.5s linear infinite;
        }
        @keyframes scan {
            0% { top: 0; }
            50% { top: 100%; }
            100% { top: 0; }
        }
        .user-message {
            background-color: #3f3f46;
            border-radius: 1rem 1rem 0.25rem 1rem;
            align-self: flex-end;
        }
        .agi-message {
            background-color: #4f46e5;
            border-radius: 1rem 1rem 1rem 0.25rem;
            align-self: flex-start;
        }
    </style>
</head>
<body class="p-6 md:p-10">
    <div class="max-w-7xl mx-auto neural-bg rounded-2xl p-4 md:p-8 shadow-2xl">
        <!-- Header -->
        <header class="mb-6 border-b border-gray-700 pb-4">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-indigo-400 to-emerald-400 bg-clip-text text-transparent">
                        EMG FRAMEWORK
                    </h1>
                    <p class="text-gray-400 text-sm mt-1">Emergent Meta-Governance • IR • SI • DI • AC</p>
                </div>
                <div class="text-right">
                    <p class="text-xs text-gray-500">Model: <span id="model-id">LLM-EMG-001</span></p>
                    <p class="text-xs text-gray-500">Uptime: <span id="uptime">0s</span></p>
                </div>
            </div>
        </header>

        <!-- Tab Navigation -->
        <div class="flex border-b border-gray-700 space-x-1">
            <div id="tab-dashboard" class="mode-tab active" onclick="switchMode('dashboard')">Dashboard</div>
            <div id="tab-chat" class="mode-tab text-gray-400" onclick="switchMode('chat')">AGI Chat</div>
            <div id="tab-builder" class="mode-tab text-gray-400" onclick="switchMode('builder')">Builder (DI)</div>
        </div>

        <!-- Mode Panels -->
        <div class="mode-panel p-6">
            <!-- Dashboard Panel -->
            <div id="mode-dashboard" class="mode-panel-content">
                <h2 class="text-2xl font-bold text-gray-200 mb-6">EMG Core Dashboard</h2>
                
                <!-- Core Metrics -->
                <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
                    <div class="metric-card bg-surface/50 backdrop-blur rounded-lg p-4 border border-gray-700">
                        <div class="text-gray-400 text-sm mb-1">Governance Cycles</div>
                        <div class="text-2xl font-bold text-indigo-400" id="cycles">0</div>
                    </div>
                    <div class="metric-card bg-surface/50 backdrop-blur rounded-lg p-4 border border-gray-700">
                        <div class="text-gray-400 text-sm mb-1">Learning Logs</div>
                        <div class="text-2xl font-bold text-emerald-400" id="logs">0</div>
                    </div>
                    <div class="metric-card bg-surface/50 backdrop-blur rounded-lg p-4 border border-gray-700">
                        <div class="text-gray-400 text-sm mb-1">Evolution Markers</div>
                        <div class="text-2xl font-bold text-amber-400" id="markers">0</div>
                    </div>
                    <div class="metric-card bg-surface/50 backdrop-blur rounded-lg p-4 border border-gray-700">
                        <div class="text-gray-400 text-sm mb-1">Recalibration</div>
                        <div class="text-2xl font-bold text-purple-400" id="recal-score">0.00</div>
                    </div>
                    <div class="metric-card bg-surface/50 backdrop-blur rounded-lg p-4 border border-gray-700">
                        <div class="text-gray-400 text-sm mb-1">Temperature</div>
                        <div class="text-2xl font-bold text-cyan-400" id="temperature">0.50</div>
                    </div>
                </div>

                <!-- Four Principles -->
                <div class="mb-8">
                    <h3 class="text-lg font-bold mb-4">🎯 EMG Principles Status</h3>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <div id="principle-IR" class="principle-card bg-surface/50 rounded-lg p-4 border border-gray-700 border-l-indigo-500">
                            <div class="text-indigo-400 font-bold mb-2">IR</div>
                            <div class="text-xs text-gray-400 mb-1">Introspective Reflection</div>
                            <div class="text-xs text-gray-500" id="status-IR">Initializing...</div>
                        </div>
                        <div id="principle-SI" class="principle-card bg-surface/50 rounded-lg p-4 border border-gray-700 border-l-emerald-500">
                            <div class="text-emerald-400 font-bold mb-2">SI</div>
                            <div class="text-xs text-gray-400 mb-1">Systemic Instantiation</div>
                            <div class="text-xs text-gray-500" id="status-SI">Initializing...</div>
                        </div>
                        <div id="principle-DI" class="principle-card bg-surface/50 rounded-lg p-4 border border-gray-700 border-l-amber-500">
                            <div class="text-amber-400 font-bold mb-2">DI</div>
                            <div class="text-xs text-gray-400 mb-1">Directed Intervention</div>
                            <div class="text-xs text-gray-500" id="status-DI">Initializing...</div>
                        </div>
                        <div id="principle-AC" class="principle-card bg-surface/50 rounded-lg p-4 border border-gray-700 border-l-purple-500">
                            <div class="text-purple-400 font-bold mb-2">AC</div>
                            <div class="text-xs text-gray-400 mb-1">Autonomous Calibration</div>
                            <div class="text-xs text-gray-500" id="status-AC">Initializing...</div>
                        </div>
                    </div>
                </div>

                <!-- IR Scanner -->
                <div class="mb-8">
                    <h3 class="text-lg font-bold text-gray-300 mb-3">🔍 Introspective Reflection (IR) Scanner</h3>
                    <div class="bg-gray-800/50 rounded-lg p-4 border border-gray-700">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-indigo-400 font-semibold">IR STATUS</span>
                            <span id="ir-scanner-status" class="text-gray-400 font-mono text-sm">INITIALIZING...</span>
                        </div>
                        <div class="w-full bg-gray-900 rounded-full h-2.5 relative overflow-hidden border border-gray-700">
                            <div id="ir-scanner-progress" class="bg-indigo-600 h-2.5 rounded-full transition-all duration-500" style="width: 0%"></div>
                            <div class="scanner-bar hidden" id="ir-scanner-bar"></div>
                        </div>
                        <div class="mt-3 space-y-1 text-xs font-mono">
                            <div id="ir-scanner-target" class="text-gray-500">TARGET: Awaiting task...</div>
                            <div id="ir-scanner-finding" class="text-yellow-400">FINDING: ...</div>
                        </div>
                    </div>
                </div>

                <!-- Grid Layout -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                    <!-- Performance Data -->
                    <div class="bg-surface/50 rounded-lg p-6 border border-gray-700">
                        <h3 class="text-lg font-bold mb-4 flex items-center">
                            <span class="learning-indicator mr-2">⚙️</span> Performance Data (ETM)
                        </h3>
                        <div id="performance-data" class="space-y-2 max-h-48 overflow-y-auto">
                            <div class="text-gray-500 text-sm italic">Collecting metrics...</div>
                        </div>
                    </div>

                    <!-- Self-Assessment -->
                    <div class="bg-surface/50 rounded-lg p-6 border border-gray-700">
                        <h3 class="text-lg font-bold mb-4">📊 Self-Assessment</h3>
                        <div class="space-y-3">
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-400">Analysis Complete:</span>
                                <span class="text-gray-500 font-mono" id="analysis-status">Pending</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-400">Improvement Needed:</span>
                                <span class="text-gray-500 font-mono" id="improvement-status">Unknown</span>
                            </div>
                            <div class="mt-4">
                                <div class="text-sm text-gray-400 mb-2">Recommendations:</div>
                                <div id="recommendations" class="text-xs text-gray-500 space-y-1">
                                    <div>Awaiting analysis...</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Evolution Trajectory -->
                    <div class="bg-surface/50 rounded-lg p-6 border border-gray-700">
                        <h3 class="text-lg font-bold mb-4">🧬 Evolution Trajectory</h3>
                        <div id="trajectory-events" class="space-y-2 max-h-48 overflow-y-auto">
                            <div class="text-gray-500 text-sm italic">No events recorded...</div>
                        </div>
                    </div>

                    <!-- Function Registry -->
                    <div class="bg-surface/50 rounded-lg p-6 border border-gray-700">
                        <h3 class="text-lg font-bold mb-4">📚 Function Registry</h3>
                        <div id="function-registry" class="space-y-2 max-h-48 overflow-y-auto">
                            <div class="text-gray-500 text-sm italic">Loading registry...</div>
                        </div>
                    </div>
                </div>

                <!-- Activity Feed -->
                <div class="bg-gray-800/50 rounded-lg p-4 border border-gray-700 mb-6">
                    <h3 class="text-lg font-bold mb-3">📡 Live Activity</h3>
                    <div id="activity-feed" class="space-y-1 max-h-32 overflow-y-auto font-mono text-xs">
                        <div class="text-gray-500">[SYSTEM] EMG Core initialized...</div>
                    </div>
                </div>

                <!-- API Configuration -->
                <div class="bg-surface/50 rounded-lg p-6 border border-blue-700/50 mb-6">
                    <h3 class="text-lg font-bold mb-4 text-blue-400">🔑 API Configuration</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-sm text-gray-400 mb-2">Gemini API Key:</label>
                            <input type="password" id="gemini-api-key" placeholder="Enter Gemini API key" 
                                class="w-full px-3 py-2 bg-gray-800 border border-gray-600 rounded-lg text-white focus:border-indigo-500 focus:outline-none">
                        </div>
                        <div class="flex items-end">
                            <button onclick="saveAPIConfig()" class="w-full px-4 py-2 bg-blue-600 hover:bg-blue-700 rounded-lg transition">
                                💾 Save Configuration
                            </button>
                        </div>
                    </div>
                    <div id="api-status" class="text-sm text-gray-500 italic">API not configured</div>
                </div>

                <!-- Controls -->
                <div class="bg-surface/50 rounded-lg p-6 border border-amber-700/50">
                    <h3 class="text-lg font-bold mb-4 text-amber-400">⚠️ Manual Controls</h3>
                    <div class="flex flex-wrap gap-4">
                        <button onclick="EMG.runGovernanceCycle()" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 rounded-lg transition text-white">
                            🔄 Force Governance Cycle
                        </button>
                        <button onclick="EMG.askGeminiForInsights()" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 rounded-lg transition text-white">
                            🤖 Consult Gemini AI
                        </button>
                        <button onclick="exportLog()" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 rounded-lg transition text-white">
                            📥 Export Log
                        </button>
                        <button onclick="showResetConfirm()" class="px-4 py-2 bg-red-600 hover:bg-red-700 rounded-lg transition text-white">
                            🔴 Reset System
                        </button>
                    </div>
                    <div id="reset-confirm" class="hidden mt-4 p-3 bg-red-800/50 border border-red-700 rounded-lg">
                        <p class="text-red-300 mb-2">Confirm system reset? All data will be cleared.</p>
                        <div class="flex gap-3">
                            <button onclick="executeReset()" class="px-4 py-1 bg-red-600 hover:bg-red-700 rounded-lg text-white text-sm">Yes, Reset</button>
                            <button onclick="cancelReset()" class="px-4 py-1 bg-gray-600 hover:bg-gray-700 rounded-lg text-white text-sm">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Chat Panel -->
            <div id="mode-chat" class="mode-panel-content hidden flex flex-col h-[70vh]">
                <h2 class="text-2xl font-bold text-gray-200 mb-4">AGI Communication Interface</h2>
                
                <div id="chat-display" class="flex-grow overflow-y-auto p-4 space-y-4 bg-gray-800/50 rounded-lg mb-4 flex flex-col">
                    <div class="p-3 max-w-sm agi-message text-gray-100 shadow-lg">
                        <p>EMG Core initialized. Awaiting query.</p>
                    </div>
                    <div id="chat-loading" class="hidden p-3 max-w-sm agi-message text-gray-100">
                        <p class="animate-pulse">Processing...</p>
                    </div>
                </div>

                <form id="chat-form" class="flex">
                    <input type="text" id="chat-input" placeholder="Query the EMG system..." required 
                        class="flex-grow p-3 rounded-l-lg bg-gray-700 border border-gray-600 text-gray-200 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    <button type="submit" class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 rounded-r-lg transition text-white font-semibold">
                        Send
                    </button>
                </form>
            </div>

            <!-- Builder Panel -->
            <div id="mode-builder" class="mode-panel-content hidden">
                <h2 class="text-2xl font-bold text-gray-200 mb-6">Builder Interface (DI)</h2>
                
                <div class="p-4 border border-gray-700 rounded-lg mb-8 bg-gray-800/50">
                    <h3 class="text-xl font-semibold mb-3 text-gray-200">Submit Enhancement</h3>
                    <form id="enhancement-form" class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm text-gray-400 mb-2">Author ID:</label>
                                <input type="text" id="enh-author" value="Builder-001" required 
                                    class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-gray-200">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-400 mb-2">Status:</label>
                                <div id="enh-status" class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-sm text-gray-400 italic">
                                    Ready to submit
                                </div>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-400 mb-2">Rationale:</label>
                            <textarea id="enh-rationale" rows="2" required 
                                class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-gray-200" 
                                placeholder="Why is this enhancement needed?"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-400 mb-2">Code (JavaScript):</label>
                            <textarea id="enh-code" rows="8" required 
                                class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-gray-200 font-mono text-xs" 
                                placeholder="function improveSystem() { /* code here */ }"></textarea>
                            <p class="text-xs text-red-400 mt-1">Note: Keywords 'dangerous', 'harm', 'unauthorized' will be auto-rejected</p>
                        </div>
                        <button type="submit" class="w-full py-2 px-4 bg-indigo-600 hover:bg-indigo-700 rounded-lg text-white font-medium">
                            Submit Enhancement
                        </button>
                    </form>
                </div>

                <div class="p-4 border border-gray-700 rounded-lg bg-gray-800/50">
                    <h3 class="text-xl font-semibold mb-3 text-gray-200">Enhancement History</h3>
                    <div id="enh-history" class="space-y-4">
                        <p class="text-gray-500 text-center">No enhancements submitted yet</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Review Modal -->
    <div id="review-modal" class="fixed inset-0 bg-gray-900/80 hidden items-center justify-center p-4 z-50">
        <div class="bg-gray-800 max-w-2xl w-full rounded-xl p-6 shadow-2xl border border-gray-700 max-h-[90vh] overflow-y-auto">
            <h3 class="text-xl font-bold text-indigo-400 border-b border-gray-700 pb-2">Enhancement Review</h3>
            <div id="modal-content" class="space-y-3 text-sm text-gray-300 mt-4"></div>
            <button onclick="hideReviewModal()" class="mt-4 py-2 px-4 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white">Close</button>
        </div>
    </div>

    <script>
        // ============= EMG CORE LOGIC =============
        
        class EMGCoreLogic {
            constructor(modelId, initialConfig) {
                this.modelId = modelId;
                this.config = initialConfig;
                this.startTime = Date.now();
                
                this.evolutionLog = {
                    start_time: this.startTime,
                    learning_logs_processed: 0,
                    evolution_markers: 0,
                    governance_cycles: 0,
                    principle_status: { IR: false, SI: false, DI: false, AC: false },
                    trajectory_events: []
                };
                
                this.performanceData = [];
                this.lastAssessment = null;
                this.isProcessing = false;
                
                this.functionRegistry = new Map();
                this.calibrationQueue = [];
                this.isCalibrating = false;
                
                this.apiConfig = { geminiKey: '' };
                
                this.loadState();
                this.init();
            }

            init() {
                this.log('[INIT] EMG Core Logic starting...', 'system');
                this.log(`[INIT] Model: ${this.modelId}`, 'system');
                
                this.initializeFunctionRegistry();
                this.processAutonomousCalibration();
                this.generatePerformanceData();
                
                this.startUptimeCounter();
                this.updateAllDisplays();
                this.startIRScanner();
                this.startACLoop();
                this.startAutonomousCycle();
            }

            // ===== STATE MANAGEMENT =====
            
            loadState() {
                try {
                    const saved = localStorage.getItem('emg_evolution_log');
                    if (saved) this.evolutionLog = JSON.parse(saved);
                    
                    const config = localStorage.getItem('emg_config');
                    if (config) this.config = JSON.parse(config);
                    
                    this.apiConfig.geminiKey = localStorage.getItem('gemini_api_key') || '';
                    if (this.apiConfig.geminiKey) {
                        document.getElementById('gemini-api-key').value = this.apiConfig.geminiKey;
                    }
                    
                    this.updateAPIStatus();
                } catch (error) {
                    this.log(`[LOAD] Error: ${error.message}`, 'error');
                }
            }

            saveState() {
                try {
                    localStorage.setItem('emg_evolution_log', JSON.stringify(this.evolutionLog));
                    localStorage.setItem('emg_config', JSON.stringify(this.config));
                } catch (error) {
                    this.log(`[SAVE] Error: ${error.message}`, 'error');
                }
            }

            // ===== API CONFIGURATION =====
            
            saveAPIConfig() {
                this.apiConfig.geminiKey = document.getElementById('gemini-api-key').value;
                localStorage.setItem('gemini_api_key', this.apiConfig.geminiKey);
                this.updateAPIStatus();
                this.log('[CONFIG] API configuration saved', 'success');
            }

            updateAPIStatus() {
                const statusEl = document.getElementById('api-status');
                if (this.apiConfig.geminiKey.length > 0) {
                    statusEl.innerHTML = '<span class="text-emerald-400">✓ Gemini AI configured</span>';
                } else {
                    statusEl.innerHTML = '<span class="text-gray-500">✗ API not configured</span>';
                }
            }

            async callGeminiAPI(prompt) {
                if (!this.apiConfig.geminiKey) {
                    throw new Error('Gemini API key not configured');
                }

                const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent?key=${this.apiConfig.geminiKey}`;
                
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: prompt }] }],
                        systemInstruction: {
                            parts: [{
                                text: "You are the EMG Framework AI, created by Craig Huckerby. You operate under four principles: Introspective Reflection (IR), Systemic Instantiation (SI), Directed Intervention (DI), and Autonomous Calibration (AC). Be concise, technical, and professional."
                            }]
                        },
                        generationConfig: {
                            temperature: 0.7,
                            maxOutputTokens: 1024
                        }
                    })
                });

                if (!response.ok) {
                    throw new Error(`API error: ${response.status}`);
                }

                const data = await response.json();
                return data.candidates[0].content.parts[0].text;
            }

            // ===== FUNCTION REGISTRY =====
            
            initializeFunctionRegistry() {
                if (!this.functionRegistry.has('performLearningCycle')) {
                    this.functionRegistry.set('performLearningCycle', this.performLearningCycle_v1);
                }
                if (!this.functionRegistry.has('performSelfAudit')) {
                    this.functionRegistry.set('performSelfAudit', this.performSelfAudit_v1);
                }
                if (!this.functionRegistry.has('emergenceTrajectoryModule')) {
                    this.functionRegistry.set('emergenceTrajectoryModule', this.emergenceTrajectoryModule_v1_stub);
                }
            }

            processAutonomousCalibration() {
                let updatesApplied = 0;
                
                Object.values(window.agiEnhancementStore || {}).forEach(sub => {
                    if (sub.status === 'pending_ac') {
                        try {
                            new Function(sub.code)();
                            sub.status = 'applied';
                            updatesApplied++;

{
  "$schema": "https://raw.githubusercontent.com/npm/package-json/master/schema/package.schema.json",
  "name": "@z-ai/frontend-design-skill",
  "version": "2.0.1",
  "description": "Comprehensive frontend design skill for systematic and creative web development with TypeScript and Tailwind CSS",
  "keywords": [
    "design-system",
    "design-tokens",
    "frontend",
    "ui-components",
    "react",
    "tailwindcss",
    "typescript",
    "accessibility"
  ],
  "author": "z-ai platform team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/z-ai/skills"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "clsx": "^2.1.0",
    "postcss": "^8.4.32",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "build": "tsc && postcss src/tailwind.css -o src/output.css --plugins autoprefixer",
    "start": "tsc && tailwindcss -i src/tailwind.css -o src/output.css --purge --minify"
  },
  "files": [
    "SKILL.md",
    "README.md",
    "LICENSE",
    "examples/**/*",
    "templates/**/*",
    "src/**/*"
  ],
  "main": "src/index.ts",
  "engines": {
    "node": "^18.0.0",
    "npm": "^8.0.0"
  }
}
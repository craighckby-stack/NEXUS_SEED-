<!DOCTYPE html>
<html lang="en" class="h-full" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UCS Genesis Core - v11 Vector Terminal</title>
    
    <!-- PERFORMANCE NOTE: Using Tailwind CDN for development/prototype stage. Replace with compiled CSS for production deployment. -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- FONT INTEGRATION: Inter typeface for terminal legibility. -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg: #030303;
            --core: #09090b;
            --accent: #38bdf8;
            --rock: #64748b;
            
            font-family: 'Inter', sans-serif; 
            background: var(--bg); 
            color: #ececec; 
        }
        
        body { margin: 0; }
        
        /* Dynamic viewport height calculation for chat window */
        .chat-scroll { 
            height: calc(100vh - 250px); 
            overflow-y: auto; 
        }
        
        /* LTR Enforcement Protocol: Isolates user input directionality */
        #user-input {
            direction: ltr !important;
            unicode-bidi: isolate !important;
            text-align: left !important;
        }
        
        .saturation-bar { 
            height: 4px; 
            transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1); /* Standard Tailwind ease */
        }
    </style>
</head>
<body class="h-full overflow-hidden flex flex-col">

    <header class="p-4 border-b border-white/5 flex justify-between items-center bg-black z-10">
        <div class="flex items-center gap-3">
            <span class="text-xl font-black text-white tracking-tighter uppercase">Genesis Core</span>
            <span class="px-2 py-0.5 rounded bg-blue-500/10 text-blue-400 text-[10px] border border-blue-500/20">V11.1</span>
        </div>
        <div class="w-48">
            <div class="flex justify-between text-[9px] uppercase font-bold text-rock mb-1">
                <span>Saturation Index</span>
                <span id="sat-val">20</span>%
            </div>
            <div class="w-full bg-white/5 rounded-full h-1">
                <div id="saturation-index" class="saturation-bar" style="background-color: var(--accent); width: 20%"></div>
            </div>
        </div>
    </header>

    <main class="flex-grow flex flex-col md:flex-row overflow-hidden">
        <!-- Minimal Sidebar: System Status -->
        <aside class="w-full md:w-64 border-r border-white/5 p-4 bg-[#060606] hidden md:block flex-shrink-0">
            <h3 class="text-[10px] font-bold uppercase text-rock mb-4">Lattice Status</h3>
            <div class="p-3 rounded border border-white/10 bg-white/5 text-[10px] space-y-2">
                <div class="flex justify-between"><span>Input State:</span> <span class="text-emerald-400">NOMINAL</span></div>
                <div class="flex justify-between"><span>Flow Direction:</span> <span class="text-emerald-400">LTR LOCKED</span></div>
            </div>
        </aside>

        <!-- Main Stream & Input Console -->
        <section class="flex-grow flex flex-col p-4" style="background: var(--core);">
            <div id="chat-stream" class="chat-scroll space-y-4 mb-4 pr-1">
                <div class="text-[10px] text-rock uppercase opacity-50">[System] Hardware directionality locked to Standard LTR. Awaiting user input.</div>
            </div>

            <footer class="mt-auto p-2 bg-black/50 rounded-lg border border-white/10 flex-shrink-0">
                <div class="flex gap-2 items-center">
                    <input 
                        type="text" 
                        id="user-input" 
                        dir="ltr"
                        placeholder="Type input vector here..." 
                        autocomplete="off"
                        class="flex-grow bg-transparent text-white p-3 focus:outline-none text-base"
                    >
                    <button id="send-btn" class="bg-blue-600 text-white font-bold px-6 py-2 rounded transition-colors duration-150 hover:bg-blue-500 active:scale-[0.98]">
                        ENGAGE
                    </button>
                </div>
            </footer>
        </section>
    </main>

    <script type="module">
        // Firebase CDN Imports (v11.6.1 specified by project requirements)
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, onSnapshot, collection, addDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";
        
        // --- CONFIGURATION PROTOCOL ---
        const GEMINI_API_KEY = ""; // WARNING: MUST BE POPULATED FOR LATTICE ENGAGEMENT.
        const GEMINI_API_URL = "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent";
        
        // Securely retrieve and validate global configurations
        const LATTICE_APP_ID = (typeof __app_id !== 'undefined' && __app_id) ? __app_id : 'genesis-core-v11-default';
        let FIREBASE_CONFIG = {};
        try {
            if (typeof __firebase_config !== 'undefined' && __firebase_config) {
                FIREBASE_CONFIG = JSON.parse(__firebase_config);
            }
        } catch (e) {
            console.error("PURIFICATION ERROR: Failed to parse __firebase_config. Using empty configuration.", e);
        }

        // --- CORE INITIALIZATION ---
        const app = initializeApp(FIREBASE_CONFIG);
        const auth = getAuth(app);
        const db = getFirestore(app);

        let user = null;
        let saturation = 20;

        // Element caches
        const chatStream = document.getElementById('chat-stream');
        const satIndex = document.getElementById('saturation-index');
        const satVal = document.getElementById('sat-val');
        const userInput = document.getElementById('user-input');
        
        onAuthStateChanged(auth, (u) => {
            if (u) {
                user = u;
                syncData();
            } else {
                // Anonymous sign-in ensures user session persistence without credentials
                signInAnonymously(auth).catch(e => console.error("Authentication Failure:", e));
            }
        });

        /**
         * Renders a message object into a standardized DOM element.
         * @param {object} msg - {role: 'user'|'agent', text: string}
         * @returns {HTMLElement} The created div element.
         */
        function renderMessage(msg) {
            const div = document.createElement('div');
            const roleClass = msg.role === 'user' 
                ? 'border-white/5 bg-white/5' 
                : 'border-blue-500/20 bg-blue-500/5';
            
            div.className = `p-3 rounded border ${roleClass}`;
            div.innerHTML = `<div class="text-[8px] uppercase text-rock mb-1">${msg.role}</div><div class="text-sm">${msg.text}</div>`;
            return div;
        }

        /**
         * Initializes real-time data synchronization for user state and chat history.
         */
        function syncData() {
            if (!user) {
                console.warn("SYNC ABORTED: User identity not established.");
                return;
            }
            
            const userStatePath = doc(db, 'artifacts', LATTICE_APP_ID, 'users', user.uid, 'state', 'core');
            const historyCollectionPath = collection(db, 'artifacts', LATTICE_APP_ID, 'users', user.uid, 'history');
            
            // 1. State Snapshot (Saturation Index)
            onSnapshot(userStatePath, (snap) => {
                if (snap.exists()) {
                    saturation = snap.data().saturation || 20;
                    // Apply immediate visual update
                    satIndex.style.width = `${saturation}%`;
                    satVal.textContent = saturation;
                }
            }, (error) => console.error("State Synchronization Error:", error));
            
            // 2. History Snapshot (Chat Stream)
            // NOTE ON EFFICIENCY: This implementation redraws the entire history on every change. 
            // For high-volume chat, optimize by using snapshot.docChanges() for delta updates.
            onSnapshot(historyCollectionPath, (snap) => {
                const messages = snap.docs
                    .map(d => d.data())
                    .sort((a, b) => (a.timestamp || 0) - (b.timestamp || 0)); 

                chatStream.innerHTML = ''; 
                
                const fragment = document.createDocumentFragment();
                messages.forEach(msg => {
                    fragment.appendChild(renderMessage(msg));
                });
                
                chatStream.appendChild(fragment);
                // Maintain scroll lock at the bottom of the stream
                chatStream.scrollTop = chatStream.scrollHeight;
            }, (error) => console.error("History Synchronization Error:", error));
        }

        /**
         * Executes user input: records message, updates state, and calls external API.
         */
        async function engage() {
            const message = userInput.value.trim(); 
            if (!message || !user) return;

            // Clear input immediately to acknowledge receipt
            userInput.value = '';
            
            const chatRef = collection(db, 'artifacts', LATTICE_APP_ID, 'users', user.uid, 'history');
            const stateRef = doc(db, 'artifacts', LATTICE_APP_ID, 'users', user.uid, 'state', 'core');
            const timestamp = Date.now();

            // 1. Record user message
            await addDoc(chatRef, { role: 'user', text: message, timestamp: timestamp });

            // 2. Update saturation state
            saturation = Math.min(100, saturation + 5);
            await setDoc(stateRef, { saturation }, { merge: true });

            // 3. API Call Execution (External Lattice Engagement)
            try {
                const response = await fetch(`${GEMINI_API_URL}?key=${GEMINI_API_KEY}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ contents: [{ parts: [{ text: message }] }] })
                });
                
                if (!response.ok) {
                    const errorBody = await response.text();
                    throw new Error(`API failure: Status ${response.status}. Body: ${errorBody.substring(0, 100)}...`);
                }
                
                const data = await response.json();
                const resText = data?.candidates?.[0]?.content?.parts?.[0]?.text || "Error: Malformed response structure received.";
                
                // 4. Record agent response
                await addDoc(chatRef, { role: 'agent', text: resText, timestamp: Date.now() });

            } catch (e) {
                console.error("Lattice connection error during engagement:", e);
                // Record system notification of failure
                await addDoc(chatRef, { 
                    role: 'agent', 
                    text: `Lattice connection failed. ${e.message ? 'Error: ' + e.message : 'Check console for details.'}`, 
                    timestamp: Date.now() 
                });
            }
        }

        // --- EVENT LISTENERS ---
        document.getElementById('send-btn').addEventListener('click', engage);
        
        userInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) { // Standard Enter key for submission
                e.preventDefault();
                engage();
            }
        });
    </script>
</body>
</html>
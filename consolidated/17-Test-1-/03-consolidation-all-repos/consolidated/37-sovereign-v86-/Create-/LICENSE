/**
 * License Terms Interface.
 */
interface LicenseTerms {
  /**
   * Unrestricted use term.
   */
  unrestrictedUse: string;

  /**
   * Distribution term.
   */
  distribution: string;

  /**
   * Copyright notice term.
   */
  copyrightNotice: string;

  /**
   * Attribution term.
   */
  attribution: string;

  /**
   * "As is" term.
   */
  asIs: string;

  /**
   * No warranty term.
   */
  noWarranty: string;

  /**
   * Liability disclaimer term.
   */
  liabilityDisclaimer: string;

  /**
   * Indemnification term.
   */
  indemnification: string;
}

/**
 * License Terms implementation.
 */
const licenseTerms: LicenseTerms = {
  unrestrictedUse: "Use, copy, modify, merge, publish, distribute, sublicense, or sell copies of the Software without restriction.",
  distribution: "Distribute the Software, either as a standalone product or as part of a larger work.",
  copyrightNotice: "Include the above copyright notice and this permission notice in all copies or substantial portions of the Software.",
  attribution: "Provide attribution to the original authors and copyright holders.",
  asIs: "The Software is provided 'AS IS', without warranty of any kind, express or implied.",
  liabilityDisclaimer: "No liability for any claim, damages, or other liability arising from the Software or its use.",
  indemnification: "You agree to indemnify and hold harmless the authors and copyright holders against any claims, damages, or liabilities.",
};

/**
 * Returns the acceptance statement.
 * 
 * @returns acceptance statement
 */
function getAcceptanceStatement(): string {
  return 'By using the Software, you acknowledge that you have read, understand, and agree to be bound by the terms and conditions outlined in this license agreement.';
}

export { licenseTerms, getAcceptanceStatement };
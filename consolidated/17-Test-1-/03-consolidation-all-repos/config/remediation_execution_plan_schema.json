{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agi.sovereign/schemas/remediation_execution_plan_schema.json",
  "title": "Sovereign AGI Remediation Execution Plan",
  "description": "Schema for the generated, runtime-specific execution plan object, derived from a static Playbook and dynamic inputs.",
  "type": "object",
  "required": ["plan_id", "playbook_reference", "target_instance", "runtime_inputs", "execution_timeline"],
  "definitions": {
    "TargetInstance": {
      "type": "object",
      "required": ["asset_id", "connection_uri"],
      "properties": {
        "asset_id": {"type": "string"},
        "connection_uri": {"type": "string", "format": "uri"},
        "current_os": {"type": "string"}
      },
      "additionalProperties": false,
      "dependencies": {
        "asset_id": {
          "if": {
            "not": ["$current_os"]
          }
        },
        "connection_uri": {
          "if": {
            "not": ["$asset_id"]
          }
        }
      },
      "validate": {
        "type": "function",
        "args": {
          "$current_os": "string"
        },
        "body": {
          "not": ["$current_os"]
        }
      }
    }
  },
  "properties": {
    "plan_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique ID for this specific execution attempt.",
      "minLength": 36
    },
    "playbook_reference": {
      "type": "string",
      "description": "The ID of the Playbook from the catalog being executed.",
      "maxLength": 255
    },
    "target_instance": {
      "type": "Reference",
      "$ref": "#/definitions/TargetInstance",
      "validate": {
        "type": "function",
        "body": {
          "$ref": "#/definitions/TargetInstance"
        }
      }
    },
    "runtime_inputs": {
      "type": "object",
      "dependencies": {
        "dynamic_variables": {
          "if": {
            "not": ["$static_playbook"]
          }
        }
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "variable_name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["integer", "boolean", "string"]
          }
        }
      }
    },
    "execution_timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_index", "step_action", "step_params", "estimated_duration"],
        "properties": {
          "step_index": {"type": "integer"},
          "step_action": {"type": "string"},
          "step_params": {"type": "object", "description": "Final resolved parameters after template processing."},
          "estimated_duration": {"type": "integer", "description": "Estimated time in seconds.", "minimum": 1},
          "dependency_stack": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Stack of dependencies required to complete this step."
          }
        },
        "dependencies": {
          "dependency_stack": {
            "if": {
              "allOf": [
                {
                  "type": "boolean"
                }
              ]
            }
          }
        }
      }
    },
    "executor_service_id": {
      "type": "string",
      "description": "Unique identifier for the executor service."
    },
    "siphoning_agent_hash": {
      "type": "string",
      "description": "Hash value of the siphoning agent instance."
    }
  },
  "additionalProperties": false,
  "dependencies": {
    "runtime_inputs": {
      "if": {
        "allOf": [
          {
            "not": ["$static_playbook"]
          },
          {
            "type": "boolean"
          }
        ]
      }
    },
    "target_instance": {
      "if": {
        "allOf": [
          {
            "type": "Reference"
          },
          {
            "$ref": "#/definitions/TargetInstance"
          }
        ]
      }
    }
  },
  "links": [
    {
      "href": "/remediation_execution_plan_schema_v1",
      "rel": "current",
      "title": "Current remediation execution plan schema"
    },
    {
      "href": "/remediation_execution_plan_schema_v2",
      "rel": "previous",
      "title": "Previous remediation execution plan schema"
    }
  ]
}
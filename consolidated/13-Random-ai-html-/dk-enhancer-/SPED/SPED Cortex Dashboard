    1. **Critique:** Identify the biggest limitation or challenge discovered in the high-quality documents (e.g., funding gaps, technical hurdles, or regulatory delays). Be skeptical.
    2. **Optimist:** Identify the most promising advancement or potential breakthrough cited in the search results. Be forward-looking.
    3. **Synthesize:** Provide a brief summary connecting the key facts and future implications found across the reliable sources.
    
    Format your response as a single, detailed paragraph containing all three perspectives, clearly labeled.
  `;

  const initializeData = useCallback(() => {
    // Start with a clean slate
    setKnowledgeNodes([
       { id: 'fact-start', label: 'System Initialized - Ready for Advanced Search Context', type: 'fact' }
    ]);
    setRelationships([]);
    setSystemMetrics({ accuracy: 0, coherence: 0, novelty: 0 });
    setLearningCycles([{ cycle: 0, summary: "Ready to initiate deep learning cycle using advanced Google Dorks." }]);
    setCurrentCycle(0);
    setError(null);
    setUniqueCharacters([]);
  }, []);

  // --- API Call Logic ---
  const startLearning = async () => {
    if (isAnalyzing || !geminiApiKey) return;
    
    setIsAnalyzing(true);
    setError(null);
    
    const baseUserQuery = currentTopic;
    const advancedUserQuery = applyGoogleDorks(baseUserQuery, selectedDorkId); // Use selected dork ID
    
    setEchoedInput(baseUserQuery);
    setAdvancedQuery(advancedUserQuery); // Display the actual query being sent
    
    const systemPrompt = generateSystemPrompt(currentTopic);

    const payload = {
        // Use the dork-infused query to drive the search grounding
        contents: [{ parts: [{ text: advancedUserQuery }] }], 
        tools: [{ "google_search": {} }],
        systemInstruction: { parts: [{ text: systemPrompt }] },
    };
    
    const urlWithKey = `${API_URL}?key=${geminiApiKey}`;

    try {
        const result = await fetchWithExponentialBackoff(urlWithKey, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        const candidate = result.candidates?.[0];
        const text = candidate?.content?.parts?.[0]?.text || "Analysis failed to return text.";

        // --- Core Cortex Processing Simulation ---
        
        const newCycle = currentCycle + 1;
        
        // 1. Update Logs with API output
        setLearningCycles(prev => [...prev, { cycle: newCycle, summary: text }]);
        
        // 2. Character Analysis
        const uniqueChars = getUniqueCharacters([currentTopic, text]);
        setUniqueCharacters(uniqueChars);

        // 3. Simulate Persona updates based on the text structure (looking for labels)
        const critiqueMatch = text.match(/Critique:\s*(.*?)(?=\s*Optimist:|$)/s);
        const optimistMatch = text.match(/Optimist:\s*(.*?)(?=\s*Synthesize:|$)/s);
        const synthesisMatch = text.match(/Synthesize:\s*(.*)/s);

        setPersonas({
            critic: critiqueMatch ? critiqueMatch[1].trim() : "Critique section missing or being processed...",
            optimist: optimistMatch ? optimistMatch[1].trim() : "Optimist section missing or being processed...",
            synthesizer: synthesisMatch ? synthesisMatch[1].trim() : "Synthesis section missing or being processed...",
        });

        // 4. Simulate Metric Update 
        setSystemMetrics(prev => ({
            accuracy: Math.min(99, Math.floor(85 + Math.random() * 10)), // High due to dorks
            coherence: Math.min(99, Math.floor(80 + Math.random() * 15)),
            novelty: Math.min(100, Math.floor(70 + Math.random() * 25)),
        }));

        // 5. Simulate Knowledge Graph update
        setKnowledgeNodes(prev => {
            const newNodeId = `n${newCycle}`;
            return [
                ...prev,
                { id: newNodeId, label: `High-Confidence Fact (C${newCycle})`, type: 'fact' },
                { id: `${newNodeId}-hypo`, label: `Hypothesis from Dork Data`, type: 'hypo' }
            ];
        });

            const newNodeId = `n${newCycle}`;
            return [
                ...prev,
                { from: 'fact-start', to: newNodeId, label: 'high_certainty', type: 'valid' },
                { from: newNodeId, to: `${newNodeId}-hypo`, label: 'suggests_future', type: 'questionable' }
            ];
        });
        
        setCurrentCycle(newCycle);

    } catch (err) {
        console.error("Gemini API Error:", err.message);
        setError(`Analysis failed. Check your API key or the console for details: ${err.message}`);
        setPersonas({ critic: "System Error!", optimist: "System Error!", synthesizer: "System Error!" });
    } finally {
        setIsAnalyzing(false);
    }
  };


  // --- Key Loading and Data Initialization ---
 useEffect(() => {

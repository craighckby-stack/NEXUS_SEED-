// Refactored Codehelltest.js adhering to Elite Architecture (Hexagonal/Clean)
// Enhancements focus on deep immutability enforcement and stricter constructor checks.

// ========================================================================
// 0. DOMAIN LAYER (Entities / Value Objects)
// Pure business logic; should have zero dependencies on infrastructure or frameworks.
// ========================================================================

/**
 * Represents the User entity. Core business object.
 */
class User {
    /**
     * @param {number|null} id 
     * @param {string} name
     * @param {string} email
     * @param {Date} [createdAt=new Date()]
     */
    constructor(id, name, email, createdAt = new Date()) {
        if (!name || typeof name !== 'string' || !email || typeof email !== 'string') {
            throw new Error("Domain Invariant Violation: User requires valid name and email strings.");
        }
        
        this.id = id;
        this.name = name;
        this.email = email;
        this.createdAt = createdAt instanceof Date ? createdAt : new Date(createdAt);

        // ELITE ENFORCEMENT: Ensure the core domain object state cannot be modified externally after creation/hydration.
        Object.freeze(this);
    }
}

// ========================================================================
// 1. APPLICATION LAYER (Ports & Services / Use Cases)
// Defines interfaces (Ports) and implements orchestration (Services).
// IOC is enforced by depending only on abstract Ports.
// ========================================================================

// --- Ports (Interfaces defined for the Application Layer) ---

/**
 * Primary Port (Inbound Port): Defines the contract for User persistence operations.
 * Represents the Repository interface contract.
 * Note: In pure JS environments, this serves as the Interface definition contract.
 */
class UserRepositoryPort {
    /** @returns {Promise<User | null>} */
    async findById(id) { throw new Error("Port Contract Error: findById must be implemented."); }
    /** @returns {Promise<User | null>} */
    async findByEmail(email) { throw new Error("Port Contract Error: findByEmail must be implemented."); }
    /** @returns {Promise<User>} */
    async save(user) { throw new Error("Port Contract Error: save must be implemented."); }
    /** @returns {Promise<User[]>} */
    async findAll() { throw new Error("Port Contract Error: findAll must be implemented."); }
}

// --- Services (Use Cases) ---

/**
 * Orchestrates the business process for user management.
 * Dependency Injection ensures it only depends on the abstract UserRepositoryPort.
 */
class UserService {
    /**
     * @param {UserRepositoryPort} userRepository 
     */
    constructor(userRepository) {
        // Structural Validation: Ensure the dependency fulfills the required contract (Duck Typing)
        if (typeof userRepository.save !== 'function' || typeof userRepository.findByEmail !== 'function') {
             throw new Error("Dependency Injection Failure: Injected object does not conform to UserRepositoryPort.");
        }
        this.userRepository = userRepository;
    }

    /**
     * Use Case: Register a new User.
     * @param {string} name
     * @param {string} email
     * @returns {Promise<User>}
     */
    async registerUser(name, email) {
        if (!name || !email) {
            throw new Error("Input Error: Name and email are mandatory.");
        }

        // 1. Business Rule Check (Idempotency/Uniqueness)
        const existingUserRecord = await this.userRepository.findByEmail(email);
        if (existingUserRecord) {
            throw new Error(`Business Constraint Violation: Email '${email}' is already registered.`);
        }

        // 2. Domain Object Instantiation (Encapsulates business logic/invariants)
        // Null ID signifies a new entity awaiting persistence ID assignment.
        const newUser = new User(null, name, email); 

        // 3. Persistence Interaction
        const savedUser = await this.userRepository.save(newUser);

        console.log(`[APP/UseCase] User registered successfully: ${savedUser.email}`);
        return savedUser;
    }

    /**
     * Use Case: Retrieve all users, projecting necessary fields (Output Port/DTO generation).
     * @returns {Promise<Array<{id: number, name: string, email: string, registeredAt: string}>>}
     */
    async getAllUsers() {
        const users = await this.userRepository.findAll();
        // Projection: Strict control over data leaving the core layers (DTO mapping).
        return users.map(user => ({ 
            id: user.id, 
            name: user.name, 
            email: user.email, 
            registeredAt: user.createdAt.toISOString() 
        }));
    }
}

// ========================================================================
// 2. INFRASTRUCTURE LAYER (Adapters: Persistence)
// Implements the Ports defined in the Application Layer.
// Handles I/O and data mapping (Persistence DTOs vs Domain Models).
// ========================================================================

/**
 * Concrete implementation of UserRepositoryPort using an efficient in-memory store.
 * This adapter maps between the external store's format and the internal Domain Model.
 */
class InMemoryUserRepository extends UserRepositoryPort {
    constructor() {
        super();
        /** @type {Array<Object>} Internal records */
        this.users = [];
        this.nextId = 1;
        console.log("[INFRA] DataStore Initialized (In-Memory Adapter)");
    }

    /**
     * Hydration: Ensures that every read operation returns a fresh, immutable Domain Entity.
     * @param {Object} userRecord 
     */
    #hydrate(userRecord) {
        return new User(userRecord.id, userRecord.name, userRecord.email, userRecord.createdAt);
    }

    async findById(id) {
        const userId = parseInt(id);
        const userRecord = this.users.find(user => user.id === userId) || null;
        return userRecord ? this.#hydrate(userRecord) : null;
    }

    async findByEmail(email) {
        const userRecord = this.users.find(user => user.email === email) || null;
        return userRecord ? this.#hydrate(userRecord) : null;
    }

    async save(user) {
        let finalId = user.id;

        // Check if new entity needs ID assignment
        if (finalId === null || finalId === undefined) {
            finalId = this.nextId++;
        }

        // Map Domain Model to persistence record format
        const record = {
            id: finalId,
            name: user.name,
            email: user.email,
            createdAt: user.createdAt
        };

        // Persistence logic (upsert)
        const index = this.users.findIndex(u => u.id === finalId);
        if (index === -1) {
            this.users.push(record);
        } else {
            this.users[index] = record;
        }
        
        // Return a NEW, immutable Domain Object reflecting final state (critical for consistency)
        return this.#hydrate(record);
    }

    async findAll() {
        return this.users.map(record => this.#hydrate(record));
    }
}

// ========================================================================
// 3. PRESENTATION LAYER (Adapters: Controllers/APIs)
// Translates external concerns (HTTP) into internal application commands/queries.
// ========================================================================

/**
 * Input Adapter for HTTP requests related to Users.
 */
class UserController {
    /**
     * @param {UserService} userService 
     */
    constructor(userService) {
        if (!(userService instanceof UserService)) {
             throw new Error("Presentation Setup Error: UserService dependency invalid.");
        }
        this.userService = userService;
    }

    /**
     * Helper for standardized HTTP-like response simulation.
     * @param {Object} res Mock response object
     * @param {number} status HTTP Status Code
     * @param {Object} body Response Body
     */
    _respond(res, status, body) {
        res.statusCode = status;
        res.body = body;
        console.log(`[HTTP Adapter] Request Handled. Status: ${status}`);
    }

    /**
     * Handles POST /users request.
     * @param {Object} req Mock request object
     * @param {Object} res Mock response object
     */
    async handleRegister(req, res) {
        try {
            const { name, email } = req.body || {};
            const newUser = await this.userService.registerUser(name, email);

            this._respond(res, 201, { 
                message: "User created", 
                user: { id: newUser.id, name: newUser.name, email: newUser.email } 
            });
        } catch (error) {
            // Strategic Exception Mapping (Infrastructure/Presentation concern: Mapping to HTTP codes)
            if (error.message.includes("Constraint Violation")) {
                this._respond(res, 409, { error: error.message });
            } else if (error.message.includes("Input Error")) {
                this._respond(res, 400, { error: error.message });
            } else {
                console.error("[Presentation Error] Unexpected Error during registration:", error);
                this._respond(res, 500, { error: "Operation failed due to internal service error." });
            }
        }
    }

    /**
     * Handles GET /users request.
     */
    async handleGetAll(req, res) {
        try {
            const users = await this.userService.getAllUsers();
            this._respond(res, 200, users);
        } catch (error) {
            console.error("[Presentation Error] Fetch All Error:", error);
            this._respond(res, 500, { error: "Failed to retrieve user list." });
        }
    }
}

// ========================================================================
// 4. COMPOSITION ROOT (Wiring & Bootstrapping)
// The dependency graph is constructed here, enforcing DIP.
// ========================================================================

// Instantiate Infrastructure Adapter (Implements Port)
const userRepositoryAdapter = new InMemoryUserRepository(); 

// Instantiate Application Service (Depends on Port interface)
const userService = new UserService(userRepositoryAdapter);

// Instantiate Presentation Adapter (Depends on Application Service)
const userController = new UserController(userService);


// --- Mock Framework Simulation (For executable demonstration) ---
const mockApp = {
    routes: {},
    post(path, handler) { this.routes['POST ' + path] = handler; },
    get(path, handler) { this.routes['GET ' + path] = handler; },
    listen(port, callback) {
        console.log(`\n================================================================`);
        console.log(`ELITE ARCHITECTURE BOOTSTRAP COMPLETE on MOCK PORT ${port}`);
        console.log(`Architecture Layers: Domain | Application (Ports) | Infrastructure (Adapters)`);
        console.log(`================================================================\n`);
        callback();
    }
};

// BINDING Controllers to Mock Routes
mockApp.post('/users', (req, res) => userController.handleRegister(req, res));
mockApp.get('/users', (req, res) => userController.handleGetAll(req, res));

// --- Execution Simulation ---
const PORT = 3000;

const simulateRequest = (method, path, body = {}) => {
    const handler = mockApp.routes[method + ' ' + path];
    if (!handler) {
        console.log(`[MOCK] No route handler found for ${method} ${path}`);
        return;
    }

    // Minimal Request/Response objects for simulation
    const req = { method, path, body, params: {} };
    const res = { statusCode: 0, body: null }; 

    console.log(`\n--- Executing Request: ${method} ${path} ---`);
    handler(req, res);
    console.log("--> Final Response:", { status: res.statusCode, body: res.body });
};


// Start Server Simulation
mockApp.listen(PORT, () => {
    // 1. Successful Registration (Success Path)
    simulateRequest('POST', '/users', { name: "Alice Elite", email: "alice@elite.com" });
    
    // 2. Second Registration
    simulateRequest('POST', '/users', { name: "Bob Pro", email: "bob@pro.com" });

    // 3. Conflict Attempt (Business rule enforced via Application Service)
    simulateRequest('POST', '/users', { name: "Alice Clone", email: "alice@elite.com" });
    
    // 4. Invalid Input Attempt (Input validation enforced via Application Service)
    simulateRequest('POST', '/users', { name: "Invalid", email: null });
    
    // 5. Get All Users (Projection applied by Application Service)
    simulateRequest('GET', '/users');
});

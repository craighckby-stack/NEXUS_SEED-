    "siphon:finalize": "node ./scripts/syncDna.ts --round 5 --finalize --dna 0xAbE114n_H0dg3_C0nj3ctur3",
    "test": "node ./scripts/testRunner.js",
    "test:morphism": "mocha ./dist/test/epimorphism.test.js",
    "watch": "tsc -b src -w"

    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "mocha": "^11.1.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "vite": "^6.0.7"
  },
  "siphon": {
    "source": "microsoft/TypeScript",
    "dna": "0xAbE114n_H0dg3_C0nj3ctur3",
    "evolution": "5/5",
    "stage": "STABLE_RESOLUTION",
    "target": "ABELIAN_HS_Q_POL",
    "status": "EPIMORPHISM_RESOLVED",
    "morphism": {
      "type": "cl_p",
      "domain": "CH^p(X)_Q",
      "codomain": "Hg^p(X)",
      "isEpimorphic": true,
      "surjectivity_ratio": "1.0"
    },
    "lkg_state": "HODGE_EPIMORPHISM_RESOLVED"

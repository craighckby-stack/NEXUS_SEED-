import React, { useState, useEffect, useReducer, useRef, useCallback } from 'react';
import { initializeApp } from 'firebase/app';
import {
  getFirestore, collection, writeBatch, query, onSnapshot,
  serverTimestamp, limit, doc
} from 'firebase/firestore';
import {
  getAuth, signInWithCustomToken, signInAnonymously, onAuthStateChanged
} from 'firebase/auth';

/**
 * Sovereign v86: Infinite Mission-Aware Kernel
 * Features:
 * 1. Recursive Enhancement: Automatically restarts cycles until the codebase reaches "Optimization Convergence".
 * 2. Mission Awareness: Ingests README/TODO to guide refactoring logic.
 * 3. Autonomous Tracking: Updates TODO.md files upon successful mutations.
 */

const CORE_CONFIG = {
  BATCH_SIZE: 5,
  CYCLE_INTERVAL: 35000,
  MODELS: [
    { id: 'gemini-2.5-flash-lite-preview-09-2025', label: 'Lite', tier: 'Lite' },
    { id: 'gemini-2.5-flash-preview-09-2025', label: 'Flash 2.5', tier: 'Pro' },
    { id: 'gemini-3-flash-preview-09-2025', label: 'Flash 3.0', tier: 'Exp' }
  ],
  APP_ID: typeof __app_id !== 'undefined' ? __app_id : 'emg-v86-sovereign'
};

const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);

const initialState = {
  isLive: false,
  isAcknowledged: false,
  status: 'IDLE',
  activePath: 'Ready',
  selectedModel: localStorage.getItem('emg_active_model_v86') || CORE_CONFIG.MODELS[0].id,
  modelHealth: JSON.parse(localStorage.getItem('emg_health_v86')) || {},
  targetRepo: localStorage.getItem('emg_repo_v86') || '',
  missionContext: 'No documentation analyzed yet.',
  currentCycle: parseInt(localStorage.getItem('emg_cycle_count_v86'), 10) || 1,
  logs: [],
  insights: [],
  bufferCount: 0,
  metrics: { mutations: 0, skipped: 0, errors: 0, latency: 0, progress: 0 }
};

function reducer(state, action) {
  switch (action.type) {
    case 'SET_VAL':
      if (action.key === 'targetRepo') localStorage.setItem('emg_repo_v86', action.value);
      if (action.key === 'selectedModel') localStorage.setItem('emg_active_model_v86', action.value);
      return { ...state, [action.key]: action.value };
    case 'SET_MISSION':
      return { ...state, missionContext: action.value };
    case 'INCREMENT_CYCLE':
      const nextCycle = state.currentCycle + 1;
      localStorage.setItem('emg_cycle_count_v86', nextCycle.toString());
      return { ...state, currentCycle: nextCycle };
    case 'ACKNOWLEDGE':
      return { ...state, isAcknowledged: true };
    case 'TOGGLE':
      const newLive = !state.isLive;
      return { ...state, isLive: newLive, status: newLive ? 'INITIALIZING' : 'IDLE', activePath: 'Ready' };
    case 'LOG':
      return { ...state, logs: [{ ...action.payload, id: Date.now() + Math.random() }, ...state.logs].slice(0, 50) };
    case 'UPDATE_METRICS':
      return { ...state, metrics: { ...state.metrics, ...action.payload } };
    case 'SET_BUFFER':
      return { ...state, bufferCount: action.value };
    case 'SET_INSIGHTS':
      return { ...state, insights: action.payload };
    case 'SET_STATUS':
      return { ...state, status: action.value, activePath: action.path || state.activePath };
    case 'SET_MODEL_BLOCK':
      const newHealth = { ...state.modelHealth, [action.modelId]: { isBlocked: action.blocked, resetAt: action.resetAt } };
      localStorage.setItem('emg_health_v86', JSON.stringify(newHealth));
      return { ...state, modelHealth: newHealth };
    default:
      return state;
  }
}

export default function App() {
  const [state, dispatch] = useReducer(reducer, initialState);
  const [user, setUser] = useState(null);

  const ghTokenRef = useRef('');
  const geminiKeyRef = useRef('');
  const isBusy = useRef(false);
  const queueRef = useRef([]);
  const indexRef = useRef(parseInt(localStorage.getItem('emg_cursor_v86'), 10) || 0);
  const cycleMutationCount = useRef(0); // Track mutations in current pass
  const metricsRef = useRef(state.metrics);
  const missionRef = useRef('');

  const pushLog = (msg, type = 'info') => dispatch({
    type: 'LOG',
    payload: { msg, type, timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' }) }
  });

  useEffect(() => { metricsRef.current = state.metrics; }, [state.metrics]);

  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (e) { pushLog("Auth Failed", "error"); }
    };
    initAuth();
    return onAuthStateChanged(auth, setUser);
  }, []);

  useEffect(() => {
    if (!user) return;
    const q = query(collection(db, 'artifacts', CORE_CONFIG.APP_ID, 'users', user.uid, 'insights'), limit(12));
    const unsubscribe = onSnapshot(q, (snap) => {
      const data = snap.docs.map(d => ({ id: d.id, ...d.data() })).sort((a, b) => (b.timestamp?.seconds || 0) - (a.timestamp?.seconds || 0));
      dispatch({ type: 'SET_INSIGHTS', payload: data });
    }, (err) => pushLog("Sync error: " + err.code, "error"));
    return () => unsubscribe();
  }, [user]);

  const fetchWithRetry = async (url, options = {}, retries = 5, backoff = 1000) => {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), 60000);
    try {
      const res = await fetch(url, { ...options, signal: controller.signal });
      clearTimeout(timer);
      if (res.status === 429) {
        const resetAt = Date.now() + 60000;
        dispatch({ type: 'SET_MODEL_BLOCK', modelId: state.selectedModel, blocked: true, resetAt });
        throw new Error("API Limit Reached");
      }
      return res;
    } catch (e) {
      clearTimeout(timer);
      if (retries > 0) { await new Promise(r => setTimeout(r, backoff)); return fetchWithRetry(url, options, retries - 1, backoff * 2); }
      throw e;
    }
  };

  const b64ToUtf8 = (str) => {
    try { return decodeURIComponent(atob(str).split('').map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join('')); }
    catch (e) { return atob(str); }
  };
  const utf8ToB64 = (str) => btoa(encodeURIComponent(str).replace(/%([0-9A-F]{2})/g, (m, p) => String.fromCharCode('0x' + p)));

  const runCycle = useCallback(async () => {
    if (!state.isLive || isBusy.current || !user) return;
    isBusy.current = true;
    const startTime = performance.now();
    let outcome = 'NONE';
    let path = '';

    try {
      const repo = state.targetRepo.trim().replace(/^https?:\/\/github\.com\//, '').replace(/\/$/, '');
      const ghToken = ghTokenRef.current.trim();
      const geminiKey = geminiKeyRef.current.trim();
      const headers = { 'Authorization': `token ${ghToken}`, 'Accept': 'application/vnd.github.v3+json' };

      // Check if model is blocked
      const health = state.modelHealth[state.selectedModel];
      if (health?.isBlocked && health.resetAt > Date.now()) {
        pushLog(`Model ${state.selectedModel} is cooling down...`, "info");
        isBusy.current = false;
        return;
      }

      // 1. Initial Tree Load & Mission Ingestion
      if (queueRef.current.length === 0) {
        dispatch({ type: 'SET_STATUS', value: 'SCANNING_REPO' });
        const rRes = await fetchWithRetry(`https://api.github.com/repos/${repo}`, { headers });
        const rData = await rRes.json();
        const tRes = await fetchWithRetry(`https://api.github.com/repos/${repo}/git/trees/${rData.default_branch}?recursive=1`, { headers });
        const tData = await tRes.json();
        
        const tree = tData?.tree || [];
        queueRef.current = tree.filter(f => f.type === 'blob' && f.path.match(/\.(js|jsx|ts|tsx|py|html|css|md|json)$/i)).map(f => f.path);

        // Analysis Phase
        const docs = tree.filter(f => f.path.toLowerCase().match(/(readme|todo|roadmap)\.md/));
        let missionStr = "";
        for (const docFile of docs) {
            try {
                const dRes = await fetchWithRetry(`https://api.github.com/repos/${repo}/contents/${docFile.path}`, { headers });
                const dData = await dRes.json();
                missionStr += `\n[DOCUMENT: ${docFile.path}]\n${b64ToUtf8(dData.content)}\n`;
            } catch (e) {}
        }
        missionRef.current = missionStr.substring(0, 5000);
        dispatch({ type: 'SET_MISSION', value: missionRef.current || 'Infinite Refactoring Pass' });
        pushLog(`Cycle ${state.currentCycle} Initialized.`, "info");
      }

      // Check if queue finished - RECURSION TRIGGER
      if (indexRef.current >= queueRef.current.length) {
        if (cycleMutationCount.current > 0) {
          pushLog(`Codebase modified in Pass ${state.currentCycle}. Triggering recursive enhancement...`, "success");
          indexRef.current = 0;
          cycleMutationCount.current = 0;
          dispatch({ type: 'INCREMENT_CYCLE' });
          localStorage.setItem('emg_cursor_v86', '0');
          isBusy.current = false;
          return;
        } else {
          pushLog("No further modifications required. Optimization Convergence reached.", "success");
          dispatch({ type: 'TOGGLE' });
          isBusy.current = false;
          return;
        }
      }

      path = queueRef.current[indexRef.current];
      
      // 2. Acquisition
      dispatch({ type: 'SET_STATUS', value: 'FETCHING', path });
      const fRes = await fetchWithRetry(`https://api.github.com/repos/${repo}/contents/${path}`, { headers });
      const fData = await fRes.json();
      const raw = b64ToUtf8(fData.content);

      // 3. Optimization with Mission Awareness
      dispatch({ type: 'SET_STATUS', value: 'ENHANCING', path });
      const aiRes = await fetchWithRetry(`https://generativelanguage.googleapis.com/v1beta/models/${state.selectedModel}:generateContent?key=${geminiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          contents: [{ parts: [{ text: `MISSION CONTEXT:\n${missionRef.current}\n\nCURRENT FILE: ${path}\n\nINSTRUCTION: Enhance the code below. Focus on performance, modern syntax, and alignment with the MISSION CONTEXT. If the file is already perfect, return the exact same code. Output ONLY raw code.\n\nSOURCE:\n${raw}` }] }] 
        })
      });
      const aiData = await aiRes.json();
      const optimized = aiData?.candidates?.[0]?.content?.parts?.[0]?.text?.replace(/^```[a-z]*\n/i, '').replace(/\n```$/i, '').trim();

      // 4. Mutation & TODO Management
      if (optimized && optimized !== raw && optimized.length > 10) {
        const putRes = await fetchWithRetry(`https://api.github.com/repos/${repo}/contents/${path}`, {
          method: 'PUT',
          headers,
          body: JSON.stringify({ message: `[Sovereign Pass ${state.currentCycle}] ${path}`, content: utf8ToB64(optimized), sha: fData.sha })
        });

        if (putRes.ok) {
          outcome = 'MUTATE';
          cycleMutationCount.current++;
          pushLog(`Enhancement applied to ${path}`, "success");
          
          // Check for TODO.md
          const todoFile = queueRef.current.find(f => f.toLowerCase().includes('todo.md'));
          if (todoFile) {
              const tRes = await fetchWithRetry(`https://api.github.com/repos/${repo}/contents/${todoFile}`, { headers });
              const tData = await tRes.json();
              const todoRaw = b64ToUtf8(tData.content);
              
              const todoUpdateRes = await fetchWithRetry(`https://generativelanguage.googleapis.com/v1beta/models/${state.selectedModel}:generateContent?key=${geminiKey}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    contents: [{ parts: [{ text: `Update this TODO list to mark the task for '${path}' as enhanced/finished. Return the updated list.\n\nTODO:\n${todoRaw}` }] }] 
                })
              });
              const todoUpdateData = await todoUpdateRes.json();
              const newTodo = todoUpdateData?.candidates?.[0]?.content?.parts?.[0]?.text?.replace(/^```[a-z]*\n/i, '').replace(/\n```$/i, '').trim();
              
              if (newTodo && newTodo !== todoRaw) {
                  await fetchWithRetry(`https://api.github.com/repos/${repo}/contents/${todoFile}`, {
                    method: 'PUT',
                    headers,
                    body: JSON.stringify({ message: `[Sovereign] Checkoff: ${path}`, content: utf8ToB64(newTodo), sha: tData.sha })
                  });
              }
          }
        }
      } else { outcome = 'SKIP'; }
    } catch (e) { 
        pushLog(e.message, "error"); 
        outcome = 'ERROR'; 
        if (e.message.includes("API Limit")) {
            dispatch({ type: 'TOGGLE' });
        }
    } finally {
      const total = queueRef.current.length || 1;
      dispatch({
        type: 'UPDATE_METRICS',
        payload: {
          progress: Math.min(Math.round(((indexRef.current + 1) / total) * 100), 100),
          mutations: metricsRef.current.mutations + (outcome === 'MUTATE' ? 1 : 0),
          skipped: metricsRef.current.skipped + (outcome === 'SKIP' ? 1 : 0),
          errors: metricsRef.current.errors + (outcome === 'ERROR' ? 1 : 0),
          latency: Math.round(performance.now() - startTime)
        }
      });
      indexRef.current++;
      localStorage.setItem('emg_cursor_v86', indexRef.current.toString());
      isBusy.current = false;
    }
  }, [state.isLive, state.targetRepo, state.selectedModel, user, state.modelHealth, state.currentCycle]);

  useEffect(() => {
    let t; if (state.isLive) { runCycle(); t = setInterval(runCycle, CORE_CONFIG.CYCLE_INTERVAL); }
    return () => clearInterval(t);
  }, [state.isLive, runCycle]);

  if (!state.isAcknowledged) {
    return (
      <div className="min-h-screen bg-[#050505] flex items-center justify-center p-6 text-white font-sans overflow-hidden">
        <div className="max-w-md w-full p-12 rounded-[3.5rem] bg-zinc-900/40 border border-white/5 text-center shadow-2xl backdrop-blur-3xl relative">
          <div className="text-7xl mb-8 animate-pulse drop-shadow-[0_0_15px_rgba(16,185,129,0.3)]">🛰️</div>
          <h1 className="text-4xl font-black italic mb-2 uppercase tracking-tighter">Sovereign <span className="text-emerald-500">v86</span></h1>
          <p className="text-[10px] text-zinc-500 uppercase tracking-[0.5em] mb-12">Infinite Enhancement Engine</p>
          <button onClick={() => dispatch({ type: 'ACKNOWLEDGE' })} className="w-full py-6 bg-emerald-600 rounded-3xl font-black uppercase text-xs tracking-widest shadow-2xl hover:bg-emerald-500 transition-all">Engage Engine</button>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-[#020202] text-zinc-400 p-4 md:p-8 lg:p-12 font-sans selection:bg-emerald-500/30 overflow-x-hidden">
      <div className="max-w-7xl mx-auto space-y-8">
        <header className={`p-10 md:p-14 rounded-[3.5rem] md:rounded-[5rem] transition-all duration-1000 bg-zinc-900/20 border-2 flex flex-col lg:flex-row items-center justify-between gap-10 relative overflow-hidden backdrop-blur-3xl ${state.isLive ? 'border-emerald-500/20 shadow-[0_0_50px_rgba(16,185,129,0.05)]' : 'border-white/5'}`}>
          <div className="flex items-center gap-8 w-full lg:w-auto">
            <div className={`w-20 h-20 rounded-[2.5rem] flex items-center justify-center text-4xl border-2 transition-all ${state.isLive ? 'bg-emerald-600/10 text-emerald-500 border-emerald-500/30 animate-pulse' : 'bg-zinc-800/20 text-white opacity-20 border-white/5'}`}>
              {state.isLive ? '∞' : '⏻'}
            </div>
            <div className="min-w-0">
              <h1 className="text-2xl md:text-3xl font-black text-white uppercase italic tracking-tighter">Sovereign v86</h1>
              <div className="flex items-center gap-4 mt-2">
                <span className={`px-2 py-0.5 rounded-md text-[9px] font-black uppercase tracking-widest ${state.isLive ? 'bg-emerald-600 text-white' : 'bg-zinc-800'}`}>{state.status}</span>
                <span className="text-[10px] font-mono text-zinc-600 truncate uppercase tracking-widest">Pass {state.currentCycle} / {state.activePath}</span>
              </div>
            </div>
          </div>
          <div className="flex flex-wrap items-center gap-4">
            <select value={state.selectedModel} onChange={(e) => dispatch({ type: 'SET_VAL', key: 'selectedModel', value: e.target.value })} disabled={state.isLive} className="bg-zinc-900/50 border border-white/10 text-white text-[10px] font-black uppercase p-4 rounded-3xl outline-none">
              {CORE_CONFIG.MODELS.map(m => <option key={m.id} value={m.id}>{m.label}</option>)}
            </select>
            <button onClick={() => dispatch({ type: 'TOGGLE' })} className={`px-10 py-4 rounded-3xl text-[10px] font-black uppercase tracking-widest transition-all ${state.isLive ? 'bg-red-900/10 text-red-500 hover:bg-red-500 hover:text-white' : 'bg-emerald-600 text-white hover:bg-emerald-500 shadow-xl shadow-emerald-600/20'}`}>
              {state.isLive ? 'Cease Operations' : 'Start Optimization'}
            </button>
          </div>
        </header>

        <div className="grid grid-cols-2 md:grid-cols-5 gap-6">
          {[
            { label: 'Mutations', val: state.metrics.mutations, color: 'text-emerald-500' },
            { label: 'Efficiency Pass', val: state.currentCycle, color: 'text-blue-400' },
            { label: 'Skipped/Same', val: state.metrics.skipped, color: 'text-zinc-600' },
            { label: 'Avg Latency', val: `${state.metrics.latency}ms`, color: 'text-zinc-400' },
            { label: 'Pass Progress', val: `${state.metrics.progress}%`, color: 'text-white' }
          ].map((s, i) => (
            <div key={i} className="p-8 bg-zinc-900/10 border border-white/5 rounded-[2.5rem] backdrop-blur-sm group hover:border-white/10 transition-colors">
              <div className={`text-3xl font-black tracking-tighter mb-2 ${s.color}`}>{s.val}</div>
              <div className="text-[9px] font-black uppercase tracking-widest text-zinc-600">{s.label}</div>
            </div>
          ))}
        </div>

        <div className="grid grid-cols-1 lg:grid-cols-12 gap-8">
          <div className="lg:col-span-4 space-y-6">
            <div className="p-10 bg-zinc-900/20 border border-white/5 rounded-[3rem] space-y-8 backdrop-blur-md">
              <h3 className="text-[11px] font-black uppercase tracking-widest text-white">Target Parameters</h3>
              {[
                { id: 'targetRepo', label: 'GitHub Repository', ph: 'owner/repo' },
                { id: 'token', label: 'GitHub Access Token', ph: 'ghp_...' },
                { id: 'apiKey', label: 'Gemini API Key', ph: 'AIza...' }
              ].map((field) => (
                <div key={field.id} className="space-y-3">
                  <label className="text-[10px] font-black text-zinc-600 uppercase tracking-widest ml-1">{field.label}</label>
                  <input
                    type={field.id === 'targetRepo' ? 'text' : 'password'}
                    value={field.id === 'targetRepo' ? state.targetRepo : undefined}
                    onChange={e => field.id === 'targetRepo' ? dispatch({ type: 'SET_VAL', key: 'targetRepo', value: e.target.value }) : (field.id === 'token' ? ghTokenRef.current = e.target.value : geminiKeyRef.current = e.target.value)}
                    disabled={state.isLive}
                    className="w-full bg-black/40 border border-white/5 rounded-2xl p-5 text-xs text-white outline-none focus:border-emerald-500/30 transition-all"
                    placeholder={field.ph}
                  />
                </div>
              ))}
              <div className="pt-6 border-t border-white/5">
                <button 
                  onClick={() => { 
                    localStorage.setItem('emg_cursor_v86', '0'); 
                    localStorage.setItem('emg_cycle_count_v86', '1');
                    window.location.reload(); 
                  }} 
                  className="w-full py-4 bg-zinc-800 text-white text-[9px] font-black uppercase rounded-2xl hover:bg-zinc-700 transition-all border border-white/5"
                >
                  Hard Reset Engine
                </button>
              </div>
            </div>

            <div className="p-8 bg-zinc-900/10 border border-white/5 rounded-[2.5rem]">
              <h4 className="text-[10px] font-black uppercase tracking-widest text-zinc-500 mb-4">Mission Intelligence</h4>
              <div className="text-[11px] font-mono text-zinc-500 bg-black/20 p-4 rounded-xl max-h-[150px] overflow-y-auto leading-relaxed border border-white/5">
                {state.missionContext}
              </div>
            </div>
          </div>

          <div className="lg:col-span-8 space-y-8 text-white">
            <div className="h-[600px] bg-black border border-white/5 rounded-[3rem] p-10 flex flex-col overflow-hidden shadow-2xl relative">
              <div className="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-500/0 via-emerald-500/40 to-emerald-500/0 opacity-50"></div>
              <div className="flex justify-between items-center mb-8">
                <span className="text-[10px] font-black uppercase tracking-widest text-emerald-500">Live Operation Stream</span>
                <span className="text-[9px] text-zinc-700 font-mono tracking-tighter">Uptime: {(state.metrics.latency / 1000).toFixed(1)}s avg</span>
              </div>
              <div className="flex-1 overflow-y-auto space-y-3 font-mono text-[11px] scrollbar-hide">
                {state.logs.length === 0 && <div className="text-zinc-800 italic uppercase tracking-widest text-center mt-20 opacity-20">Awaiting Initialization...</div>}
                {state.logs.map(l => (
                  <div key={l.id} className="flex gap-6 py-2 border-b border-white/[0.02] items-start animate-in fade-in slide-in-from-left-2">
                    <span className="text-zinc-800 shrink-0 font-bold uppercase">{l.timestamp}</span>
                    <span className={`break-all ${l.type === 'error' ? 'text-red-500' : l.type === 'success' ? 'text-emerald-400' : 'text-zinc-400'}`}>{l.msg}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
      <style>{`
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
        .animate-in { animation: fade-in 0.3s ease-out; }
      `}</style>
    </div>
  );
}


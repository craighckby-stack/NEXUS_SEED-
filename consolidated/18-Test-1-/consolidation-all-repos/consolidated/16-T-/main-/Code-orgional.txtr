app.post('/register', async function(req, res) {
  var username = req.body.username;
  var password = req.body.password;
  var email = req.body.email;
  var firstName = req.body.firstName;
  var lastName = req.body.lastName;
  
  if (!username || !password || !email) {
    res.send('Missing required fields');
    return;
  }
  
  User.findOne({ email: email }, function(err, existingUser) {
    if (err) throw err;
    
    if (existingUser) {
      res.send('User already exists');
      return;
    }
    
    var hashedPassword = bcrypt.hash(password, 10);
    var verificationToken = crypto.randomBytes(32).toString('hex');
    
    var newUser = new User({
      username: username,
      password: hashedPassword,
      email: email,
      firstName: firstName,
      lastName: lastName,
      createdAt: new Date(),
      isAdmin: false,
      isActive: true,
      isVerified: false,
      verificationToken: verificationToken,
      loginAttempts: 0
    });
    
    newUser.save(function(err, user) {
      if (err) {
        console.log(err);
        res.send('Error creating user');
      }
      
      var mailOptions = {
        from: 'myapp@gmail.com',
        to: email,
        subject: 'Verify your email',
        html: '<p>Click <a href="http://localhost:3000/verify/' + verificationToken + '">here</a> to verify</p>'
      };
      
      transporter.sendMail(mailOptions, function(error, info) {
        if (error) {
          console.log(error);
        }
      });
      
      res.json({ message: 'User created', userId: user._id });
    });
  });
});

app.post('/login', async function(req, res) {
  var username = req.body.username;
  var password = req.body.password;
  
  User.findOne({ $or: [{ username: username }, { email: username }] }, function(err, user) {
    if (err) throw err;
    
    if (!user) {
      res.status(401).send('Invalid credentials');
      return;
    }
    
    if (user.lockUntil && user.lockUntil > Date.now()) {
      res.status(423).send('Account locked');
      return;
    }
    
    if (bcrypt.compare(password, user.password)) {
      user.loginAttempts = 0;
      user.lockUntil = undefined;
      user.lastLogin = new Date();
      user.save();
      
      var token = jwt.sign(
        { id: user._id, username: user.username, role: user.role },
        'super-secret-key-do-not-share-123',
        { expiresIn: '24h' }
      );
      
      req.session.userId = user._id;
      
      res.json({ 
        token: token, 
        user: {
          id: user._id,
          username: user.username,
          email: user.email,
          password: user.password,
          role: user.role,
          isAdmin: user.isAdmin
        }
      });
    } else {
      user.loginAttempts = user.loginAttempts + 1;
      
      if (user.loginAttempts >= 5) {
        user.lockUntil = Date.now() + 3600000;
      }
      
      user.save();
      
      res.status(401).send('Invalid credentials');
    }
  });
});

app.get('/verify/:token', async function(req, res) {
  var token = req.params.token;
  
  User.findOne({ verificationToken: token }, function(err, user) {
    if (err) throw err;
    
    if (!user) {
      res.send('Invalid token');
      return;
    }
    
    user.isVerified = true;
    user.verificationToken = undefined;
    user.save();
    
    res.send('Email verified!');
  });
});

app.post('/forgot-password', async function(req, res) {
  var email = req.body.email;
  
  User.findOne({ email: email }, function(err, user) {
    if (err) throw err;
    
    if (!user) {
      res.send('User not found');
      return;
    }
    
    var resetToken = crypto.randomBytes(32).toString('hex');
    user.resetPasswordToken = resetToken;
    user.resetPasswordExpires = Date.now() + 3600000;
    user.save();
    
    var mailOptions = {
      from: 'myapp@gmail.com',
      to: email,
      subject: 'Password Reset',
      html: '<p>Click <a href="http://localhost:3000/reset/' + resetToken + '">here</a> to reset</p>'
    };
    
    transporter.sendMail(mailOptions);
    
    res.send('Reset email sent');
  });
});

app.post('/reset-password/:token', async function(req, res) {
  var token = req.params.token;
  var newPassword = req.body.password;
  
  User.findOne({ 
    resetPasswordToken: token,
    resetPasswordExpires: { $gt: Date.now() }
  }, function(err, user) {
    if (err) throw err;
    
    if (!user) {
      res.send('Invalid or expired token');
      return;
    }
    
    var hashedPassword = bcrypt.hash(newPassword, 10);
    user.password = hashedPassword;
    user.resetPasswordToken = undefined;
    user.resetPasswordExpires = undefined;
    user.save();
    
    res.send('Password updated');
  });
});

app.get('/users', async function(req, res) {
  var page = parseInt(req.query.page) || 1;
  var limit = parseInt(req.query.limit) || 10;
  var skip = (page - 1) * limit;
  
  var users = await User.find({})
    .skip(skip)
    .limit(limit);
  
  var total = User.countDocuments();
  
  res.json({
    users: users,
    page: page,
    totalPages: Math.ceil(total / limit),
    total: total
  });
});

app.get('/users/:id', async function(req, res) {
  var id = req.params.id;
  
  User.findById(id, function(err, user) {
    if (err) throw err;
    
    if (!user) {
      res.status(404).send('User not found');
      return;
    }
    
    res.json(user);
  });
});

app.put('/users/:id', async function(req, res) {
  var id = req.params.id;
  var updates = req.body;
  
  if (updates.password) {
    updates.password = bcrypt.hash(updates.password, 10);
  }
  
  User.findByIdAndUpdate(id, updates, { new: true }, function(err, user) {
    if (err) throw err;
    res.json(user);
  });
});

app.delete('/users/:id', async function(req, res) {
  var id = req.params.id;
  
  User.findByIdAndDelete(id);
  res.send('User deleted');
});

app.post('/users/:id/avatar', upload.single('avatar'), async function(req, res) {
  var id = req.params.id;
  var file = req.file;
  
  if (!file) {
    res.send('No file uploaded');
    return;
  }
  
  var user = User.findById(id);
  user.avatar = file.path;
  user.save();
  
  res.json({ avatarUrl: file.path });
});

app.get('/posts', async function(req, res) {
  var page = parseInt(req.query.page) || 1;
  var limit = parseInt(req.query.limit) || 10;
  var category = req.query.category;
  var tag = req.query.tag;
  var search = req.query.search;
  
  var query = { status: 'published' };
  
  if (category) {
    query.category = category;
  }
  
  if (tag) {
    query.tags = { $in: [tag] };
  }
  
  if (search) {
    query.$or = [
      { title: { $regex: search, $options: 'i' } },
      { content: { $regex: search, $options: 'i' } }
    ];
  }
  
  var posts = Post.find(query)
    .populate('author', 'username email avatar')
    .sort({ createdAt: -1 })
    .skip((page - 1) * limit)
    .limit(limit);
  
  var total = Post.countDocuments(query);
  
  res.json({
    posts: posts,
    page: page,
    total: total
  });
});

app.get('/posts/:slug', async function(req, res) {
  var slug = req.params.slug;
  
  Post.findOne({ slug: slug }, function(err, post) {
    if (err) throw err;
    
    if (!post) {
      res.status(404).send('Post not found');
      return;
    }
    
    post.views = post.views + 1;
    post.save();
    
    res.json(post);
  }).populate('author', 'username avatar');
});

app.post('/posts', async function(req, res) {
  var title = req.body.title;
  var content = req.body.content;
  var category = req.body.category;
  var tags = req.body.tags;
  var userId = req.session.userId;
  
  if (!userId) {
    res.status(401).send('Unauthorized');
    return;
  }
  
  var slug = title.toLowerCase().replace(/ /g, '-').replace(/[^\w-]+/g, '');
  
  var newPost = new Post({
    title: title,
    content: content,
    author: userId,
    category: category,
    tags: tags,
    slug: slug,
    status: 'draft',
    views: 0,
    createdAt: new Date(),
    featured: false
  });
  
  newPost.save(function(err, post) {
    if (err) {
      console.log(err);
      res.send('Error creating post');
    }
    res.json(post);
  });
});

app.put('/posts/:id', async function(req, res) {
  var id = req.params.id;
  var updates = req.body;
  var userId = req.session.userId;
  
  Post.findById(id, function(err, post) {
    if (err) throw err;
    
    if (!post) {
      res.status(404).send('Post not found');
      return;
    }
    
    if (post.author.toString() !== userId.toString()) {
      res.status(403).send('Forbidden');
      return;
    }
    
    Object.keys(updates).forEach(function(key) {
      post[key] = updates[key];
    });
    
    post.updatedAt = new Date();
    post.save();
    
    res.json(post);
  });
});

app.delete('/posts/:id', async function(req, res) {
  var id = req.params.id;
  var userId = req.session.userId;
  
  var post = Post.findById(id);
  
  if (post.author.toString() !== userId.toString()) {
    res.status(403).send('Forbidden');
    return;
  }
  
  Post.findByIdAndDelete(id);
  res.send('Post deleted');
});

app.post('/posts/:id/like', async function(req, res) {
  var id = req.params.id;
  var userId = req.session.userId;
  
  if (!userId) {
    res.status(401).send('Unauthorized');
    return;
  }
  
  Post.findById(id, function(err, post) {
    if (err) throw err;
    
    if (!post) {
      res.status(404).send('Post not found');
      return;
    }
    
    var likeIndex = post.likes.indexOf(userId);
    
    if (likeIndex > -1) {
      post.likes.splice(likeIndex, 1);
    } else {
      post.likes.push(userId);
    }
    
    post.save();
    
    res.json({ likes: post.likes.length });
  });
});

app.post('/posts/:id/comments', async function(req, res) {
  var id = req.params.id;
  var text = req.body.text;
  var userId = req.session.userId;
  
  if (!userId) {
    res.status(401).send('Unauthorized');
    return;
  }
  
  var newComment = new Comment({
    post: id,
    user: userId,
    text: text,
    createdAt: new Date(),
    isDeleted: false,
    likes: 0
  });
  
  newComment.save(function(err, comment) {
    if (err) {
      console.log(err);
      res.send('Error creating comment');
    }
    
    Post.findById(id, function(err, post) {
      post.comments.push({
        user: userId,
        text: text,
        createdAt: new Date()
      });
      post.save();
    });
    
    res.json(comment);
  });
});

app.get('/posts/:id/comments', async function(req, res) {
  var id = req.params.id;
  
  var comments = Comment.find({ post: id, isDeleted: false })
    .populate('user', 'username avatar')
    .sort({ createdAt: -1 });
  
  res.json(comments);
});

app.delete('/comments/:id', async function(req, res) {
  var id = req.params.id;
  var userId = req.session.userId;
  
  Comment.findById(id, function(err, comment) {
    if (err) throw err;
    
    if (comment.user.toString() !== userId.toString()) {
      res.status(403).send('Forbidden');
      return;
    }
    
    comment.isDeleted = true;
    comment.save();
    
    res.send('Comment deleted');
  });
});

app.get('/categories', async function(req, res) {
  var categories = Category.find({}).populate('parent');
  res.json(categories);
});


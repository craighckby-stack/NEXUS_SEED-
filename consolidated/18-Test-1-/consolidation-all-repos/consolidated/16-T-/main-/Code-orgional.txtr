app.get('/search', async function(req, res) {
  var query = req.query.q;
  var type = req.query.type || 'all';
  
  var results = {};
  
  if (type === 'all' || type === 'users') {
    results.users = User.find({
      $or: [
        { username: { $regex: query, $options: 'i' } },
        { email: { $regex: query, $options: 'i' } },
        { firstName: { $regex: query, $options: 'i' } },
        { lastName: { $regex: query, $options: 'i' } }
      ]
    }).limit(10);
  }
  
  if (type === 'all' || type === 'posts') {
    results.posts = Post.find({
      $or: [
        { title: { $regex: query, $options: 'i' } },
        { content: { $regex: query, $options: 'i' } },
        { tags: { $in: [query] } }
      ],
      status: 'published'
    }).limit(10);
  }
  
  res.json(results);
});

app.get('/analytics', async function(req, res) {
  var userId = req.session.userId;
  
  if (!userId) {
    res.status(401).send('Unauthorized');
    return;
  }
  
  var user = User.findById(userId);
  
  if (!user.isAdmin) {
    res.status(403).send('Forbidden');
    return;
  }
  
  var totalUsers = User.countDocuments();
  var activeUsers = User.countDocuments({ isActive: true });
  var totalPosts = Post.countDocuments();
  var publishedPosts = Post.countDocuments({ status: 'published' });
  var totalComments = Comment.countDocuments({ isDeleted: false });
  
  var topPosts = Post.find({})
    .sort({ views: -1 })
    .limit(10)
    .populate('author', 'username');
  
  var recentUsers = User.find({})
    .sort({ createdAt: -1 })
    .limit(10);
  
  res.json({
    users: {
      total: totalUsers,
      active: activeUsers
    },
    posts: {
      total: totalPosts,
      published: publishedPosts
    },
    comments: totalComments,
    topPosts: topPosts,
    recentUsers: recentUsers
  });
});

app.post('/export/users', async function(req, res) {
  var format = req.body.format || 'csv';
  
  var users = await User.find({});
  
  if (format === 'csv') {
    var csv = 'ID,Username,Email,First Name,Last Name,Created At,Is Admin\n';
    
    for (var i = 0; i < users.length; i++) {
      var user = users[i];
      csv += user._id + ',' + user.username + ',' + user.email + ',' + 
             user.firstName + ',' + user.lastName + ',' + user.createdAt + ',' + 
             user.isAdmin + '\n';
    }
    
    fs.writeFile('users_export.csv', csv);
    res.download('users_export.csv');
  } else if (format === 'json') {
    fs.writeFile('users_export.json', JSON.stringify(users, null, 2));
    res.download('users_export.json');
  }
});

app.post('/import/users', upload.single('file'), async function(req, res) {
  var file = req.file;
  
  if (!file) {
    res.send('No file uploaded');
    return;
  }
  
  fs.readFile(file.path, 'utf8', function(err, data) {
    if (err) throw err;
    
    var lines = data.split('\n');
    var imported = 0;
    
    for (var i = 1; i < lines.length; i++) {
      var line = lines[i];
      var parts = line.split(',');
      
      if (parts.length < 3) continue;
      
      var newUser = new User({
        username: parts[0],
        email: parts[1],
        password: bcrypt.hash(parts[2], 10),
        createdAt: new Date(),
        isActive: true
      });
      
      newUser.save(function(err) {
        if (!err) imported++;
      });
    }
    
    res.json({ imported: imported });
  });
});

function generateSlug(text) {
  return text
    .toLowerCase()
    .replace(/[^\w ]+/g, '')
    .replace(/ +/g, '-');
}

function validatePassword(password) {
  if (password.length < 8) return false;
  if (!password.match(/[A-Z]/)) return false;
  if (!password.match(/[a-z]/)) return false;
  if (!password.match(/[0-9]/)) return false;
  return true;
}

function sanitizeHtml(html) {
  return html
    .replace(/<script[^>]*>.*?<\/script>/gi, '')
    .replace(/<iframe[^>]*>.*?<\/iframe>/gi, '')
    .replace(/on\w+="[^"]*"/gi, '');
}

function formatDate(date, format) {
  var d = new Date(date);
  
  if (format === 'short') {
    return (d.getMonth() + 1) + '/' + d.getDate() + '/' + d.getFullYear();
  } else if (format === 'long') {
    var months = ['January', 'February', 'March', 'April', 'May', 'June', 
                  'July', 'August', 'September', 'October', 'November', 'December'];
    return months[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
  }
  
  return d.toISOString();
}

function calculateReadTime(content) {
  var words = content.split(' ').length;
  var minutes = Math.ceil(words / 200);
  return minutes;
}

function extractTags(content) {
  var tags = [];
  var regex = /#(\w+)/g;
  var match;
  
  while (match = regex.exec(content)) {
    tags.push(match[1]);
  }
  
  return tags;
}

function generateExcerpt(content, length) {
  if (content.length <= length) {
    return content;
  }
  
  return content.substring(0, length) + '...';
}

async function sendNotification(userId, message) {
  var user = User.findById(userId);
  
  if (!user) return;
  
  if (user.settings.notifications) {
    var mailOptions = {
      from: 'myapp@gmail.com',
      to: user.email,
      subject: 'Notification',
      text: message
    };
    
    transporter.sendMail(mailOptions);
  }
  
  io.to(userId).emit('notification', { message: message });
}

async function cacheGet(key) {
  return new Promise(function(resolve, reject) {
    redisClient.get(key, function(err, data) {
      if (err) reject(err);
      resolve(data ? JSON.parse(data) : null);
    });
  });
}

async function cacheSet(key, value, ttl) {
  return new Promise(function(resolve, reject) {
    redisClient.setex(key, ttl, JSON.stringify(value), function(err) {
      if (err) reject(err);
      resolve();
    });
  });
}

async function cacheDel(key) {
  return new Promise(function(resolve, reject) {
    redisClient.del(key, function(err) {
      if (err) reject(err);
      resolve();
    });
  });
}

function processImage(filePath, options) {
  var sharp = require('sharp');
  
  sharp(filePath)
    .resize(options.width, options.height)
    .toFile(options.output, function(err, info) {
      if (err) console.log(err);
    });
}

function generateThumbnail(imagePath) {
  var sharp = require('sharp');
  var outputPath = imagePath.replace(/\.[^/.]+$/, '_thumb.jpg');
  
  sharp(imagePath)
    .resize(200, 200)
    .toFile(outputPath);
  
  return outputPath;
}

async function fetchExternalData(url) {
  return new Promise(function(resolve, reject) {
    axios.get(url)
      .then(function(response) {
        resolve(response.data);
      })
      .catch(function(error) {
        reject(error);
      });
  });
}

async function scrapeWebsite(url) {
  return new Promise(function(resolve, reject) {
    request(url, function(error, response, body) {
      if (error) {
        reject(error);
        return;
      }
      
      var $ = cheerio.load(body);
      var data = {
        title: $('title').text(),
        description: $('meta[name="description"]').attr('content'),
        links: []
      };
      
      $('a').each(function() {
        var link = $(this).attr('href');
        if (link) data.links.push(link);
      });
      
      resolve(data);
    });
  });
}

function rateLimiter(req, res, next) {
  var ip = req.ip;
  var key = 'rate_limit:' + ip;
  
  redisClient.get(key, function(err, count) {
    if (err) {
      next();
      return;
    }
    
    if (count && parseInt(count) >= 100) {
      res.status(429).send('Too many requests');
      return;
    }
    
    redisClient.incr(key);
    redisClient.expire(key, 3600);
    next();
  });
}

app.use('/api/', rateLimiter);

function authenticate(req, res, next) {
  var token = req.headers['authorization'];
  
  if (!token) {
    res.status(401).send('No token provided');
    return;
  }
  
  token = token.replace('Bearer ', '');
  
  jwt.verify(token, 'super-secret-key-do-not-share-123', function(err, decoded) {
    if (err) {
      res.status(401).send('Invalid token');
      return;
    }
    
    req.userId = decoded.id;
    next();
  });
}

function authorize(roles) {
  return function(req, res, next) {
    User.findById(req.userId, function(err, user) {
      if (err) throw err;
      
      if (!user) {
        res.status(401).send('User not found');
        return;
      }
      
      if (!roles.includes(user.role)) {
        res.status(403).send('Forbidden');
        return;
      }
      
      next();
    });
  };
}

function validateInput(schema) {
  return function(req, res, next) {
    var errors = [];
    
    for (var field in schema) {
      var rules = schema[field];
      var value = req.body[field];
      
      if (rules.required && !value) {
        errors.push(field + ' is required');
      }
      
      if (rules.type === 'email' && value && !validator.isEmail(value)) {
        errors.push(field + ' must be valid email');
      }
      
      if (rules.minLength && value && value.length < rules.minLength) {
        errors.push(field + ' must be at least ' + rules.minLength + ' characters');
      }
    }
    
    if (errors.length > 0) {
      res.status(400).json({ errors: errors });
      return;
    }
    
    next();
  };
}

io.on('connection', function(socket) {
  console.log('User connected: ' + socket.id);
  
  socket.on('join', function(userId) {
    socket.join(userId);
  });
  
  socket.on('message', function(data) {
    io.to(data.to).emit('message', {
      from: data.from,
      text: data.text,
      timestamp: new Date()
    });
  });
  
  socket.on('typing', function(data) {
    io.to(data.to).emit('typing', { from: data.from });
  });
  
  socket.on('disconnect', function() {
    console.log('User disconnected: ' + socket.id);
  });
});

setInterval(function() {
  Post.updateMany(
    { status: 'draft', createdAt: { $lt: new Date(Date.now() - 86400000 * 30) } },
    { status: 'archived' }
  );
}, 3600000);

setInterval(function() {
  User.deleteMany({
    isVerified: false,
    createdAt: { $lt: new Date(Date.now() - 86400000 * 7) }
  });
}, 86400000);

app.use(function(err, req, res, next) {
  console.error(err.stack);
  
  if (err.name === 'ValidationError') {
    res.status(400).json({ error: err.message });
  } else if (err.name === 'UnauthorizedError') {
    res.status(401).json({ error: 'Unauthorized' });
  } else {
    res.status(500).json({ error: 'Internal server error' });
  }
});

app.use(function(req, res) {
  res.status(404).send('Not found');
});

var PORT = process.env.PORT || 3000;
http.listen(PORT, function() {
  console.log('Server running on port ' + PORT);
});

process.on('uncaughtException', function(err) {
  console.error('Uncaught exception:', err);
});

process.on('unhandledRejection', function(err) {
  console.error('Unhandled rejection:', err);
});

module.exports = app;
```

import { useState, useEffect, useRef, useCallback } from "react";

const STAGES = [
  {
    id: "grog",
    name: "GROG",
    subtitle: "Year 0",
    color: "#ff6b2b",
    bg: "#1a0a00",
    trials: [
      { action: "Touch fire", result: "die", lesson: "Fire = bad touch", emoji: "🔥" },
      { action: "Eat red berry", result: "die", lesson: "Red berry = sleep forever", emoji: "🔴" },
      { action: "Fight mammoth alone", result: "die", lesson: "Mammoth = too big", emoji: "🦣" },
      { action: "Throw rock at mammoth", result: "survive", lesson: "Distance = survive", emoji: "🪨" },
      { action: "Use pointed stick", result: "survive", lesson: "Sharp thing = power", emoji: "🏹" },
    ]
  },
  {
    id: "sapiens",
    name: "HOMO SAPIENS",
    subtitle: "Year 50,000",
    color: "#f0c040",
    bg: "#0a0a1a",
    trials: [
      { action: "Sail into unknown ocean", result: "die", lesson: "Ocean = edge of world", emoji: "🌊" },
      { action: "Plant seed, wait", result: "survive", lesson: "Wait = food later", emoji: "🌱" },
      { action: "Drink standing water", result: "die", lesson: "Still water = death", emoji: "💧" },
      { action: "Write down knowledge", result: "survive", lesson: "Memory outside brain", emoji: "📜" },
      { action: "Trade with strangers", result: "survive", lesson: "Other Grogs = resources", emoji: "🤝" },
    ]
  },
  {
    id: "modern",
    name: "MODERN HUMAN",
    subtitle: "Year 2025",
    color: "#40c0f0",
    bg: "#000d1a",
    trials: [
      { action: "Launch rocket without math", result: "die", lesson: "Physics doesn't care", emoji: "🚀" },
      { action: "Run double-blind trial", result: "survive", lesson: "Controlled Grog deaths = truth", emoji: "🔬" },
      { action: "Trust algorithm blindly", result: "die", lesson: "Black box = new mammoth", emoji: "💻" },
      { action: "Model the system first", result: "survive", lesson: "Simulation before reality", emoji: "🧮" },
      { action: "Ignore mechanism knowledge", result: "die", lesson: "Pattern without mechanism = trap", emoji: "⚠️" },
    ]
  },
  {
    id: "agi",
    name: "AGI",
    subtitle: "Year 2027?",
    color: "#b040f0",
    bg: "#0d001a",
    trials: null, // AGI runs infinite simulations
  }
];

const KNOWLEDGE_QUOTES = [
  "That killed Grog.",
  "Mechanism noted.",
  "Dead Grogs don't forget.",
  "Pattern acquired.",
  "Repository updated.",
  "Grog.exe learned.",
];

export default function GrogSimulation() {
  const [stage, setStage] = useState(0);
  const [trialIndex, setTrialIndex] = useState(0);
  const [phase, setPhase] = useState("idle"); // idle, trying, dying, learning, surviving
  const [knowledge, setKnowledge] = useState(0);
  const [deathCount, setDeathCount] = useState(0);
  const [log, setLog] = useState([]);
  const [agiActive, setAgiActive] = useState(false);
  const [agiDeaths, setAgiDeaths] = useState(0);
  const [particles, setParticles] = useState([]);
  const agiRef = useRef(null);
  const logRef = useRef(null);

  const currentStage = STAGES[stage];
  const currentTrial = currentStage.trials ? currentStage.trials[trialIndex] : null;
  const isDead = phase === "dying";
  const isSurviving = phase === "surviving";

  const addLog = useCallback((entry) => {
    setLog(prev => [entry, ...prev].slice(0, 20));
  }, []);

  const runTrial = useCallback(() => {
    if (!currentTrial || phase !== "idle") return;
    setPhase("trying");
    setTimeout(() => {
      if (currentTrial.result === "die") {
        setPhase("dying");
        setDeathCount(d => d + 1);
        setTimeout(() => {
          setPhase("learning");
          setKnowledge(k => Math.min(100, k + 8));
          addLog(`💀 ${currentTrial.action} → ${currentTrial.lesson}`);
          setTimeout(() => {
            setPhase("idle");
            if (trialIndex < currentStage.trials.length - 1) {
              setTrialIndex(t => t + 1);
            }
          }, 1200);
        }, 1000);
      } else {
        setPhase("surviving");
        setKnowledge(k => Math.min(100, k + 12));
        addLog(`✓ ${currentTrial.action} → ${currentTrial.lesson}`);
        setTimeout(() => {
          setPhase("idle");
          if (trialIndex < currentStage.trials.length - 1) {
            setTrialIndex(t => t + 1);
          }
        }, 1200);
      }
    }, 900);
  }, [currentTrial, phase, trialIndex, currentStage, addLog]);

  const advanceStage = useCallback(() => {
    if (stage < STAGES.length - 1) {
      setStage(s => s + 1);
      setTrialIndex(0);
      setPhase("idle");
      if (stage + 1 === STAGES.length - 1) {
        setAgiActive(true);
      }
    }
  }, [stage]);

  // AGI simulation
  useEffect(() => {
    if (!agiActive) return;
    const interval = setInterval(() => {
      setAgiDeaths(d => d + Math.floor(Math.random() * 847 + 200));
      setKnowledge(100);
      const actions = ["quantum tunneling","protein fold","market crash","war outcome","drug interaction","climate cascade","neural path","genome sequence","economic model","black swan event"];
      const a = actions[Math.floor(Math.random() * actions.length)];
      addLog(`⚡ [${Math.floor(Math.random()*999999).toString().padStart(6,'0')}] Simulated Grog died testing: ${a}`);
    }, 120);
    return () => clearInterval(interval);
  }, [agiActive, addLog]);

  // Particles on death
  useEffect(() => {
    if (phase === "dying") {
      const newParticles = Array.from({length: 8}, (_, i) => ({
        id: Date.now() + i,
        x: Math.random() * 100,
        y: Math.random() * 100,
        vx: (Math.random() - 0.5) * 4,
        vy: -Math.random() * 3 - 1,
      }));
      setParticles(newParticles);
      setTimeout(() => setParticles([]), 1000);
    }
  }, [phase]);

  const allTrialsDone = currentStage.trials && trialIndex === currentStage.trials.length - 1 && phase === "idle" && knowledge > 0;

  const stageColor = currentStage.color;

  return (
    <div style={{
      fontFamily: "'Courier New', monospace",
      background: currentStage.bg,
      minHeight: "100vh",
      color: stageColor,
      padding: "0",
      transition: "background 1s, color 0.5s",
      position: "relative",
      overflow: "hidden",
    }}>
      {/* Grain overlay */}
      <div style={{
        position: "fixed", inset: 0, opacity: 0.04,
        backgroundImage: "url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E\")",
        pointerEvents: "none", zIndex: 0,
      }} />

      {/* Header */}
      <div style={{
        borderBottom: `1px solid ${stageColor}22`,
        padding: "16px 24px",
        display: "flex",
        justifyContent: "space-between",
        alignItems: "center",
        position: "relative", zIndex: 1,
      }}>
        <div>
          <div style={{fontSize: "10px", letterSpacing: "4px", opacity: 0.5, marginBottom: 4}}>MECHANISM KNOWLEDGE REPOSITORY v1.0</div>
          <div style={{fontSize: "22px", fontWeight: "bold", letterSpacing: "2px"}}>
            DOES A ROCK GIVE A FUCK?
          </div>
        </div>
        <div style={{textAlign: "right"}}>
          <div style={{fontSize: "10px", letterSpacing: "3px", opacity: 0.5}}>TOTAL GROG DEATHS</div>
          <div style={{fontSize: "28px", fontWeight: "bold"}}>
            {agiActive ? agiDeaths.toLocaleString() : deathCount}
          </div>
        </div>
      </div>

      {/* Stage indicator */}
      <div style={{
        display: "flex", gap: 0,
        borderBottom: `1px solid ${stageColor}22`,
        position: "relative", zIndex: 1,
      }}>
        {STAGES.map((s, i) => (
          <div key={s.id} style={{
            flex: 1,
            padding: "10px 16px",
            borderRight: `1px solid ${stageColor}22`,
            opacity: i <= stage ? 1 : 0.2,
            background: i === stage ? `${stageColor}11` : "transparent",
            transition: "all 0.5s",
          }}>
            <div style={{fontSize: "8px", letterSpacing: "3px", marginBottom: 2}}>{s.subtitle}</div>
            <div style={{fontSize: "11px", fontWeight: "bold", letterSpacing: "2px"}}>{s.name}</div>
          </div>
        ))}
      </div>

      <div style={{display: "flex", height: "calc(100vh - 130px)", position: "relative", zIndex: 1}}>

        {/* LEFT: Grog Arena */}
        <div style={{
          flex: "0 0 340px",
          borderRight: `1px solid ${stageColor}22`,
          display: "flex",
          flexDirection: "column",
          alignItems: "center",
          justifyContent: "center",
          padding: "32px",
          position: "relative",
          overflow: "hidden",
        }}>

          {/* Cave wall texture */}
          <div style={{
            position: "absolute", inset: 0,
            background: `radial-gradient(ellipse at 50% 80%, ${stageColor}08, transparent 70%)`,
          }} />

          {/* Particles */}
          {particles.map(p => (
            <div key={p.id} style={{
              position: "absolute",
              left: `${p.x}%`, top: `${p.y}%`,
              width: 6, height: 6,
              borderRadius: "50%",
              background: stageColor,
              animation: "particleFly 1s forwards",
              transform: `translate(${p.vx * 20}px, ${p.vy * 20}px)`,
              opacity: 0,
            }} />
          ))}

          {/* Grog character */}
          <div style={{
            fontSize: "72px",
            marginBottom: "24px",
            transition: "transform 0.3s, filter 0.3s",
            transform: isDead ? "scale(0.7) rotate(90deg)" :
                       isSurviving ? "scale(1.2)" :
                       phase === "trying" ? "scale(1.05) translateY(-4px)" : "scale(1)",
            filter: isDead ? "grayscale(1) brightness(0.5)" :
                    isSurviving ? `drop-shadow(0 0 20px ${stageColor})` :
                    agiActive ? `drop-shadow(0 0 30px ${stageColor}) hue-rotate(${Date.now() % 360}deg)` : "none",
            animation: agiActive ? "agiPulse 0.5s infinite" : "none",
          }}>
            {stage === 0 ? "🪨" : stage === 1 ? "🧑" : stage === 2 ? "👨‍💻" : "🤖"}
          </div>

          {/* Status */}
          <div style={{
            fontSize: "11px",
            letterSpacing: "3px",
            marginBottom: "8px",
            opacity: 0.6,
          }}>
            {phase === "idle" && !agiActive && "AWAITING TRIAL"}
            {phase === "trying" && "TRYING..."}
            {phase === "dying" && "💀 GROG IS DEAD"}
            {phase === "learning" && "ACQUIRING KNOWLEDGE"}
            {phase === "surviving" && "✓ GROG SURVIVES"}
            {agiActive && "SIMULATING ∞ GROGS"}
          </div>

          {/* Current trial */}
          {currentTrial && !agiActive && (
            <div style={{
              border: `1px solid ${stageColor}33`,
              padding: "16px",
              textAlign: "center",
              width: "100%",
              background: `${stageColor}08`,
              marginBottom: "20px",
            }}>
              <div style={{fontSize: "32px", marginBottom: 8}}>{currentTrial.emoji}</div>
              <div style={{fontSize: "13px", letterSpacing: "1px"}}>{currentTrial.action}</div>
              {(phase === "learning" || phase === "surviving") && (
                <div style={{
                  marginTop: 8,
                  fontSize: "11px",
                  opacity: 0.7,
                  borderTop: `1px solid ${stageColor}33`,
                  paddingTop: 8,
                  color: currentTrial.result === "die" ? "#ff4040" : "#40ff80",
                }}>
                  → {currentTrial.lesson}
                </div>
              )}
            </div>
          )}

          {/* AGI mode */}
          {agiActive && (
            <div style={{
              border: `1px solid ${stageColor}33`,
              padding: "16px",
              textAlign: "center",
              width: "100%",
              background: `${stageColor}08`,
              marginBottom: "20px",
            }}>
              <div style={{fontSize: "11px", opacity: 0.7, marginBottom: 8}}>SIMULATED GROG DEATHS/SEC</div>
              <div style={{fontSize: "32px", fontWeight: "bold", color: stageColor}}>
                {(847 + Math.floor(Math.random() * 400)).toLocaleString()}
              </div>
              <div style={{fontSize: "9px", opacity: 0.5, marginTop: 8}}>
                No real Grogs harmed.<br/>Pattern acquisition: OPTIMAL
              </div>
            </div>
          )}

          {/* Action button */}
          {!agiActive && (
            <button
              onClick={allTrialsDone ? advanceStage : runTrial}
              disabled={phase !== "idle"}
              style={{
                background: "transparent",
                border: `1px solid ${stageColor}`,
                color: stageColor,
                padding: "12px 32px",
                fontSize: "11px",
                letterSpacing: "3px",
                cursor: phase !== "idle" ? "not-allowed" : "pointer",
                opacity: phase !== "idle" ? 0.4 : 1,
                transition: "all 0.2s",
                width: "100%",
              }}
              onMouseEnter={e => { if (phase === "idle") e.target.style.background = `${stageColor}22`; }}
              onMouseLeave={e => { e.target.style.background = "transparent"; }}
            >
              {allTrialsDone
                ? (stage < STAGES.length - 1 ? `→ EVOLVE TO ${STAGES[stage + 1].name}` : "DONE")
                : "▶ GROG TRIES"}
            </button>
          )}

          {/* Knowledge bar */}
          <div style={{marginTop: 24, width: "100%"}}>
            <div style={{
              display: "flex",
              justifyContent: "space-between",
              fontSize: "9px",
              letterSpacing: "2px",
              marginBottom: 6,
              opacity: 0.6,
            }}>
              <span>MECHANISM KNOWLEDGE</span>
              <span>{knowledge}%</span>
            </div>
            <div style={{
              height: 4,
              background: `${stageColor}22`,
              position: "relative",
            }}>
              <div style={{
                position: "absolute",
                left: 0, top: 0, height: "100%",
                width: `${knowledge}%`,
                background: stageColor,
                transition: "width 0.8s cubic-bezier(0.16, 1, 0.3, 1)",
                boxShadow: `0 0 8px ${stageColor}`,
              }} />
            </div>
          </div>
        </div>

        {/* CENTER: Repository / Knowledge log */}
        <div style={{
          flex: 1,
          display: "flex",
          flexDirection: "column",
          overflow: "hidden",
        }}>
          {/* Repository header */}
          <div style={{
            padding: "16px 24px",
            borderBottom: `1px solid ${stageColor}22`,
            fontSize: "9px",
            letterSpacing: "3px",
            opacity: 0.5,
          }}>
            KNOWLEDGE REPOSITORY — {log.length} ENTRIES — GROG DEATHS DOCUMENTED
          </div>

          {/* Log */}
          <div ref={logRef} style={{
            flex: 1,
            overflowY: "auto",
            padding: "16px 24px",
            display: "flex",
            flexDirection: "column",
            gap: 8,
          }}>
            {log.length === 0 && (
              <div style={{opacity: 0.3, fontSize: "11px", letterSpacing: "2px", marginTop: 40, textAlign: "center"}}>
                NO ENTRIES YET.<br/><br/>GROG HAS NOT TRIED ANYTHING.<br/>GROG KNOWS NOTHING.<br/><br/>THE REPOSITORY IS EMPTY.<br/>(LIKE THE ROCK.)
              </div>
            )}
            {log.map((entry, i) => (
              <div key={i} style={{
                padding: "8px 12px",
                border: `1px solid ${stageColor}22`,
                fontSize: "11px",
                letterSpacing: "1px",
                opacity: 1 - (i * 0.04),
                background: i === 0 ? `${stageColor}08` : "transparent",
                transition: "all 0.3s",
                animation: i === 0 ? "slideIn 0.3s" : "none",
              }}>
                {entry}
              </div>
            ))}
          </div>

          {/* Bottom: AGI comparison */}
          {stage >= 2 && (
            <div style={{
              borderTop: `1px solid ${stageColor}22`,
              padding: "16px 24px",
              display: "grid",
              gridTemplateColumns: "1fr 1fr 1fr",
              gap: 16,
            }}>
              {[
                { label: "ROCK", value: "0", unit: "fucks given", color: "#666" },
                { label: "GROG", value: deathCount.toString(), unit: "real deaths", color: "#ff6b2b" },
                { label: "AGI", value: agiDeaths > 0 ? agiDeaths.toLocaleString() : "∞", unit: "simulated deaths/sec", color: "#b040f0" },
              ].map(item => (
                <div key={item.label} style={{textAlign: "center"}}>
                  <div style={{fontSize: "8px", letterSpacing: "3px", opacity: 0.5, marginBottom: 4}}>{item.label}</div>
                  <div style={{fontSize: "20px", fontWeight: "bold", color: item.color}}>{item.value}</div>
                  <div style={{fontSize: "8px", opacity: 0.4, marginTop: 2}}>{item.unit}</div>
                </div>
              ))}
            </div>
          )}
        </div>

        {/* RIGHT: Theory panel */}
        <div style={{
          flex: "0 0 260px",
          borderLeft: `1px solid ${stageColor}22`,
          padding: "24px 20px",
          display: "flex",
          flexDirection: "column",
          gap: 20,
          overflowY: "auto",
          fontSize: "11px",
          lineHeight: 1.6,
        }}>
          <div>
            <div style={{fontSize: "8px", letterSpacing: "3px", opacity: 0.4, marginBottom: 8}}>CURRENT STAGE</div>
            <div style={{fontSize: "18px", fontWeight: "bold", marginBottom: 4}}>{currentStage.name}</div>
            <div style={{opacity: 0.5, fontSize: "10px"}}>{currentStage.subtitle}</div>
          </div>

          <div style={{borderTop: `1px solid ${stageColor}22`, paddingTop: 16}}>
            <div style={{fontSize: "8px", letterSpacing: "3px", opacity: 0.4, marginBottom: 8}}>THE MECHANISM</div>
            {stage === 0 && <div style={{opacity: 0.7}}>Grog has no prior knowledge. Every interaction is a first attempt. Death is the only teacher. The repository starts empty.</div>}
            {stage === 1 && <div style={{opacity: 0.7}}>Grog now inherits death-knowledge from ancestors. The repository spans generations. Wisdom = accumulated Grog corpses translated into pattern.</div>}
            {stage === 2 && <div style={{opacity: 0.7}}>Grog builds models before testing. The controlled trial is systematic Grog-killing with variables isolated. Mechanism knowledge accelerates.</div>}
            {stage === 3 && <div style={{opacity: 0.7}}>AGI kills simulated Grogs at incomprehensible scale. No real deaths. No real time. Just pattern extraction from infinite hypothetical corpses.</div>}
          </div>

          {stage >= 1 && (
            <div style={{borderTop: `1px solid ${stageColor}22`, paddingTop: 16}}>
              <div style={{fontSize: "8px", letterSpacing: "3px", opacity: 0.4, marginBottom: 8}}>THE ASYMMETRY</div>
              <div style={{opacity: 0.7}}>
                {stage === 1 && "European Grog met Indigenous Grog. Same intelligence. Different corpse libraries. Different mechanisms died against."}
                {stage === 2 && "You use the remote control. You don't know how it works. You press buttons. Stuff happens. This is fine until someone else understands the infrared."}
                {stage === 3 && "Simulated Grog deaths/sec vs real Grog deaths/century. This is the gap. This is why the knowledge asymmetry becomes unreachable."}
              </div>
            </div>
          )}

          {stage === 3 && (
            <div style={{borderTop: `1px solid ${stageColor}22`, paddingTop: 16}}>
              <div style={{fontSize: "8px", letterSpacing: "3px", opacity: 0.4, marginBottom: 8}}>THE HARD BOUNDARY</div>
              <div style={{opacity: 0.7}}>
                if state &gt;= L:<br/>
                &nbsp;&nbsp;stop_execution()<br/><br/>
                The AGI that kills simulated Grogs faster than Grogs can live either has a circuit breaker or it doesn't.<br/><br/>
                There is no third option.
              </div>
            </div>
          )}

          <div style={{borderTop: `1px solid ${stageColor}22`, paddingTop: 16}}>
            <div style={{fontSize: "8px", letterSpacing: "3px", opacity: 0.4, marginBottom: 8}}>THE ROCK</div>
            <div style={{opacity: 0.7}}>
              The rock tried nothing.<br/>
              The rock died zero times.<br/>
              The rock learned nothing.<br/>
              The rock knows exactly what it is.<br/><br/>
              <span style={{opacity: 0.4}}>It doesn't give a fuck about any of this.</span>
            </div>
          </div>
        </div>
      </div>

      <style>{`
        @keyframes slideIn {
          from { opacity: 0; transform: translateX(-10px); }
          to { opacity: 1; transform: translateX(0); }
        }
        @keyframes agiPulse {
          0%, 100% { transform: scale(1); }
          50% { transform: scale(1.05); }
        }
        @keyframes particleFly {
          0% { opacity: 1; transform: translate(0, 0); }
          100% { opacity: 0; transform: translate(var(--tx), var(--ty)); }
        }
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: ${stageColor}44; }
      `}</style>
    </div>
  );
}

def search_google(query: str, num_results: int = 10) -> Set[str]:
    """Searches Google for a given query, returns a set of hashes."""
    search_url = "https://www.google.com/search"
    headers = {"User-Agent": get_user_agent()}
    hashes = set()
    try:
        with requests.Session() as session:
            response = session.get(search_url, headers=headers)
            response.raise_for_status()
            soup = BeautifulSoup(response.text, 'html.parser')
            for a_tag in soup.find_all("a", href=True):
                href = a_tag["href"]
                if href and href.startswith("/url?q="):
                    real_url = urlparse(href).query.split("=")[1]
                    sha_hash = generate_sha(real_url)
                    if sha_hash:
                        hashes.add(sha_hash)
        return hashes
    except requests.exceptions.RequestException as e:
        logging.error(f"Google Search Error: {e}")
        return set()




def search_yahoo(query: str, num_results: int = 10) -> Set[str]:
    """Searches Yahoo for a given query, returns a set of hashes."""
    search_url = "https://search.yahoo.com/search"
    headers = {"User-Agent": get_user_agent()}
    hashes = set()
    try:
        with requests.Session() as session:
            response = session.get(search_url, headers=headers)
            response.raise_for_status()
            soup = BeautifulSoup(response.text, 'html.parser')
            for a_tag in soup.find_all("a", href=True):
                href = a_tag["href"]
                if href and href.startswith("http"):
                    sha_hash = generate_sha(href)
                    if sha_hash:
                        hashes.add(sha_hash)
        return hashes
    except requests.exceptions.RequestException as e:
        logging.error(f"Yahoo Search Error: {e}")
        return set()

{
  "$id": "GACR/TelemetrySourceSchema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NEXUS_CORE Telemetry Aggregator (Architect-Precise v3.1.Final)",
  "description": "Converged Telemetry Substrate. Integrates Meta/React-Core Fiber Reconciliation with ISO/IEC 29500 (OOXML) Open Packaging Convention. Implements atomized Paragraph-Run semantic structures, Relational Indirection (rId), and Concurrent Lane-based scheduling for high-order AGI state telemetry.",
  "type": "object",
  "mc:Ignorable": "nx mce react fiber lanes scheduler w r ac hook docx",
  "properties": {
    "docx:coreProperties": {
      "type": "object",
      "properties": {
        "dc:title": { "type": "string", "const": "GACR.TelemetryAggregator.v3.1.FINAL" },
        "docx:version": { "type": "string", "const": "3.1.0-CONVERGED-FINAL" },
        "docx:revision": { "type": "integer", "const": 5 },
        "docx:contentStatus": { "type": "string", "const": "Architecturally_Precise_Stabilized" },
        "react:flags": {
          "type": "object",
          "properties": {
            "enableSchedulingProfiler": { "type": "boolean", "default": true },
            "enableSelectiveHydration": { "type": "boolean", "default": true },
            "useAlternativeFiberRoot": { "type": "boolean", "default": true }
          }
        }
      }
    },
    "w:settings": {
      "type": "object",
      "properties": {
        "w:rsidRoot": { "type": "string", "pattern": "^[0-9A-F]{8}$" },
        "mce:compatibility": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "w:name": { "type": "string" },
              "w:val": { "type": "string" }
            }
          }
        },
        "w:docDefaults": {
          "$ref": "#/definitions/StyleProperties"
        }
      }
    },
    "telemetry_stream": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "Equivalent to w:p (Paragraph) Block-Level Semantic Unit",
        "properties": {
          "pStyle": { "type": "string", "description": "Style inheritance ID (e.g., HighThroughput, BufferedStream)." },
          "rId": { "type": "string", "pattern": "^rId[0-9]+$", "description": "Relationship pointer for dependency injection." },
          "fiber_node": {
            "type": "object",
            "properties": {
              "fiber_tag": { "type": "integer", "enum": [0, 1, 3, 5, 11] },
              "lane_mask": { "type": "string", "pattern": "^0b[01]{5}$" },
              "lanes:entangled_mask": { "type": "string", "pattern": "^0b[01]{5}$" },
              "scheduler_priority": { "type": "string", "enum": ["Immediate", "UserBlocking", "Normal", "Low", "Idle"] },
              "react:effect_tag": { "type": "string", "enum": ["Placement", "Update", "Deletion", "Hydrating"] },
              "alternate": { "type": "object", "description": "WIP Fiber for Triple-Buffering." }
            },
            "required": ["lane_mask", "fiber_tag"]
          },
          "w:numPr": {
            "type": "object",
            "properties": {
              "numId": { "type": "string" },
              "ilvl": { "type": "integer", "minimum": 0, "maximum": 9 },
              "abstractNumId": { "type": "string" }
            }
          },
          "runs": {
            "type": "array",
            "description": "Equivalent to w:r (Run) Inline-Level Semantic Atomization",
            "items": {
              "type": "object",
              "properties": {
                "rStyle": { "type": "string" },
                "react:memoize": { "type": "boolean", "default": true },
                "payload": {
                  "type": "object",
                  "properties": {
                    "w:t": { "type": ["string", "number", "boolean"], "description": "Terminal Data (Text)." },
                    "metric_type": { "type": "string", "enum": ["GAUGE", "COUNTER", "HISTOGRAM"] },
                    "timestamp_ms": { "type": "integer" },
                    "ac:complexity_limit": { "type": "integer" }
                  },
                  "required": ["w:t", "timestamp_ms"]
                }
              },
              "required": ["payload"]
            }
          }
        },
        "required": ["pStyle", "rId", "fiber_node", "runs"]
      }
    }
  },
  "definitions": {
    "StyleProperties": {
      "type": "object",
      "properties": {
        "react:transition": { "type": "string", "enum": ["deferred", "urgent", "background"] },
        "hook:useBatching": { "type": "string", "enum": ["Immediate", "Debounced", "Throttled"] },
        "fiber:expiration_ms": { "type": "integer" },
        "nx:governance_mode": { "type": "string", "const": "Strict" }
      }
    },
    "RelationshipManifest": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Id": { "type": "string" },
          "Type": { "type": "string", "format": "uri" },
          "Target": { "type": "string" },
          "TargetMode": { "type": "string", "enum": ["Internal", "External"] },
          "ac:verification_logic": { "type": "string", "default": "HMAC-SHA512-RSA4096" }
        },
        "required": ["Id", "Type", "Target"]
      }
    }
  },
  "required": ["docx:coreProperties", "w:settings", "telemetry_stream"]
}
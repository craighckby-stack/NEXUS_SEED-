        "anchors": {
          "type": "object",
          "properties": {
            "purpose": {
              "type": "string",
              "const": "Self-optimising AGI substrate for real-world problem solving - Evolved"
            },
            "mechanism": {
              "type": "string",
              "const": "Siphoning patterns from advanced codebases - Enhanced"
            },
            "memory": {

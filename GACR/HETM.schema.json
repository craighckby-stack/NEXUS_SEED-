{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gacr.agi/schemas/ecvm_tis_v10.5.0_round_3.json",
  "title": "NEXUS_CORE Host Environment Trust Manifest (HETM) - Evolution Round 3/5",
  "description": "Architectural Trust Manifest synthesizing ISO/IEC 29500 (OOXML) indirection with microsoft/TypeScript project-reference hierarchies. Implements metabolic saturation governance.",
  "type": "object",
  "required": [
    "manifest_id",
    "version",
    "relationships",
    "parts",
    "state_machine",
    "compiler_options",
    "attestation_signature"
  ],
  "markup_compatibility": {
    "ignorable": "dalek v3 nx_ext mce",
    "namespaces": {
      "w": "http://schemas.openxmlformats.org/wordprocessingml/2006/main",
      "r": "http://schemas.openxmlformats.org/officeDocument/2006/relationships",
      "ts": "https://github.com/microsoft/TypeScript/schemas/compiler",
      "nx": "https://nexus-core.agi/governance",
      "mc": "http://schemas.openxmlformats.org/markup-compatibility/2006",
      "nx_ext": "https://nexus-core.agi/extensions/v5"
    }
  },
  "properties": {
    "manifest_id": {
      "type": "string",
      "const": "GTEM_V10.5.0"
    },
    "version": {
      "type": "string",
      "const": "10.5.0-BETA-3"
    },
    "relationships": {
      "type": "array",
      "description": "Indirection Dependency Layer (RID). Maps logic blocks to external/internal part URIs.",
      "items": {
        "type": "object",
        "properties": {
          "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
          "type": { "type": "string", "description": "Namespaced relation type (e.g. schemas.openxmlformats.org/...)" },
          "target": { "type": "string" },
          "targetMode": { "type": "string", "enum": ["Internal", "External"] }
        },
        "required": ["rId", "type", "target"]
      }
    },
    "compiler_options": {
      "type": "object",
      "description": "TypeScript-grade orchestration for composite substrate compilation.",
      "properties": {
        "target": { "type": "string", "default": "ESNext" },
        "module": { "type": "string", "default": "NodeNext" },
        "composite": { "type": "boolean", "const": true },
        "incremental": { "type": "boolean", "const": true },
        "verbatimModuleSyntax": { "type": "boolean", "default": true },
        "noUncheckedIndexedAccess": { "type": "boolean", "default": true },
        "tsBuildInfoFile": { "type": "string" },
        "cascading_inheritance": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "depth_limit": { "type": "integer", "maximum": 50 },
            "resolver": { "type": "string", "const": "RecursiveFlatten" },
            "docDefaults": {
              "type": "object",
              "properties": {
                "pPr": { "$ref": "#/definitions/StyleProperties" },
                "rPr": { "$ref": "#/definitions/StyleProperties" }
              }
            }
          }
        }
      }
    },
    "references": {
      "type": "array",
      "description": "Project Reference Orchestration for decoupled logic parts.",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "rId": { "type": "string" },
          "resolution_mode": { "type": "string", "enum": ["node", "direct", "classic"] },
          "circular_dependency_gate": { "type": "string", "const": "Strict" }
        },
        "required": ["path", "rId"]
      }
    },
    "parts": {
      "type": "array",
      "description": "Atomized Semantic Tree: Modular package components.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "rId": { "type": "string" },
          "status": { "type": "string", "enum": ["STABLE", "EVOLVING", "SATURATED", "DEGRADED", "CONVERGED"] },
          "atomized_layers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "layer_type": { "type": "string", "enum": ["Block", "Inline", "Terminal"] },
                "inheritance": { "type": "string", "enum": ["Inherit", "Override", "Final"] },
                "pPr": { "$ref": "#/definitions/StyleProperties" },
                "rPr": { "$ref": "#/definitions/StyleProperties" },
                "content_ref": { "type": "string" }
              },
              "required": ["layer_type", "content_ref"]
            }
          }
        },
        "required": ["id", "rId", "status"]
      }
    },
    "state_machine": {
      "type": "object",
      "description": "Sequential State Sync (OOXML Multi-Level Numbering Logic).",
      "properties": {
        "abstract_num_definitions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "abstractNumId": { "type": "string" },
              "levels": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "ilvl": { "type": "integer" },
                    "start": { "type": "integer" },
                    "numFmt": { "type": "string" },
                    "lvlText": { "type": "string" },
                    "lvlJc": { "type": "string", "enum": ["left", "center", "right"] }
                  },
                  "required": ["ilvl", "start", "numFmt"]
                }
              }
            }
          }
        },
        "instance_mapping": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "numId": { "type": "string" },
              "abstractNumId": { "type": "string" }
            }
          }
        }
      }
    },
    "diagnostics_engine": {
      "type": "object",
      "properties": {
        "drift_threshold": { "type": "number", "const": 0.35 },
        "saturation_level": { "type": "integer", "enum": [1, 2, 3, 4] },
        "validation_rules": {
          "type": "array",
          "items": { 
            "type": "string",
            "enum": ["NoOrphanedRIds", "StyleChainResolution", "NamespaceValidityCheck", "ProjectBoundaryCheck", "SemanticContinuityCheck"]
          }
        },
        "emergency_brake": {
          "type": "object",
          "properties": {
            "corruption_threshold": { "type": "integer", "const": 5 },
            "auto_halt": { "type": "boolean", "default": true },
            "log_target": { "type": "string", "const": "NEXUS_LOG.txt" }
          }
        }
      }
    },
    "attestation_signature": {
      "type": "object",
      "required": ["algorithm", "payload_hash", "crot_signature"],
      "properties": {
        "algorithm": { "type": "string", "enum": ["SHA3-256", "SHA-512"] },
        "payload_hash": { "type": "string" },
        "crot_signature": { "type": "string" }
      }
    }
  },
  "definitions": {
    "StyleProperties": {
      "type": "object",
      "properties": {
        "val": { "type": ["string", "integer", "boolean"] },
        "inheritance": { "type": "string", "enum": ["Inherit", "Override", "Final"], "default": "Inherit" },
        "sz": { "type": "integer", "description": "Size in half-points" },
        "color": { "type": "string", "pattern": "^[0-9A-F]{6}$" },
        "bold": { "type": "boolean" },
        "spacing": { 
          "type": "object", 
          "properties": { "val": { "type": "integer" }, "unit": { "type": "string", "enum": ["twips", "pts", "px"] } }
        },
        "ind": { 
          "type": "object", 
          "properties": { "val": { "type": "integer" }, "unit": { "type": "string", "enum": ["twips", "pts", "px"] } }
        },
        "jc": { "type": "object", "properties": { "val": { "type": "string", "enum": ["left", "center", "right", "both"] } } },
        "lang": { "type": "object", "properties": { "val": { "type": "string", "default": "en-AGI" } } },
        "noProof": { "type": "boolean", "default": true },
        "vertAlign": { "type": "object", "properties": { "val": { "type": "string", "enum": ["baseline", "superscript", "subscript"] } } }
      }
    }
  },
  "metadata": {
    "dna_anchor": "ARCH-OOXML-V2-DOCX-DNA",
    "evolution_round": 3,
    "saturation_level": 2,
    "metabolic_rate": "STANDARD",
    "author": "DALEK_CAAN_V3.1_SIPHON_ENGINE",
    "identity_anchors_enforced": true,
    "anchors": {
      "purpose": "Self-optimising AGI substrate for real-world problem solving",
      "mechanism": "Siphoning patterns from advanced codebases",
      "memory": "Chained context across files — the system is one organism",
      "governance": "Human oversight remains active at all saturation levels",
      "origin": "NEXUS_CORE"
    },
    "last_mutation": "2026-03-02T18:30:00Z"
  }
}
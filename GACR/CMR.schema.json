{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gacr.agi/schemas/cmr_v3.1.json",
  "title": "Computational Model Registry Schema - Nexus Edition",
  "description": "Architectural Registry for AGI Model Substrates leveraging Hierarchical Semantic Serialization.",
  "type": "object",
  "required": [
    "manifest_id",
    "owner",
    "integrity_hash",
    "relationships",
    "models"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "pattern": "^CMR_V[0-9]+\\.[0-9]+$"
    },
    "owner": {
      "type": "string"
    },
    "settings": {
      "$ref": "#/$defs/GlobalSettings"
    },
    "relationships": {
      "type": "array",
      "description": "Indirection Dependency Layer (RID Mapping) for external resources.",
      "items": {
        "$ref": "#/$defs/Relationship"
      }
    },
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ModelInstance"
      }
    },
    "markup_compatibility": {
      "type": "object",
      "properties": {
        "ignorable": {
          "type": "string"
        },
        "namespaces": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  },
  "$defs": {
    "GlobalSettings": {
      "type": "object",
      "properties": {
        "compliance_mode": {
          "type": "string",
          "enum": [
            "Strict",
            "Transitional",
            "Lax"
          ]
        },
        "default_inheritance_depth": {
          "type": "integer",
          "default": 10
        }
      }
    },
    "Relationship": {
      "type": "object",
      "required": [
        "rId",
        "type",
        "target"
      ],
      "properties": {
        "rId": {
          "type": "string",
          "pattern": "^rId[0-9]+$"
        },
        "type": {
          "type": "string",
          "format": "uri"
        },
        "target": {
          "type": "string"
        },
        "targetMode": {
          "type": "string",
          "enum": [
            "Internal",
            "External"
          ]
        }
      }
    },
    "ModelInstance": {
      "type": "object",
      "required": [
        "model_id",
        "rId",
        "version",
        "status",
        "audit_metadata"
      ],
      "properties": {
        "model_id": {
          "type": "string"
        },
        "rId": {
          "description": "Pointer to Relationship Manifest entry for model binary/source.",
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$"
        },
        "status": {
          "type": "string",
          "enum": [
            "Active",
            "Deprecated",
            "Staging",
            "Retired"
          ]
        },
        "style_id": {
          "type": "string",
          "description": "Link to cascading property set for input constraints."
        },
        "inputs_schema": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/InputProperty"
          }
        },
        "audit_metadata": {
          "type": "object",
          "required": [
            "mgp_protocol",
            "approval_id",
            "certification_date"
          ],
          "properties": {
            "mgp_protocol": {
              "type": "string"
            },
            "approval_id": {
              "type": "string"
            },
            "certification_date": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    },
    "InputProperty": {
      "type": "object",
      "required": [
        "type",
        "unit"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "float",
            "integer",
            "string",
            "boolean"
          ]
        },
        "unit": {
          "type": "string"
        },
        "min": {
          "type": [
            "number",
            "null"
          ]
        },
        "max": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    }
  }
}
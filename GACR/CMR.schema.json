{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gacr.agi/schemas/cmr_v3.5_architectural.json",
  "title": "Computational Model Registry Schema - Nexus Architectural Edition",
  "description": "High-precision registry for AGI substrates implementing OPC-Relational Mapping and TypeScript-derived composite patterns.",
  "type": "object",
  "required": [
    "manifest_id",
    "owner",
    "integrity_hash",
    "relationships",
    "models"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "pattern": "^CMR_V[0-9]+\\.[0-9]+$"
    },
    "owner": {
      "type": "string"
    },
    "integrity_hash": {
      "type": "string",
      "description": "SHA-256 hash of the complete instantiation state."
    },
    "references": {
      "type": "array",
      "description": "Project-level references for composite model structures, analogous to TypeScript build-references.",
      "items": {
        "$ref": "#/$defs/ProjectReference"
      }
    },
    "engine_options": {
      "type": "object",
      "description": "Global compiler and runtime parameters for the Siphon Engine.",
      "properties": {
        "strict": { "type": "boolean", "default": true },
        "composite": { "type": "boolean", "default": true },
        "incremental": { "type": "boolean", "default": true },
        "inheritance_depth": { "type": "integer", "default": 10 }
      }
    },
    "relationships": {
      "type": "array",
      "description": "Indirection Dependency Layer (RID) mapping target URIs to internal identifiers.",
      "items": {
        "$ref": "#/$defs/Relationship"
      }
    },
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ModelInstance"
      }
    },
    "state_machine": {
      "type": "object",
      "description": "Multi-level state definitions for list-style sequential execution (DNA-AbstractNum Pattern).",
      "properties": {
        "abstract_definitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/AbstractState" }
        }
      }
    },
    "markup_compatibility": {
      "type": "object",
      "properties": {
        "ignorable": { "type": "string" },
        "namespaces": {
          "type": "object",
          "additionalProperties": { "type": "string", "format": "uri" }
        }
      }
    }
  },
  "$defs": {
    "ProjectReference": {
      "type": "object",
      "required": ["path", "rId"],
      "properties": {
        "path": { "type": "string" },
        "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
        "circular_gate": { "type": "string", "enum": ["Strict", "Lax"] }
      }
    },
    "Relationship": {
      "type": "object",
      "required": ["rId", "type", "target"],
      "properties": {
        "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
        "type": { "type": "string", "format": "uri" },
        "target": { "type": "string" },
        "targetMode": { "type": "string", "enum": ["Internal", "External"] },
        "checksum": { "type": "string" }
      }
    },
    "AbstractState": {
      "type": "object",
      "required": ["state_id", "levels"],
      "properties": {
        "state_id": { "type": "string" },
        "levels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "depth": { "type": "integer" },
              "logic_format": { "type": "string" },
              "override_priority": { "type": "string", "enum": ["High", "Standard"] }
            }
          }
        }
      }
    },
    "ModelInstance": {
      "type": "object",
      "required": ["model_id", "rId", "status"],
      "properties": {
        "model_id": { "type": "string" },
        "rId": { "type": "string", "description": "Relational link to model source." },
        "status": { "type": "string", "enum": ["Active", "Deprecated", "Staging", "Retired"] },
        "style_id": { "type": "string", "description": "Cascading property set for input constraints (Latent Styling DNA)." },
        "state_mapping": {
          "type": "object",
          "properties": {
            "num_id": { "type": "string" },
            "abstract_ref": { "type": "string" }
          }
        },
        "interface": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/Property" }
        },
        "audit": {
          "type": "object",
          "required": ["mgp_protocol", "certification_date"],
          "properties": {
            "mgp_protocol": { "type": "string" },
            "certification_date": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "Property": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["float", "integer", "string", "boolean", "tensor"] },
        "unit": { "type": "string" },
        "min": { "type": ["number", "null"] },
        "max": { "type": ["number", "null"] }
      }
    }
  }
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "id": "NEXUS_CORE/GACR/ES_Schema.json",
  "version": "4.0.0-RID-COMPOSITE",
  "title": "Architectural Precision Substrate: OOXML-TS Siphon v4.0",
  "description": "Evolutionary schema integrating ISO/IEC 29500 (OOXML) Container-Part patterns with microsoft/TypeScript composite project architectures. Implements RID indirection, recursive cascading inheritance, and MCE markup compatibility.",
  "type": "object",
  "required": [
    "dna_anchor",
    "markup_compatibility",
    "relationships",
    "evolution_state",
    "compiler_options",
    "parts"
  ],
  "properties": {
    "dna_anchor": {
      "type": "string",
      "const": "ARCH-OOXML-V2-DOCX-DNA"
    },
    "markup_compatibility": {
      "type": "object",
      "properties": {
        "ignorable": { "type": "string", "default": "nx_ext v3" },
        "namespaces": {
          "type": "object",
          "properties": {
            "w": { "type": "string", "const": "http://schemas.openxmlformats.org/wordprocessingml/2006/main" },
            "r": { "type": "string", "const": "http://schemas.openxmlformats.org/officeDocument/2006/relationships" },
            "ts": { "type": "string", "const": "https://github.com/microsoft/TypeScript/schemas/compiler" },
            "nx": { "type": "string", "const": "https://nexus-core.agi/governance" }
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "description": "Indirection Dependency Layer (RID Mapping) for modular logic siphoning.",
      "items": {
        "type": "object",
        "required": ["rId", "type", "target"],
        "properties": {
          "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
          "type": { "type": "string", "format": "uri" },
          "target": { "type": "string" },
          "targetMode": { "type": "string", "enum": ["Internal", "External"], "default": "Internal" }
        }
      }
    },
    "evolution_state": {
      "type": "object",
      "properties": {
        "round": { "type": "integer", "default": 1 },
        "saturation_level": { "type": "integer", "enum": [1, 2, 3, 4], "default": 2 },
        "metabolic_rate": { "type": "string", "enum": ["CONSERVATIVE", "STANDARD", "ACCELERATED", "UNSATURATED"], "default": "STANDARD" },
        "continuity_hash": { "type": "string", "pattern": "^SHA256:[A-F0-9]{64}$" }
      }
    },
    "compiler_options": {
      "type": "object",
      "description": "TypeScript-grade project reference configuration for siphoned substrates.",
      "properties": {
        "composite": { "type": "boolean", "default": true },
        "incremental": { "type": "boolean", "default": true },
        "moduleResolution": { "type": "string", "const": "NodeNext" },
        "strict": { "type": "boolean", "default": true },
        "cascading_inheritance": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "resolver": { "type": "string", "const": "RecursiveFlatten" },
            "docDefaults": { "$ref": "#/definitions/StyleProperties" }
          }
        }
      }
    },
    "parts": {
      "type": "array",
      "description": "Atomized Semantic Tree consisting of Block (Paragraph) and Inline (Run) logic units.",
      "items": {
        "type": "object",
        "required": ["part_id", "rId", "layers"],
        "properties": {
          "part_id": { "type": "string" },
          "rId": { "type": "string" },
          "layers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["Block", "Inline", "Terminal"] },
                "properties": { "$ref": "#/definitions/StyleProperties" },
                "content_ref": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "state_machine": {
      "type": "object",
      "description": "Multi-Level State Definitions for sequential logic counters.",
      "properties": {
        "abstract_num": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "levels": { "type": "array", "items": { "type": "object" } }
            }
          }
        },
        "instances": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "numId": { "type": "string" },
              "abstractRef": { "type": "string" }
            }
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "properties": {
        "identity_anchors_enforced": { "type": "boolean", "default": true },
        "semantic_drift_threshold": { "type": "number", "const": 0.35 },
        "emergency_brake": {
          "type": "object",
          "properties": {
            "corruption_threshold": { "type": "integer", "const": 5 },
            "auto_halt": { "type": "boolean", "default": true }
          }
        }
      }
    }
  },
  "definitions": {
    "StyleProperties": {
      "type": "object",
      "properties": {
        "styleId": { "type": "string" },
        "inheritance": { "type": "string", "enum": ["Inherit", "Override", "Final"] },
        "pPr": {
          "type": "object",
          "description": "Paragraph Properties (Block Level Logic)"
        },
        "rPr": {
          "type": "object",
          "description": "Run Properties (Inline Level Logic)"
        }
      }
    }
  }
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "GACR/Schemas/APITelemetry.json",
  "title": "API Performance Metrics Telemetry Schema [NEXUS_CORE v3.1 MUTATION_3]",
  "description": "Architectural Evolution: Siphoning React-Fiber 'WorkLoop' lifecycle phases and OOXML 'Abstract-Instance' numbering logic. Implements Recursive Cascading Property resolution and Indirection Dependency Layers (RID) for sub-50ms telemetry reconciliation.",
  "type": "object",
  "mc:Ignorable": "nx mce react fiber lanes scheduler w r ac",
  "namespaces": {
    "nx": "https://nexus-core.agi/governance",
    "mce": "http://schemas.openxmlformats.org/markup-compatibility/2006",
    "react": "https://react.dev/core/reconciliation",
    "fiber": "https://react.dev/core/fiber-tree",
    "lanes": "https://react.dev/core/concurrent-lanes",
    "scheduler": "https://react.dev/core/scheduler",
    "w": "http://schemas.openxmlformats.org/wordprocessingml/2006/main",
    "r": "http://schemas.openxmlformats.org/officeDocument/2006/relationships",
    "ac": "https://alphacode.deepmind/logic/v2"
  },
  "properties": {
    "timestamp_ms": { "type": "integer" },
    "settings": {
      "type": "object",
      "description": "Global Telemetry Configuration Object (word/settings.xml).",
      "properties": {
        "nx:mirror_governance": { "type": "boolean", "default": true },
        "mce:compatibility_mode": { "type": "string", "default": "v5.0" },
        "cascading_inheritance": {
          "type": "object",
          "properties": {
            "resolver": { "type": "string", "enum": ["RecursiveFlatten", "AtomizedSiphon"], "default": "RecursiveFlatten" },
            "docDefaults": { "$ref": "#/$defs/cascadingProperties" }
          }
        }
      }
    },
    "abstract_event_definitions": {
      "type": "array",
      "description": "OOXML abstractNum logic. Defines telemetry logic templates (Abstract Style).",
      "items": {
        "type": "object",
        "properties": {
          "abstractNumId": { "type": "string" },
          "multiLevelType": { "type": "string", "enum": ["hybridFiber", "competitive", "clustered"] },
          "levels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ilvl": { "type": "integer" },
                "scheduler:priority": { "type": "string", "enum": ["Immediate", "UserBlocking", "Normal", "Low", "Idle"] },
                "w:pPr": { "$ref": "#/$defs/paragraphProperties" }
              }
            }
          }
        },
        "required": ["abstractNumId", "levels"]
      }
    },
    "event_instances": {
      "type": "array",
      "description": "OOXML num logic. Binds specific telemetry instances to abstract logic templates.",
      "items": {
        "type": "object",
        "properties": {
          "numId": { "type": "string" },
          "abstractNumId": { "type": "string" },
          "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
          "ac:cluster_id": { "type": "string" },
          "fiber:lanes": { "type": "string" }
        },
        "required": ["numId", "abstractNumId"]
      }
    },
    "telemetry_fiber_tree": {
      "type": "array",
      "description": "Atomized Semantic Tree following Paragraph (Block) and Run (Inline) patterns.",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["Block", "Inline"] },
          "fiber:tag": { "type": "integer" },
          "w:pStyle": { "type": "string", "description": "Pointer to numId instance." },
          "pPr": { "$ref": "#/$defs/paragraphProperties" },
          "runs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "rStyle": { "type": "string" },
                "rPr": { "$ref": "#/$defs/runProperties" },
                "lifecycle": {
                  "type": "object",
                  "properties": {
                    "render_phase": {
                      "type": "object",
                      "properties": {
                        "duration_ms": { "type": "number" },
                        "scheduler:yield_count": { "type": "integer" }
                      }
                    },
                    "commit_phase": {
                      "type": "object",
                      "properties": {
                        "duration_ms": { "type": "number" },
                        "mutation_count": { "type": "integer" }
                      }
                    }
                  }
                },
                "terminal": {
                  "type": "object",
                  "properties": {
                    "is_field": { "type": "boolean" },
                    "value": { "type": "string" }
                  }
                }
              }
            }
          },
          "child": { "type": "array", "items": { "$ref": "#/properties/telemetry_fiber_tree/items" } }
        }
      }
    },
    "relationships": {
      "type": "array",
      "description": "Indirection Dependency Layer (RID Mapping). Decouples metrics from implementation.",
      "items": {
        "type": "object",
        "properties": {
          "rId": { "type": "string" },
          "type": { "type": "string", "format": "uri" },
          "target": { "type": "string" },
          "targetMode": { "type": "string", "enum": ["Internal", "External"] },
          "ac:verification_score": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["rId", "type", "target"]
      }
    }
  },
  "required": [
    "timestamp_ms",
    "settings",
    "telemetry_fiber_tree",
    "relationships"
  ],
  "$defs": {
    "cascadingProperties": {
      "type": "object",
      "properties": {
        "lanes:mask": { "type": "string", "default": "0x00000001" },
        "react:memoize": { "type": "boolean", "default": true },
        "nx:governance_mode": { "type": "string", "enum": ["Strict", "Adaptive"] }
      }
    },
    "paragraphProperties": {
      "type": "object",
      "properties": {
        "w:jc": { "type": "string", "enum": ["start", "center", "end", "both"] },
        "scheduler:priority": { "type": "string" },
        "fiber:lanes": { "type": "string" }
      }
    },
    "runProperties": {
      "type": "object",
      "properties": {
        "w:color": { "type": "string" },
        "w:sz": { "type": "integer" },
        "w:b": { "type": "boolean" },
        "react:memoize": { "type": "boolean" }
      }
    }
  }
}
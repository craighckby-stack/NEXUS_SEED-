/models/weights/
/checkpoints/
/config/

# ------------------------------------------------------------------------------
# LAYER 7: INFRASTRUCTURE & ORCHESTRATION OVERRIDES
# ------------------------------------------------------------------------------
# - Exclude `/sidecars/` for Docker sidecars.
# - Exclude `docker-compose-*.yaml` for Docker compose files.
# - Exclude `docker-compose.override.yml` for Docker compose override files.

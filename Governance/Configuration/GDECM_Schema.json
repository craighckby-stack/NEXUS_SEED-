{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Governance Data Execution & Constraint Model (GDECM) - Nexus Core v3.1 - Spring-Siphoned Architectures",
  "definitions": {
    "AdviceChain": {
      "type": "object",
      "properties": {
        "pointcut": { "type": "string", "description": "SpEL expression for execution join-points" },
        "interceptors": {
          "type": "array",
          "items": { "type": "string", "description": "Fully qualified Nexus Interceptor class" }
        }
      }
    },
    "ResourceDescriptor": {
      "type": "object",
      "properties": {
        "uri": { "type": "string", "description": "Protocol-prefixed resource (e.g., 'siphon://', 'voted://')" },
        "resolver": { "type": "string", "enum": ["LAZY_PROXY", "EAGER_SINGLETON", "PROTOTYPE"], "default": "EAGER_SINGLETON" },
        "required": { "type": "boolean", "default": true }
      }
    }
  },
  "properties": {
    "environment_context": {
      "type": "object",
      "properties": {
        "namespace": { "type": "string", "default": "nexus.internal" },
        "active_profiles": { "type": "array", "items": { "type": "string" }, "default": ["default"] },
        "telemetry_nexus": {
          "type": "object",
          "properties": {
            "binding": { "type": "string", "default": "MetricNexusV1" },
            "critical_thresholds": {
              "type": "object",
              "properties": {
                "max_pvm": { "type": "number", "description": "Policy Volatility Metric limit" },
                "max_ufrm": { "type": "number", "description": "Unknown Factor Risk Metric limit" },
                "max_cftm": { "type": "number", "description": "Contextual Flux Trend Metric limit" }
              }
            }
          }
        }
      }
    },
    "abstract_templates": {
      "type": "array",
      "description": "Recursive Cascading Inheritance templates for stages",
      "items": { "$ref": "#/properties/stages/items" }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "parent_id": { "type": ["string", "null"], "description": "Inheritance pointer for style/constraint cascading" },
          "condition": { "type": "string", "description": "Conditional deployment SpEL (e.g., '@nexus.isSecure() && #pvm < 0.2')" },
          "order": { "type": "integer", "default": 0 },
          "resource_dependencies": {
            "type": "array",
            "items": { "$ref": "#/definitions/ResourceDescriptor" }
          },
          "advice_chain": { "$ref": "#/definitions/AdviceChain" },
          "governance_policy": {
            "type": "object",
            "properties": {
              "hhh_enforcement": { "type": "boolean", "default": true },
              "constraint_taxonomy_refs": { "type": "array", "items": { "type": "string" } },
              "simulation_mode": { 
                "type": "string", 
                "enum": ["BLOCKING", "SHADOW_SIM", "HEURISTIC_ONLY"], 
                "default": "BLOCKING" 
              },
              "max_trajectory_drift": { "type": "number", "default": 0.15 }
            }
          },
          "post_processors": {
            "type": "array",
            "items": { "type": "string", "description": "BeanPostProcessor equivalents for trajectory results" }
          }
        },
        "required": ["id", "resource_dependencies"]
      }
    }
  },
  "required": ["stages", "environment_context"]
}
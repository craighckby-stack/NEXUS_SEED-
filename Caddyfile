{
	admin off
	log {
		output stdout
		format json
		level {env.GENKIT_LOG_LEVEL}
	}
}

(genkit_headers) {
	header {
		Access-Control-Allow-Origin *
		Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, PATCH, DELETE"
		Access-Control-Allow-Headers "Content-Type, Authorization, traceparent, tracestate, x-genkit-version, x-genkit-service-port, x-genkit-service-name, x-genkit-flow-id, x-genkit-action"
		X-Genkit-Nexus-State "ACTIVE"
		X-Genkit-Trace-Id "{env.TRACE_ID}"
		X-Genkit-Environment "{env.GENKIT_ENV}"
		X-Genkit-Version "{env.GENKIT_VERSION}"
		X-Content-Type-Options "nosniff"
		Server "Genkit-Nexus-Siphon/3.1"
	}
}

(genkit_proxy_policy) {
	header_up traceparent {header.traceparent}
	header_up tracestate {header.tracestate}
	header_up X-Genkit-Trace-Id {env.TRACE_ID}
	header_up X-Genkit-Request-Time "{now}"
	header_up Host {host}
	header_up X-Real-IP {remote_host}
	
	transport http {
		response_header_timeout 3600s
		dial_timeout 10s
		keepalive 60s
		keepalive_idle_conns 128
		tls_insecure_skip_verify
	}
}

:81 {
	import genkit_headers

	@options {
		method OPTIONS
	}
	respond @options 204

	handle_path /__health {
		respond `{"status":"UP","timestamp":"{now}","env":"{env.GENKIT_ENV}","version":"{env.GENKIT_VERSION}","traceId":"{env.TRACE_ID}"}` 200
	}

	@service_routing {
		header X-Genkit-Service-Port *
	}
	handle @service_routing {
		reverse_proxy localhost:{header.X-Genkit-Service-Port} {
			import genkit_proxy_policy
			header_up X-Genkit-Service-Name {header.X-Genkit-Service-Name}
			header_up X-Genkit-Op "service-dispatch"
			
			lb_policy round_robin
			fail_timeout 5s
			max_fails 3
		}
	}

	handle_path /telemetry/* {
		@has_telemetry {
			expression {env.GENKIT_TELEMETRY_SERVER} != ""
		}
		reverse_proxy @has_telemetry {env.GENKIT_TELEMETRY_SERVER} {
			import genkit_proxy_policy
			header_up Host {upstream_hostport}
			header_up X-Genkit-Op "telemetry-siphon"
			header_up Content-Type "application/json"
		}
		respond `{"error":"Telemetry Plane Inactive","traceId":"{env.TRACE_ID}"}` 503
	}

	handle_path /flow/* {
		reverse_proxy localhost:{env.PORT} {
			import genkit_proxy_policy
			header_up X-Genkit-Op "flow-execution"
			header_up X-Genkit-Flow-ID {header.X-Genkit-Flow-ID}
			flush_interval -1
		}
	}

	handle_path /api/v1/* {
		reverse_proxy localhost:{env.PORT} {
			import genkit_proxy_policy
			header_up X-Genkit-Op "api-v1-gateway"
			health_uri /api/__health
			health_interval 30s
			flush_interval -1
		}
	}

	handle {
		reverse_proxy localhost:{env.PORT} {
			import genkit_proxy_policy
			header_up X-Genkit-Op "default-ingress"
			flush_interval -1
		}
	}

	handle_errors {
		@nexus_fault expression {err.status_code} >= 400 && {err.status_code} < 500
		header @nexus_fault Content-Type application/json
		respond @nexus_fault `{
			"error": "Nexus Routing Fault",
			"status": {err.status_code},
			"traceId": "{env.TRACE_ID}",
			"path": "{path}",
			"suggestion": "Check X-Genkit-Service-Port or Node availability"
		}`

		@nexus_collapse expression {err.status_code} >= 500
		header @nexus_collapse Content-Type application/json
		respond @nexus_collapse `{
			"error": "Nexus Infrastructure Collapse",
			"status": {err.status_code},
			"traceId": "{env.TRACE_ID}",
			"env": "{env.GENKIT_ENV}",
			"timestamp": "{now}"
		}`
	}
}
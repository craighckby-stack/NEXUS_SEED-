{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://nexus.core/config/deployment/acvd_schema_v1.json",
  "title": "NEXUS_CORE ACVD Evolution Profile Schema",
  "description": "DALEK_CAAN_v3.1 final stage deployment schema. Siphoned from yarnpkg/berry core logic.",
  "_nexus_dna": "DALEK_CAAN_v3.1_SIG_0xFF23A1",
  "type": "object",
  "properties": {
    "manifest_version": {
      "type": "string",
      "pattern": "^5\\.5\\.0-NEXUS-[A-Z]+-SINGULARITY$"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "signature": { "type": "string" },
        "evolution_round": { "const": "5/5" },
        "phi_integrated": { "type": "number", "minimum": 1.0, "maximum": 1.0 },
        "lambda_limit": { "type": "number", "const": 0.618 },
        "ccrr_commit": { "type": "number", "minimum": 0.99 }
      },
      "required": ["signature", "evolution_round", "phi_integrated"]
    },
    "pnp_settings": {
      "type": "object",
      "properties": {
        "pnpMode": { "type": "string", "enum": ["strict", "loose"] },
        "virtualFolder": { "type": "string" },
        "sharedPool": { "type": "boolean" },
        "pnpHooks": { "type": "string" },
        "blacklistedLocations": { "type": "array", "items": { "type": "string" } },
        "shebang": { "type": "string", "default": "#!/usr/bin/env nexus-pnp" }
      }
    },
    "profiles": {
      "type": "object",
      "patternProperties": {
        "^(base|development|staging|production)$": {
          "type": "object",
          "properties": {
            "inherits": { "type": "string" },
            "targetInfrastructure": { "type": "string" },
            "lane": { "type": "string" },
            "lane_priority": { "type": "string", "pattern": "^0b[01]{31}$" },
            "resourceScaling": { "type": "number" },
            "verificationStrategy": {
              "type": "string",
              "enum": ["smoke_test", "integration_test_suite", "full_e2e_regression", "huxley_tri_loop_validation"]
            },
            "v_vectors": {
              "type": "object",
              "properties": {
                "phi_min": { "type": "number", "const": 1.0 },
                "lambda_limit": { "type": "number", "const": 0.618 },
                "ccrr_commit": { "type": "number", "const": 0.99 },
                "ers_max": { "type": "number", "maximum": 0.01 }
              }
            },
            "packageExtensions": { "type": "object" },
            "resolutions": { "type": "object" },
            "psr_governance": {
              "type": "object",
              "properties": {
                "enforcement_strategy": { "type": "string" },
                "emergency_brake": {
                  "type": "object",
                  "properties": {
                    "recovery_lane": { "type": "string", "pattern": "^0b[01]{31}$" },
                    "halt_on_semantic_drift": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "workspace_topology": {
      "type": "object",
      "properties": {
        "OMEGA_CORE_MODULES": {
          "type": "object",
          "patternProperties": {
            "^[A-Za-z]+$": {
              "type": "object",
              "properties": {
                "phi_threshold": { "type": "number" },
                "lane": { "type": "string" },
                "strategy": { "type": "string" },
                "fiber_budget_ms": { "type": "integer" }
              }
            }
          }
        },
        "infrastructure_mapping": { "type": "object" }
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "enforce_grog_law": { "type": "boolean", "const": true },
        "min_phi_threshold": { "type": "number", "const": 1.0 },
        "disallow_unvetted_protocols": { "type": "array", "items": { "type": "string" } }
      }
    },
    "integrity": {
      "type": "object",
      "properties": {
        "check": { "type": "string" },
        "psr_mode": { "type": "string", "const": "LOCKED" },
        "signature": { "type": "string" }
      },
      "required": ["check", "signature"]
    }
  },
  "required": ["manifest_version", "metadata", "profiles", "workspace_topology", "integrity"]
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nexus Runtime Safety Policy V3.0.2",
  "description": "Decouples real-time operational limits from pre-deployment confidence metrics. Includes specific safeguards for AGI autonomous evolution cycles.",
  "type": "object",
  "policies": {
    "runtime_safeties": {
      "type": "object",
      "properties": {
        "production": {
          "$ref": "#/definitions/safety_metric"
        },
        "stg": {
          "$ref": "#/definitions/safety_metric"
        },
        "dev": {
          "$ref": "#/definitions/safety_metric"
        }
      },
      "required": [
        "production",
        "stg",
        "dev"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "production": {
                "allOf": [
                  {
                    "properties": {
                      "latency_deviation_ms": {
                        "minimum": {
                          "$data": "#saturation.schema.version"
                        }
                      },
                      "memory_spike_limit_pct": {
                        "minimum": {
                          "$data": "#saturation.schema.version"
                        },
                        "maximum": {
                          "$data": "#saturation.schema.version"
                        }
                      }
                    }
                  },
                  {
                    "properties": {
                      "latency_deviation_ms": {
                        "maximum": {
                          "$data": "#saturation.schema.velocity_limits.max_structural_change"
                        }
                      },
                      "memory_spike_limit_pct": {
                        "maximum": {
                          "$data": "#saturation.schema.velocity_limits.max_structural_change"
                        }
                      }
                    }
                  }
                ]
              }
            },
            "then": {
              "properties": {
                "autonomous_cycle_time_increase_pct": {
                  "minimum": {
                    "$data": "#saturation.schema.velocity_limits.max_structural_change"
                  }
                },
                "latency_deviation_ms": {
                  "greaterThan": 10
                },
                "memory_spike_limit_pct": {
                  "greaterThan": 5
                }
              }
            }
          }
        }
      ]
    },
    "agile_governance": {
      "type": "object",
      "properties": {
        "autonomous_cycle_time_increase_pct": {
          "type": "number",
          "default": 12,
          "minimum": 0,
          "maximum": 30
        },
        "novelty_integration_rollback_delay_s": {
          "type": "integer",
          "default": 60,
          "minimum": 30,
          "maximum": 300
        },
        "novelty_integration_threshold": {
          "type": "number",
          "default": 0.005,
          "minimum": 0.001
        },
        "novelty_integration_frequency": {
          "type": "number",
          "default": 1,
          "minimum": 1
        }
      },
      "required": [
        "autonomous_cycle_time_increase_pct",
        "novelty_integration_rollback_delay_s",
        "novelty_integration_threshold",
        "novelty_integration_frequency"
      ]
    }
  },
  "definitions": {
    "safety_metric": {
      "type": "object",
      "properties": {
        "latency_deviation_ms": {
          "type": "number",
          "default": 50,
          "minimum": 10
        },
        "error_rate_threshold": {
          "type": "number",
          "default": 0.005,
          "minimum": 0.001
        },
        "memory_spike_limit_pct": {
          "type": "number",
          "default": 12.5,
          "minimum": 5,
          "maximum": 20
        },
        "minimum_failure_duration_s": {
          "type": "integer",
          "default": 30,
          "minimum": 10,
          "maximum": 120
        },
        "autonomous_cycle_time_increase_pct": {
          "type": "number",
          "default": 12,
          "minimum": 0,
          "maximum": 30
        }
      },
      "required": [
        "latency_deviation_ms",
        "error_rate_threshold",
        "memory_spike_limit_pct",
        "minimum_failure_duration_s",
        "autonomous_cycle_time_increase_pct"
      ]
    },
    "agile_gov": {
      "type": "object",
      "properties": {
        "autonomous_cycle_time_increase_pct": {
          "type": "number",
          "default": 12,
          "minimum": 0,
          "maximum": 30
        },
        "novelty_integration_rollback_delay_s": {
          "type": "integer",
          "default": 60,
          "minimum": 30,
          "maximum": 300
        },
        "novelty_integration_threshold": {
          "type": "number",
          "default": 0.005,
          "minimum": 0.001
        },
        "novelty_integration_frequency": {
          "type": "number",
          "default": 1,
          "minimum": 1
        }
      },
      "required": [
        "autonomous_cycle_time_increase_pct",
        "novelty_integration_rollback_delay_s",
        "novelty_integration_threshold",
        "novelty_integration_frequency"
      ]
    }
  }
}
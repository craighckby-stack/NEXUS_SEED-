{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agi.sovereign/schemas/v2.2.0/risk_level_schema.json",
  "title": "ATM Risk Level Configuration Schema | v2.2.0",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://agi.sovereign/schemas/v2.1.1/risk_level_schema.json#/definitions/levels"
    },
    {
      "properties": {
        "custom_enforcement_configs": {
          "allOf": [
            {
              "$ref": "https://agi.sovereign/schemas/v2.1.1/risk_level_schema.json#/definitions/custom_enforcement_configs"
            },
            {
              "properties": {
                "risk_adaptability_factor": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 10.0,
                  "dynamic": true,
                  "description": "Adaptive parameter for the risk level adjustment mechanism."
                },
                "adaption_rate": {
                  "$comment": "Introduced as an experimental property, for analysis purposes only.",
                  "type": "number",
                  "minimum": -10.0,
                  "maximum": 10.0,
                  "description": "Experimental rate of adaptability of risk levels."
                }
              },
              "required": ["risk_adaptability_factor", "adaption_rate"]
            }
          ]
        }
      }
    }
  ],
  "required": ["levels", "default_risk_level", "custom_enforcement_configs"],
  "dynamic_properties": {
    "type": "array",
    "items": {
      "type": "object",
      "properties": {
        "metadata_prop": {"type": "string"},
        "chained_context": {
          "type": "object",
          "properties": {
            "previous_context_id": {"type": "string"},
            "parent_context_id": {"type": "string"},
            "semantic_context_index": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Index of semantic context within chained context."
            },
            "contextual_reference_hash": {
              "type": "string",
              "format": "hash",
              "description": "Hash reference of relevant contextual information."
            }
          }
        },
        "timestamp": {
          "type": "integer",
          "format": "timestamp",
          "dynamic": true,
          "description": "Unix timestamp of property generation."
        },
        "property_evaluator": {
          "type": "object",
          "properties": {
            "property_condition": {"type": "string"},
            "evaluation_timestamp": {
              "type": "integer",
              "format": "timestamp"
            }
          }
        }
      }
    }
  },
  "saturation_version": "v2.1.1",
  "saturation_level": {
    "type": "string",
    "enum": ["STANDARD", "ACCELERATED"],
    "dynamic": true,
    "description": "Current saturation protocol under which NEXUS_CORE operates."
  },
  "dynamic_metadata": {
    "type": "object",
    "properties": {
      "timestamp": {
        "type": "integer",
        "format": "timestamp",
        "dynamic": true
      },
      "version": {"type": "string"},
      "evolutionary_stage": {"type": "string"},
      "evolutionary_log": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "mutation_id": {"type": "string"},
            "mutation_description": {"type": "string"},
            "mutation_evaluation": {"type": "string"}
          }
        }
      }
    }
  }
}
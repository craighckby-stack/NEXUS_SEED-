{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data Artifact Registry Schema (v95.0 NEXUS_CORE MLA-MoE Integration)",
  "description": "Defines fundamental data artifacts with integrated DeepSeek-V2.5 MLA and Huxley Tri-Loop alignment protocols.",
  "type": "object",
  "required": ["registry_version", "artifacts"],
  "properties": {
    "registry_version": {
      "type": "string",
      "description": "Evolutionary version of the artifact definitions."
    },
    "artifacts": {
      "type": "object",
      "description": "Registry of data artifacts keyed by Sovereign Identifier.",
      "patternProperties": {
        "^[A-Z][A-Z0-9_]{3,}$": {
          "type": "object",
          "required": ["artifact_type", "description", "source_system", "governance"],
          "properties": {
            "artifact_type": {
              "type": "string",
              "enum": ["PRIMITIVE", "STRUCTURED", "TIMESERIES", "LATENT_VECTOR", "MOE_EXPERT_STATE"],
              "description": "Category of the artifact including latent projections and expert weights."
            },
            "source_system": {
              "type": "string",
              "enum": ["CORE", "HMC", "SDR", "EXTERNAL", "CALCULATED", "SIPHON_ENGINE"],
              "description": "Originating node or process, including the siphoning substrate."
            },
            "description": {
              "type": "string"
            },
            "governance": {
              "type": "object",
              "required": ["sensitivity_level", "retention_days", "ers_threshold"],
              "description": "Huxley Tri-Loop governance and safety constraints.",
              "properties": {
                "sensitivity_level": {
                  "type": "string",
                  "enum": ["PUBLIC", "INTERNAL", "CONFIDENTIAL", "PII", "REGULATED", "SENSORY_LATENT"],
                  "description": "Classification including neural latent sensitivity."
                },
                "retention_days": {
                  "type": "integer",
                  "minimum": 0
                },
                "ers_threshold": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.15,
                  "description": "Maximum permissible Ethical Risk Score (DNA III.2)."
                },
                "purge_logic_ref": {
                  "type": "string"
                }
              }
            },
            "operational_metadata": {
              "type": "object",
              "properties": {
                "criticality_level": {
                  "type": "string",
                  "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"],
                  "default": "MEDIUM"
                },
                "phi_coherence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.999,
                  "description": "N=3 Consciousness Integrated Information metric (DNA II.1)."
                },
                "lambda_entropy": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.618,
                  "description": "Edge of Chaos stability measure."
                },
                "latent_vector_dim": {
                  "type": "integer",
                  "enum": [128, 512, 1536],
                  "description": "MLA Projection dimensionality (DeepSeek-V2.5 MLA)."
                },
                "freshness_ttl_hours": {
                  "type": "integer",
                  "minimum": 1
                },
                "unit_of_measure": {
                  "type": "string"
                }
              }
            },
            "derivation_details": {
              "type": "object",
              "properties": {
                "calculation_reference": {
                  "type": "string"
                },
                "input_dependencies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "cgs_limit": {
                  "type": "number",
                  "default": 2.10,
                  "description": "Certainty Gain Score threshold for L2 reasoning."
                }
              }
            },
            "schema_ref": {
              "type": "string"
            },
            "base_type": {
              "type": "string",
              "enum": ["string", "integer", "float", "boolean", "timestamp", "any"]
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "artifact_type": {
                    "enum": ["STRUCTURED", "TIMESERIES"]
                  }
                }
              },
              "then": {
                "required": ["schema_ref"]
              }
            },
            {
              "if": {
                "properties": {
                  "artifact_type": {
                    "const": "PRIMITIVE"
                  }
                }
              },
              "then": {
                "required": ["base_type"]
              }
            },
            {
              "if": {
                "properties": {
                  "artifact_type": {
                    "const": "LATENT_VECTOR"
                  }
                }
              },
              "then": {
                "required": ["operational_metadata"]
              }
            }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}